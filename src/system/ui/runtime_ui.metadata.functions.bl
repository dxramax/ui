  }

  let enabled_when = runtime_ui_metadata_entry_text_value(
    published_entry,
    base_entry,
    "enabled_when"
  );
  if (enabled_when != null) {
    merged_entry["enabled_when"] = enabled_when;
  }

  let record_path = runtime_ui_metadata_entry_text_value(
    published_entry,
    base_entry,
    "record_path"
  );
  if (record_path != null) {
