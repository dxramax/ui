    base_entry["events"],
    published_entry["events"]
  );
  if (events != null) {
    merged_entry["events"] = events;
  }

  let items = published_entry["items"];
  if (items == null) {
    items = base_entry["items"];
  }
  if (items != null) {
    merged_entry["items"] = items;
  }

  return merged_entry;
}

private function runtime_ui_merge_control_metadata_entries(base_entries: Json, published_entries: Json): Json {
  let merged_entries: Json = [];
  let merged_count = 0;

  for (published_entry in published_entries ?? []) {
    let entry_id = Runtime.json_to_str(published_entry["id"]);
    if (entry_id == "") {
      continue;
    }
    let base_entry = runtime_ui_find_metadata_entry_by_id(base_entries, entry_id);
    if (base_entry != null) {
      merged_entries[merged_count] = runtime_ui_merge_control_metadata_entry(base_entry, published_entry);
      merged_count = merged_count + 1;
      continue;
    }
    merged_entries[merged_count] = published_entry;
    merged_count = merged_count + 1;
  }

  for (base_entry in base_entries ?? []) {
    let entry_id = Runtime.json_to_str(base_entry["id"]);
    if (entry_id == "") {
      continue;
    }
    if (runtime_ui_find_metadata_entry_by_id(published_entries, entry_id) == null) {
      merged_entries[merged_count] = base_entry;
      merged_count = merged_count + 1;
    }
  }

  return merged_entries;
}

private function runtime_ui_control_has_source_metadata(control_metadata: Json): bool {
  let source_metadata = control_metadata["source"];
  if (source_metadata == null) {
    return false;
  }

  return Runtime.json_to_str(source_metadata["name"]) != ""
    || Runtime.json_to_str(source_metadata["handler"]) != ""
    || Runtime.json_to_str(source_metadata["path"]) != ""
    || Runtime.json_to_str(source_metadata["dispatch_target"]) != "";
}

private function runtime_ui_complete_control_runtime_metadata(
  control_metadata: Json,
  state_fields: Json
): Json {
  if (control_metadata == null) {
    return null;
  }

  let control_type = Runtime.json_to_str(control_metadata["type"]);
  if (control_type != "DataGrid" && control_type != "Grid") {
    return control_metadata;
  }
  if (Runtime.json_to_str(control_metadata["pagination_path"]) != "") {
    return control_metadata;
  }
  if (!runtime_ui_control_has_source_metadata(control_metadata)) {
    return control_metadata;
  }

  let pagination_field_name = runtime_ui_find_matching_pagination_state_field_name(
    state_fields,
    Runtime.json_to_str(control_metadata["id"])
  );
  if (pagination_field_name == "") {
    return control_metadata;
  }

  control_metadata["pagination_path"] = "state." + pagination_field_name;
  return control_metadata;
}

private function runtime_ui_complete_controls_runtime_metadata(
  controls: Json,
  state_fields: Json
): Json {
  let completed_controls: Json = [];
  let completed_control_count = 0;

  for (control_metadata in controls ?? []) {
    let completed_control_metadata = runtime_ui_complete_control_runtime_metadata(
      control_metadata,
      state_fields
    );
    if (completed_control_metadata == null) {
      continue;
    }
    completed_controls[completed_control_count] = completed_control_metadata;
    completed_control_count = completed_control_count + 1;
  }

  return completed_controls;
}

private function runtime_ui_merge_button_metadata_entries(base_entries: Json, published_entries: Json): Json {
  let merged_entries: Json = [];
  let merged_count = 0;

  for (published_entry in published_entries ?? []) {
    let entry_id = Runtime.json_to_str(published_entry["id"]);
    if (entry_id == "") {
      continue;
    }
    let base_entry = runtime_ui_find_metadata_entry_by_id(base_entries, entry_id);
    if (base_entry != null) {
      merged_entries[merged_count] = runtime_ui_merge_button_metadata_entry(base_entry, published_entry);
      merged_count = merged_count + 1;
      continue;
    }
    merged_entries[merged_count] = published_entry;
    merged_count = merged_count + 1;
  }

  for (base_entry in base_entries ?? []) {
    let entry_id = Runtime.json_to_str(base_entry["id"]);
    if (entry_id == "") {
      continue;
    }
    if (runtime_ui_find_metadata_entry_by_id(published_entries, entry_id) == null) {
      merged_entries[merged_count] = base_entry;
      merged_count = merged_count + 1;
    }
  }

  return merged_entries;
}

private function runtime_ui_merge_state_field_metadata_entry(base_entry: Json, published_entry: Json): Json {
  let merged_entry = runtime_ui_merge_metadata_entry(base_entry, published_entry);

  let name = runtime_ui_metadata_entry_text_value(published_entry, base_entry, "name");
  if (name != null) {
    merged_entry["name"] = name;
  }

  let value_type = runtime_ui_metadata_entry_text_value(
    published_entry,
    base_entry,
    "value_type"
  );
  if (value_type != null) {
    merged_entry["value_type"] = value_type;
  }

  return merged_entry;
}

private function runtime_ui_merge_state_field_metadata_entries(
  base_entries: Json,
  published_entries: Json
): Json {
  let merged_entries: Json = [];
  let merged_count = 0;

  for (base_entry in base_entries ?? []) {
    let entry_name = Runtime.json_to_str(base_entry["name"]);
    let published_entry = runtime_ui_find_metadata_entry_by_name(published_entries, entry_name);
    if (published_entry != null) {
      merged_entries[merged_count] = runtime_ui_merge_state_field_metadata_entry(
        base_entry,
        published_entry
      );
    } else {
      merged_entries[merged_count] = base_entry;
    }
    merged_count = merged_count + 1;
  }

  for (published_entry in published_entries ?? []) {
    let entry_name = Runtime.json_to_str(published_entry["name"]);
    if (entry_name == "") {
      continue;
    }
    if (runtime_ui_find_metadata_entry_by_name(base_entries, entry_name) == null) {
      merged_entries[merged_count] = published_entry;
      merged_count = merged_count + 1;
    }
  }

  return merged_entries;
}

private function runtime_ui_merge_metadata_entries(base_entries: Json, published_entries: Json): Json {
  let merged_entries: Json = [];
  let merged_count = 0;

  for (base_entry in base_entries ?? []) {
    let entry_id = Runtime.json_to_str(base_entry["id"]);
    let published_entry = runtime_ui_find_metadata_entry_by_id(published_entries, entry_id);
    if (published_entry != null) {
      merged_entries[merged_count] = runtime_ui_merge_metadata_entry(base_entry, published_entry);
    } else {
      merged_entries[merged_count] = base_entry;
    }
    merged_count = merged_count + 1;
  }

  for (published_entry in published_entries ?? []) {
    let entry_id = Runtime.json_to_str(published_entry["id"]);
    if (entry_id == "") {
      continue;
    }
    if (runtime_ui_find_metadata_entry_by_id(base_entries, entry_id) == null) {
      merged_entries[merged_count] = published_entry;
      merged_count = merged_count + 1;
    }
  }

  return merged_entries;
}

private function runtime_ui_match_node_id(node_match: Json): string {
  if (node_match == null) {
    return "";
  }

  let node_id = Runtime.json_to_str(node_match["node_id"]);
  if (node_id != "") {
    return node_id;
  }

  node_id = Runtime.json_to_str(node_match["id"]);
  if (node_id != "") {
    return node_id;
  }

  return Runtime.json_to_str(node_match);
}

private function runtime_ui_list_child_node_ids(parent_node_id: string): Json {
  let normalized_parent_node_id = Runtime.json_to_str(parent_node_id);
  if (normalized_parent_node_id == "") {
    return [];
  }

  let child_node_ids: Json = [];
  let child_node_count = 0;
  let parent_node_json = ast.node_to_json(normalized_parent_node_id);

  for (child_node_ref in parent_node_json["children"] ?? []) {
    let child_node_id = runtime_ui_match_node_id(child_node_ref);
    if (child_node_id == "") {
      continue;
    }
    child_node_ids[child_node_count] = child_node_id;
    child_node_count = child_node_count + 1;
  }

  for (child_node_match in ast.list_children(normalized_parent_node_id) ?? []) {
    let child_node_id = runtime_ui_match_node_id(child_node_match);
    if (child_node_id == "") {
      continue;
    }

    let already_listed = false;
    for (listed_child_node_id in child_node_ids) {
      if (Runtime.json_to_str(listed_child_node_id) == child_node_id) {
        already_listed = true;
        break;
      }
    }
    if (already_listed) {
      continue;
    }

    child_node_ids[child_node_count] = child_node_id;
    child_node_count = child_node_count + 1;
  }

  let ordered_child_node_ids: Json = [];
  let ordered_child_node_count = 0;
  for (child_node_id in child_node_ids) {
    let insert_index = ordered_child_node_count;
    let compare_index = 0;
    for (ordered_child_node_id in ordered_child_node_ids) {
      if (
        runtime_ui_node_starts_before(
          Runtime.json_to_str(child_node_id),
          Runtime.json_to_str(ordered_child_node_id)
        )
      ) {
        insert_index = compare_index;
        break;
      }
      compare_index = compare_index + 1;
    }

    let shift_index = ordered_child_node_count;
    while (shift_index > insert_index) {
      ordered_child_node_ids[shift_index] = ordered_child_node_ids[shift_index - 1];
      shift_index = shift_index - 1;
    }
    ordered_child_node_ids[insert_index] = child_node_id;
    ordered_child_node_count = ordered_child_node_count + 1;
  }

  return ordered_child_node_ids;
}

private function runtime_ui_node_starts_before(left_node_id: string, right_node_id: string): bool {
  let normalized_left_node_id = Runtime.json_to_str(left_node_id);
  let normalized_right_node_id = Runtime.json_to_str(right_node_id);
  if (normalized_left_node_id == "" || normalized_right_node_id == "") {
    return false;
  }

  let left_range = ast.node_to_json(normalized_left_node_id)["range"];
  let right_range = ast.node_to_json(normalized_right_node_id)["range"];
  if (left_range == null || right_range == null) {
    return false;
  }

  let left_start_offset = left_range["start_offset"];
  let right_start_offset = right_range["start_offset"];
  if (left_start_offset != null && right_start_offset != null && left_start_offset != right_start_offset) {
    return Runtime.json_to_i64(left_start_offset) < Runtime.json_to_i64(right_start_offset);
  }

  let left_start_line = left_range["start_line"];
  let right_start_line = right_range["start_line"];
  if (left_start_line != null && right_start_line != null && left_start_line != right_start_line) {
    return Runtime.json_to_i64(left_start_line) < Runtime.json_to_i64(right_start_line);
  }

  let left_start_column = left_range["start_column"];
  let right_start_column = right_range["start_column"];
  if (left_start_column != null && right_start_column != null && left_start_column != right_start_column) {
    return Runtime.json_to_i64(left_start_column) < Runtime.json_to_i64(right_start_column);
  }

  return false;
}

private function runtime_ui_match_kind_name(node_match: Json): string {
  if (node_match == null) {
    return "";
  }

  let kind_name = Runtime.json_to_str(node_match["kind_name"]);
  if (kind_name != "") {
    return kind_name;
  }

  kind_name = Runtime.json_to_str(node_match["kind"]);
  if (kind_name != "") {
    return kind_name;
  }

  return Runtime.json_to_str(node_match["node_type"]);
}

private function runtime_ui_resolve_ast_node_id(node_json: Json): string {
  if (node_json == null) {
    return "";
  }

  let node_id = Runtime.json_to_str(node_json["node_id"]);
  if (node_id != "") {
    return node_id;
  }

  return Runtime.json_to_str(node_json["id"]);
}

private function runtime_ui_resolve_canonical_ast_node_id(node_json: Json): string {
  if (node_json == null) {
    return "";
  }

  let source_node_id_property = runtime_ui_property_container_value(
    node_json["properties"],
    "node_id"
  );
  let source_node_id_value = Runtime.json_to_i64(source_node_id_property);
  if (source_node_id_value > 0) {
    let attachment_document_shift = 4294967296;
    if (source_node_id_value >= attachment_document_shift) {
      source_node_id_value =
        source_node_id_value
        - ((source_node_id_value / attachment_document_shift) * attachment_document_shift);
    }
    if (source_node_id_value > 0) {
      return Runtime.json_to_str(source_node_id_value);
    }
  }

  let resolved_node_id = Runtime.json_to_str(node_json["resolved_node_id"]);
  if (resolved_node_id != "" && resolved_node_id != "0") {
    return resolved_node_id;
  }

  let properties = runtime_ui_property_value(node_json, "resolved_node_id");
  resolved_node_id = Runtime.json_to_str(properties);
  if (resolved_node_id != "" && resolved_node_id != "0") {
    return resolved_node_id;
  }

  return runtime_ui_resolve_ast_node_id(node_json);
}

private function runtime_ui_node_kind(node_json: Json): string {
  if (node_json == null) {
    return "";
  }

  let kind = Runtime.json_to_str(node_json["kind"]);
  if (kind != "") {
    return kind;
  }

  return Runtime.json_to_str(node_json["node_type"]);
}

private function runtime_ui_is_form_declaration_kind(kind: string): bool {
  let normalized_kind = Runtime.json_to_str(kind);
  return normalized_kind == "formDeclaration"
    || normalized_kind == "formDeclarationWithHeader"
    || normalized_kind == "formDeclarationWithoutHeader";
}

private function runtime_ui_is_app_declaration_kind(kind: string): bool {
  let normalized_kind = Runtime.json_to_str(kind);
  return normalized_kind == "appDeclaration"
    || normalized_kind == "appDeclarationWithHeader"
    || normalized_kind == "appDeclarationWithoutHeader";
}

private function runtime_ui_collect_nodes_by_kinds(kinds: Json): Json {
  let collected_matches: Json = [];
  let collected_count = 0;

  for (kind in kinds ?? []) {
    let normalized_kind = Runtime.json_to_str(kind);
    if (normalized_kind == "") {
      continue;
    }
    let kind_matches = ast.list_nodes_by_kind(normalized_kind) ?? [];
    for (kind_match in kind_matches) {
      collected_matches[collected_count] = kind_match;
      collected_count = collected_count + 1;
    }
  }

  return collected_matches;
}

private function runtime_ui_collect_form_declaration_matches(): Json {
  return runtime_ui_collect_nodes_by_kinds([
    "formDeclaration"
  ]);
}

private function runtime_ui_collect_app_declaration_matches(): Json {
  return runtime_ui_collect_nodes_by_kinds([
    "appDeclaration",
    "appDeclarationWithHeader",
    "appDeclarationWithoutHeader"
  ]);
}

private function runtime_ui_node_source_path(node_json: Json): string {
  if (node_json == null) {
    return "";
  }

  let source_path = Runtime.json_to_str(node_json["source_path"]);
  if (source_path != "") {
    return source_path;
  }

  return Runtime.json_to_str(runtime_ui_property_value(node_json, "source_path"));
}

private function runtime_ui_node_span(node_json: Json): Json {
  if (node_json == null) {
    return null;
  }

  let span = node_json["span"];
  if (span != null) {
    return span;
  }

  span = node_json["range"];
  if (span != null) {
    return span;
  }

  span = runtime_ui_property_value(node_json, "span");
  if (span != null) {
    return span;
  }

  return runtime_ui_property_value(node_json, "range");
}

private function runtime_ui_collect_descendant_values_internal(
  node_id: string,
  expected_kind: string,
  collect_symbol_names: bool
): Json {
  let normalized_node_id = Runtime.json_to_str(node_id);
  let normalized_expected_kind = Runtime.json_to_str(expected_kind);
  let values: Json = [];
  let value_count = 0;

  if (
    normalized_node_id == ""
    || (
      collect_symbol_names != true
      && normalized_expected_kind == ""
    )
  ) {
    return values;
  }

  if (collect_symbol_names == true) {
    let node_json = ast.node_to_json(normalized_node_id);
    let symbol_name = runtime_ui_direct_node_symbol_name(node_json);
    if (symbol_name != "") {
      values[value_count] = symbol_name;
      value_count = value_count + 1;
    }
  }

  let child_nodes = ast.list_children(normalized_node_id) ?? [];
  for (child_node in child_nodes) {
    let child_node_id = runtime_ui_match_node_id(child_node);
    if (
      collect_symbol_names != true
      && runtime_ui_match_kind_name(child_node) == normalized_expected_kind
    ) {
      values[value_count] = child_node;
      value_count = value_count + 1;
    }

    let child_values = runtime_ui_collect_descendant_values_internal(
      child_node_id,
      normalized_expected_kind,
      collect_symbol_names
    ) ?? [];
    for (child_value in child_values) {
      values[value_count] = child_value;
      value_count = value_count + 1;
    }
  }

  return values;
}

private function runtime_ui_collect_descendant_node_matches_by_kind(
  node_id: string,
  expected_kind: string
): Json {
  return runtime_ui_collect_descendant_values_internal(node_id, expected_kind, false);
}

private function runtime_ui_direct_node_symbol_name(node_json: Json): string {
  if (node_json == null) {
    return "";
  }

  let symbol_name = Runtime.json_to_str(runtime_ui_property_value(node_json, "symbol_name"));
  if (symbol_name != "") {
    return symbol_name;
  }

  return Runtime.json_to_str(runtime_ui_property_value(node_json, "normalized_symbol_name"));
}

private function runtime_ui_resolve_canonical_declaration_node(node_json: Json): Json {
  if (node_json == null) {
    return null;
  }

  let node_kind = runtime_ui_node_kind(node_json);
  let parent_node_id = Runtime.json_to_str(node_json["parent_id"]);
  if (parent_node_id == "") {
    return node_json;
  }

  if (
    node_kind == "formDeclarationWithHeader"
    || node_kind == "formDeclarationWithoutHeader"
  ) {
    let parent_node_json = ast.node_to_json(parent_node_id);
    if (runtime_ui_node_kind(parent_node_json) == "formDeclaration") {
      return parent_node_json;
    }
  } else if (
    node_kind == "appDeclarationWithHeader"
    || node_kind == "appDeclarationWithoutHeader"
  ) {
    let parent_node_json = ast.node_to_json(parent_node_id);
    if (runtime_ui_node_kind(parent_node_json) == "appDeclaration") {
      return parent_node_json;
    }
  }

  return node_json;
}

private function runtime_ui_resolve_form_analysis_node(node_json: Json): Json {
  let canonical_node_json = runtime_ui_resolve_canonical_declaration_node(node_json);
  if (canonical_node_json == null) {
    return null;
  }

  let canonical_node_id = runtime_ui_resolve_ast_node_id(canonical_node_json);
  if (canonical_node_id == "") {
    return canonical_node_json;
  }

  let wrapped_form_node_id = runtime_ui_find_first_child_node_id_by_kinds(
    canonical_node_id,
    [
      "formDeclarationWithHeader",
      "formDeclarationWithoutHeader"
    ]
  );
  if (wrapped_form_node_id != "") {
    return ast.node_to_json(wrapped_form_node_id);
  }

  return canonical_node_json;
}

private function runtime_ui_resolve_declaration_primary_symbol_name(node_json: Json): string {
  let canonical_node_json = runtime_ui_resolve_canonical_declaration_node(node_json);
  if (canonical_node_json == null) {
    return "";
  }

  let node_id = runtime_ui_resolve_ast_node_id(canonical_node_json);
  if (node_id != "") {
    let identifier_node_id = runtime_ui_find_first_child_node_id_by_kinds(
      node_id,
      [
        "identifier",
        "qualifiedIdentifier"
      ]
    );
    if (identifier_node_id != "") {
      let direct_symbol_name = runtime_ui_direct_node_symbol_name(
        ast.node_to_json(identifier_node_id)
      );
      if (direct_symbol_name != "") {
        return direct_symbol_name;
      }
    }
  }

  return runtime_ui_resolve_node_symbol_name(canonical_node_json);
}

private function runtime_ui_collect_descendant_symbol_names(node_id: string): Json {
  return runtime_ui_collect_descendant_values_internal(node_id, "", true);
}

private function runtime_ui_symbol_list_contains(symbol_names: Json, expected_symbol_name: string): bool {
  let normalized_expected_symbol_name = Runtime.json_to_str(expected_symbol_name);
  if (normalized_expected_symbol_name == "") {
    return false;
  }

  for (symbol_name in symbol_names ?? []) {
    if (Runtime.json_to_str(symbol_name) == normalized_expected_symbol_name) {
      return true;
    }
  }

  return false;
}

private function runtime_ui_state_field_names(state_fields: Json): Json {
  let names: Json = [];
  let name_count = 0;

  for (state_field in state_fields ?? []) {
    let field_name = Runtime.json_to_str(state_field["name"]);
    if (field_name == "") {
      continue;
    }
    names[name_count] = field_name;
    name_count = name_count + 1;
  }

  return names;
}

private function runtime_ui_find_first_matching_state_field_name(
  symbol_names: Json,
  state_fields: Json,
  excluded_names: Json
): string {
  let state_field_names = runtime_ui_state_field_names(state_fields);

  for (symbol_name in symbol_names ?? []) {
    let normalized_symbol_name = Runtime.json_to_str(symbol_name);
    if (normalized_symbol_name == "") {
      continue;
    }
    if (runtime_ui_symbol_list_contains(excluded_names, normalized_symbol_name)) {
      continue;
    }
    if (runtime_ui_symbol_list_contains(state_field_names, normalized_symbol_name)) {
      return normalized_symbol_name;
    }
  }

  return "";
}

private function runtime_ui_find_matching_state_field_property(
  node_json: Json,
  property_name: string,
  state_fields: Json,
  excluded_names: Json
): string {
  let normalized_property_name = Runtime.json_to_str(property_name);
  if (node_json == null || normalized_property_name == "") {
    return "";
  }

  let node_id = runtime_ui_resolve_ast_node_id(node_json);
  if (node_id == "") {
    return "";
  }

  let child_nodes = ast.list_children(node_id) ?? [];
  for (child_node in child_nodes) {
    let child_node_id = runtime_ui_match_node_id(child_node);
    if (!runtime_ui_node_or_descendant_has_symbol_name(child_node_id, normalized_property_name)) {
      continue;
    }

    let child_symbol_names = runtime_ui_collect_descendant_symbol_names(child_node_id);
    let matched_name = runtime_ui_find_first_matching_state_field_name(
      child_symbol_names,
      state_fields,
      excluded_names
    );
    if (matched_name != "") {
      return matched_name;
    }
  }

  return "";
}

private function runtime_ui_analyze_control_child_metadata(
  control_node_json: Json,
  state_fields: Json,
  control_id: string
): Json {
  let selection_field_name = "";
  let pagination_field_name = "";
  let height_lines_symbol = "";
  if (control_node_json == null) {
    return {
      "selection": selection_field_name,
      "pagination": pagination_field_name,
      "height_lines": height_lines_symbol
    };
  }

  let node_id = runtime_ui_resolve_ast_node_id(control_node_json);
  if (node_id == "") {
    return {
      "selection": selection_field_name,
      "pagination": pagination_field_name,
      "height_lines": height_lines_symbol
    };
  }

  let child_nodes = ast.list_children(node_id) ?? [];
  for (child_node in child_nodes) {
    let child_node_id = runtime_ui_match_node_id(child_node);
    if (child_node_id == "") {
      continue;
    }

    let child_symbol_names = runtime_ui_collect_descendant_symbol_names(child_node_id);
    if (
      selection_field_name == ""
      && runtime_ui_symbol_list_contains(child_symbol_names, "selection")
    ) {
      selection_field_name = runtime_ui_find_first_matching_state_field_name(
        child_symbol_names,
        state_fields,
        [control_id]
      );
    }

    if (
      pagination_field_name == ""
      && runtime_ui_symbol_list_contains(child_symbol_names, "pagination")
    ) {
      pagination_field_name = runtime_ui_find_first_matching_state_field_name(
        child_symbol_names,
        state_fields,
        [control_id, selection_field_name]
      );
    }

    if (
      height_lines_symbol == ""
      && runtime_ui_symbol_list_contains(child_symbol_names, "height_lines")
    ) {
      let callable_symbol = runtime_ui_find_first_descendant_callable_symbol_name(child_node_id);
      if (callable_symbol != "" && callable_symbol != "height_lines") {
        height_lines_symbol = callable_symbol;
      } else {
        for (child_symbol_name in child_symbol_names) {
          let normalized_child_symbol_name = Runtime.json_to_str(child_symbol_name);
          if (
            normalized_child_symbol_name != ""
            && normalized_child_symbol_name != "height_lines"
          ) {
            height_lines_symbol = normalized_child_symbol_name;
            break;
          }
        }
      }
    }

    if (
      selection_field_name != ""
      && pagination_field_name != ""
      && height_lines_symbol != ""
    ) {
      break;
    }
  }

  return {
    "selection": selection_field_name,
    "pagination": pagination_field_name,
    "height_lines": height_lines_symbol
  };
}

private function runtime_ui_resolve_control_state_field_bindings(
  control_node_json: Json,
  state_fields: Json,
  control_id: string
): Json {
  let child_metadata = runtime_ui_analyze_control_child_metadata(
    control_node_json,
    state_fields,
    control_id
  );
  return {
    "selection": Runtime.json_to_str(child_metadata["selection"]),
    "pagination": Runtime.json_to_str(child_metadata["pagination"])
  };
}

private function runtime_ui_find_first_matching_state_field_name_by_value_type(
  state_fields: Json,
  value_type: string
): string {
  let normalized_value_type = Runtime.json_to_str(value_type);
  if (normalized_value_type == "") {
    return "";
  }

  let fallback_match = "";
  let fallback_count = 0;
  for (state_field in state_fields ?? []) {
    let field_name = Runtime.json_to_str(state_field["name"]);
    if (field_name == "") {
      continue;
    }
    if (Runtime.json_to_str(state_field["value_type"]) != normalized_value_type) {
      continue;
    }
    if (fallback_match == "") {
      fallback_match = field_name;
    }
    fallback_count = fallback_count + 1;
  }

  if (fallback_count == 1) {
    return fallback_match;
  }

  return "";
}

private function runtime_ui_normalize_identifier_text(value: string): string {
  let normalized_value = Runtime.to_lower(Runtime.json_to_str(value));
  if (normalized_value == "") {
    return "";
  }

  let normalized_text = "";
  for (character in normalized_value) {
    if (character == "_" || character == "-" || character == " ") {
      continue;
    }
    normalized_text = normalized_text + Runtime.json_to_str(character);
  }

  return normalized_text;
}

private function runtime_ui_trim_grid_suffix(value: string): string {
  let normalized_value = runtime_ui_normalize_identifier_text(value);
  if (normalized_value == "") {
    return "";
  }
  let trimmed_value = "";
  let pending_1 = "";
  let pending_2 = "";
  let pending_3 = "";
  let pending_4 = "";
  let pending_count = 0;

  for (character in normalized_value) {
    if (pending_count == 0) {
      pending_1 = character;
      pending_count = 1;
      continue;
    }
    if (pending_count == 1) {
      pending_2 = character;
      pending_count = 2;
      continue;
    }
    if (pending_count == 2) {
      pending_3 = character;
      pending_count = 3;
      continue;
    }
    if (pending_count == 3) {
      pending_4 = character;
      pending_count = 4;
      continue;
    }

    trimmed_value = trimmed_value + pending_1;
    pending_1 = pending_2;
    pending_2 = pending_3;
    pending_3 = pending_4;
    pending_4 = character;
  }

  if (pending_count < 4) {
    return normalized_value;
  }
  if (pending_1 + pending_2 + pending_3 + pending_4 == "grid") {
    return trimmed_value;
  }
  return trimmed_value + pending_1 + pending_2 + pending_3 + pending_4;
}

private function runtime_ui_trim_lower_grid_suffix(value: string): string {
  let lower_value = Runtime.to_lower(Runtime.json_to_str(value));
  if (lower_value == "") {
    return "";
  }
  let trimmed_value = "";
  let pending_1 = "";
  let pending_2 = "";
  let pending_3 = "";
  let pending_4 = "";
  let pending_count = 0;

  for (character in lower_value) {
    if (pending_count == 0) {
      pending_1 = character;
      pending_count = 1;
      continue;
    }
    if (pending_count == 1) {
      pending_2 = character;
      pending_count = 2;
      continue;
    }
    if (pending_count == 2) {
      pending_3 = character;
      pending_count = 3;
      continue;
    }
    if (pending_count == 3) {
      pending_4 = character;
      pending_count = 4;
      continue;
    }

    trimmed_value = trimmed_value + pending_1;
    pending_1 = pending_2;
    pending_2 = pending_3;
    pending_3 = pending_4;
    pending_4 = character;
  }

  if (pending_count < 4) {
    return lower_value;
  }
  if (pending_1 + pending_2 + pending_3 + pending_4 == "grid") {
    return trimmed_value;
  }
  return trimmed_value + pending_1 + pending_2 + pending_3 + pending_4;
}

private function runtime_ui_find_matching_pagination_state_field_name(
  state_fields: Json,
  control_id: string
): string {
  let normalized_control_id = runtime_ui_normalize_identifier_text(control_id);
  let normalized_control_base = runtime_ui_trim_grid_suffix(normalized_control_id);
  let lower_control_base = runtime_ui_trim_lower_grid_suffix(control_id);
  let lower_control_id = Runtime.to_lower(Runtime.json_to_str(control_id));

  let default_match = "";
  let non_default_match = "";
  let non_default_count = 0;
  let fallback_match = "";
  let fallback_count = 0;

  for (state_field in state_fields ?? []) {
    let field_name = Runtime.json_to_str(state_field["name"]);
    if (field_name == "") {
      continue;
    }
    let lower_field_name = Runtime.to_lower(field_name);
    if (lower_field_name == "limiter") {
      default_match = field_name;
    }
    let state_field_value_type = Runtime.json_to_str(state_field["value_type"]);
    if (state_field_value_type == "Limiter" && lower_field_name != "limiter") {
      if (non_default_match == "") {
        non_default_match = field_name;
      }
      non_default_count = non_default_count + 1;
    }

    let normalized_field_name = runtime_ui_normalize_identifier_text(field_name);
    if (normalized_field_name == "") {
      if (
        state_field_value_type == "Limiter"
        && fallback_match == ""
      ) {
        fallback_match = field_name;
      }
      if (state_field_value_type == "Limiter") {
        fallback_count = fallback_count + 1;
      }
      continue;
    }
    let matches_limiter_name = normalized_field_name == "limiter";
    if (
      !matches_limiter_name
      && normalized_control_base != ""
      && normalized_field_name == normalized_control_base + "limiter"
    ) {
      matches_limiter_name = true;
    }
    if (
      !matches_limiter_name
      && lower_control_base != ""
      && lower_field_name == lower_control_base + "_limiter"
    ) {
      matches_limiter_name = true;
    }
    if (state_field_value_type != "Limiter" && !matches_limiter_name) {
      continue;
    }
    if (
      normalized_control_base != ""
      && normalized_field_name == normalized_control_base + "limiter"
    ) {
      return field_name;
    }
    if (
      lower_control_base != ""
      && lower_field_name == lower_control_base + "_limiter"
    ) {
      return field_name;
    }
    if (normalized_field_name == "limiter") {
      default_match = field_name;
    }
    if (fallback_match == "") {
      fallback_match = field_name;
    }
    fallback_count = fallback_count + 1;
  }

  if (
    lower_control_id != ""
    && lower_control_id != "ui"
    && non_default_count == 1
    && non_default_match != ""
  ) {
    return non_default_match;
  }
  if (default_match != "") {
    return default_match;
  }
  if (fallback_count == 1) {
    return fallback_match;
  }
  return "";
}

private function runtime_ui_build_state_field_metadata(state_node_json: Json): Json {
  let state_node_id = runtime_ui_resolve_ast_node_id(state_node_json);
  let type_expression_node_id = runtime_ui_find_child_node_id_by_kind(state_node_id, "typeExpression");
  let value_type = runtime_ui_find_first_descendant_symbol_name(type_expression_node_id);
  let field_name = runtime_ui_resolve_node_symbol_name(state_node_json);
  if (field_name == "" || field_name == value_type) {
    let descendant_symbol_names = runtime_ui_collect_descendant_symbol_names(state_node_id);
    for (descendant_symbol_name in descendant_symbol_names) {
      let normalized_descendant_symbol_name = Runtime.json_to_str(descendant_symbol_name);
      if (
        normalized_descendant_symbol_name == ""
        || normalized_descendant_symbol_name == value_type
      ) {
        continue;
      }
      field_name = normalized_descendant_symbol_name;
      break;
    }
  }
  if (field_name == "" || field_name == value_type) {
    let identifier_node_id = runtime_ui_find_child_node_id_by_kind(state_node_id, "identifier");
    field_name = runtime_ui_direct_node_symbol_name(ast.node_to_json(identifier_node_id));
  }

  if (field_name == "") {
    return null;
  }

  return {
    "name": field_name,
    "value_type": value_type != "" ? value_type : null
  };
}

private function runtime_ui_build_state_fields_from_nodes(state_nodes: Json): Json {
  let state_fields: Json = [];
  let state_field_count = 0;

  for (state_node_json in state_nodes ?? []) {
    let state_field = runtime_ui_build_state_field_metadata(state_node_json);
    let field_name = Runtime.json_to_str(state_field["name"]);
    if (field_name == "") {
      continue;
    }
    state_fields[state_field_count] = state_field;
    state_field_count = state_field_count + 1;
  }

  return state_fields;
}

private function runtime_ui_collect_form_state_fields(form_node_json: Json): Json {
  let form_node_id = runtime_ui_resolve_ast_node_id(form_node_json);
  let form_metadata_nodes = runtime_ui_collect_form_metadata_nodes(form_node_id);
  return runtime_ui_build_state_fields_from_nodes(form_metadata_nodes["state_nodes"]);
}

private function runtime_ui_resolve_form_path_from_symbol_name(
  symbol_name: string,
  state_fields: Json
): string {
  let normalized_symbol_name = Runtime.json_to_str(symbol_name);
  if (normalized_symbol_name == "") {
    return "";
  }
  if (normalized_symbol_name == "form" || normalized_symbol_name == "state") {
    return normalized_symbol_name;
  }
  if (runtime_ui_symbol_list_contains(runtime_ui_state_field_names(state_fields), normalized_symbol_name)) {
    return "state." + normalized_symbol_name;
  }
  return "";
}

private function runtime_ui_resolve_grid_control_binding_type(
  type_expression_node_id: string
): string {
  let normalized_type_expression_node_id = Runtime.json_to_str(type_expression_node_id);
  if (normalized_type_expression_node_id == "") {
    return "";
  }

  let type_symbol_names = runtime_ui_collect_descendant_symbol_names(
    normalized_type_expression_node_id
  );
  for (type_symbol_name in type_symbol_names) {
    let normalized_type_symbol_name = Runtime.json_to_str(type_symbol_name);
    if (
      normalized_type_symbol_name == ""
      || normalized_type_symbol_name == "DataGrid"
      || normalized_type_symbol_name == "Grid"
      || normalized_type_symbol_name == "datagrid"
      || normalized_type_symbol_name == "grid"
    ) {
      continue;
    }
    if (runtime_ui_resolve_binding_declaration_kind(normalized_type_symbol_name) != "") {
      return normalized_type_symbol_name;
    }
  }

  return "";
}

private function runtime_ui_resolve_control_type_analysis(
  type_expression_node_id: string
): Json {
  let normalized_type_expression_node_id = Runtime.json_to_str(type_expression_node_id);
  let control_type_symbol = "";
  let grid_binding_type = "";
  if (normalized_type_expression_node_id == "") {
    return {
      "control_type_symbol": control_type_symbol,
      "grid_binding_type": grid_binding_type
    };
  }

  let type_symbol_names = runtime_ui_collect_descendant_symbol_names(
    normalized_type_expression_node_id
  );
  for (type_symbol_name in type_symbol_names) {
    let normalized_type_symbol_name = Runtime.json_to_str(type_symbol_name);
    if (normalized_type_symbol_name == "") {
      continue;
    }
    let normalized_control_type_symbol = normalized_type_symbol_name;
    if (normalized_control_type_symbol == "datagrid") {
      normalized_control_type_symbol = "DataGrid";
    } else if (normalized_control_type_symbol == "grid") {
      normalized_control_type_symbol = "Grid";
    }
    if (control_type_symbol == "") {
      control_type_symbol = normalized_control_type_symbol;
    }
    if (
      normalized_control_type_symbol != "DataGrid"
      && normalized_control_type_symbol != "Grid"
      && runtime_ui_resolve_binding_declaration_kind(normalized_type_symbol_name) != ""
    ) {
      grid_binding_type = normalized_type_symbol_name;
      break;
    }
  }

  if (control_type_symbol == "" || (control_type_symbol != "DataGrid" && control_type_symbol != "Grid")) {
    let form_control_type_node_id = runtime_ui_find_child_node_id_by_kind(
      normalized_type_expression_node_id,
      "formControlTypeReference"
    );
    let control_type_identifier_node_id = runtime_ui_find_first_child_node_id_by_kinds(
      form_control_type_node_id,
      [
        "unresolvedIdentifier",
        "identifier"
      ]
    );
    if (control_type_identifier_node_id != "") {
      let fallback_control_type_symbol = runtime_ui_find_first_descendant_symbol_name(
        control_type_identifier_node_id
      );
      if (fallback_control_type_symbol != "") {
        control_type_symbol = fallback_control_type_symbol;
      }
    }
  }

  return {
    "control_type_symbol": control_type_symbol,
    "grid_binding_type": grid_binding_type
  };
}

private function runtime_ui_resolve_control_source_context(control_source_node_id: string): Json {
  let normalized_control_source_node_id = Runtime.json_to_str(control_source_node_id);
  if (normalized_control_source_node_id == "") {
    return {
      "container_node_id": "",
      "form_field_from_node_id": ""
    };
  }

  let container_node_id = normalized_control_source_node_id;
  let form_field_from_node_id = "";
  let control_source_node_json = ast.node_to_json(normalized_control_source_node_id);
  let control_source_node_kind = runtime_ui_node_kind(control_source_node_json);

  if (control_source_node_kind == "formFieldFrom") {
    form_field_from_node_id = normalized_control_source_node_id;
    let parent_node_id = Runtime.json_to_str(control_source_node_json["parent_id"]);
    if (
      parent_node_id != ""
      && runtime_ui_node_kind(ast.node_to_json(parent_node_id)) == "formInlineControlField"
    ) {
      container_node_id = parent_node_id;
    }
  } else {
    form_field_from_node_id = runtime_ui_find_child_node_id_by_kind(
      normalized_control_source_node_id,
      "formFieldFrom"
    );
  }

  return {
    "container_node_id": container_node_id,
    "form_field_from_node_id": form_field_from_node_id
  };
}

private function runtime_ui_reflect_control_source_handler(control_source_node_id: string): string {
  let source_context = runtime_ui_resolve_control_source_context(control_source_node_id);
  let container_node_id = Runtime.json_to_str(source_context["container_node_id"]);
  let form_field_from_node_id = Runtime.json_to_str(source_context["form_field_from_node_id"]);
  if (container_node_id == "") {
    return "";
  }

  let load_event_handler = runtime_ui_find_form_field_property_handler(
    container_node_id,
    [
      "load"
    ]
  );
  if (load_event_handler == "") {
    load_event_handler = runtime_ui_find_direct_form_field_property_handler_by_key(
      container_node_id,
      "load"
    );
  }
  if (load_event_handler != "") {
    return load_event_handler;
  }

  let form_source_expression_node_id = runtime_ui_find_child_node_id_by_kind(
    form_field_from_node_id,
    "formSourceExpression"
  );
  if (form_source_expression_node_id != "") {
    let form_source_identifier_node_id = runtime_ui_find_first_child_node_id_by_kinds(
      form_source_expression_node_id,
      [
        "qualifiedIdentifier",
        "identifier"
      ]
    );
    if (form_source_identifier_node_id != "") {
      let direct_source_handler = runtime_ui_resolve_node_symbol_name(
        ast.node_to_json(form_source_identifier_node_id)
      );
      if (direct_source_handler != "") {
        return direct_source_handler;
      }
    }
  }

  return runtime_ui_find_first_descendant_symbol_name_skipping_kind(
    container_node_id,
    "arguments"
  );
}

private function runtime_ui_resolve_control_binding_type_from_form_field_from(
  form_field_from_node_id: string
): string {
  let normalized_form_field_from_node_id = Runtime.json_to_str(form_field_from_node_id);
  if (normalized_form_field_from_node_id == "") {
    return "";
  }

  let form_source_expression_node_id = runtime_ui_find_child_node_id_by_kind(
    normalized_form_field_from_node_id,
    "formSourceExpression"
  );
  if (form_source_expression_node_id != "") {
    let form_source_identifier_node_id = runtime_ui_find_first_child_node_id_by_kinds(
      form_source_expression_node_id,
      [
        "qualifiedIdentifier",
        "identifier"
      ]
    );
    if (form_source_identifier_node_id != "") {
      let direct_binding_type = runtime_ui_resolve_node_symbol_name(
        ast.node_to_json(form_source_identifier_node_id)
      );
      if (
        direct_binding_type != ""
        && runtime_ui_resolve_binding_declaration_kind(direct_binding_type) != ""
      ) {
        return direct_binding_type;
      }
    }
  }

  let source_symbol_names = runtime_ui_collect_descendant_symbol_names(
    normalized_form_field_from_node_id
  );
  for (source_symbol_name in source_symbol_names) {
    let normalized_source_symbol_name = Runtime.json_to_str(source_symbol_name);
    if (
      normalized_source_symbol_name != ""
      && runtime_ui_resolve_binding_declaration_kind(normalized_source_symbol_name) != ""
    ) {
      return normalized_source_symbol_name;
    }
  }

  return "";
}

private function runtime_ui_resolve_reflected_control_source_handler(
  control_node_id: string,
  control_source_node_id: string
): string {
  let normalized_control_node_id = Runtime.json_to_str(control_node_id);
  let explicit_load_handler = "";
  if (normalized_control_node_id != "") {
    explicit_load_handler = runtime_ui_find_form_field_property_handler(
      normalized_control_node_id,
      [
        "load"
      ]
    );
    if (explicit_load_handler == "") {
      explicit_load_handler = runtime_ui_find_direct_form_field_property_handler_by_key(
        normalized_control_node_id,
        "load"
      );
    }
  }
  if (explicit_load_handler != "") {
    return explicit_load_handler;
  }

  return runtime_ui_reflect_control_source_handler(control_source_node_id);
}

private function runtime_ui_resolve_form_field_property_handler(
  form_field_property_node_id: string,
  excluded_symbol_names: Json
): string {
  let normalized_form_field_property_node_id = Runtime.json_to_str(form_field_property_node_id);
  if (normalized_form_field_property_node_id == "") {
    return "";
  }

  for (child_node_id in runtime_ui_list_child_node_ids(normalized_form_field_property_node_id)) {
    let normalized_child_node_id = Runtime.json_to_str(child_node_id);
    if (normalized_child_node_id == "") {
      continue;
    }
    if (
      runtime_ui_node_kind(ast.node_to_json(normalized_child_node_id))
      == "formFieldPropertyKey"
    ) {
      continue;
    }

    let handler_symbol_name = runtime_ui_resolve_node_symbol_name(
      ast.node_to_json(normalized_child_node_id)
    );
    if (handler_symbol_name == "") {
      handler_symbol_name = runtime_ui_find_first_descendant_symbol_name(
        normalized_child_node_id
      );
    }
    if (
      handler_symbol_name != ""
      && !runtime_ui_symbol_list_contains(excluded_symbol_names, handler_symbol_name)
    ) {
      return handler_symbol_name;
    }
  }

  return "";
}

private function runtime_ui_find_direct_form_field_property_handler_by_key(
  control_node_id: string,
  property_key_symbol_name: string
): string {
  let normalized_control_node_id = Runtime.json_to_str(control_node_id);
  let normalized_property_key_symbol_name = Runtime.json_to_str(property_key_symbol_name);
  if (normalized_control_node_id == "" || normalized_property_key_symbol_name == "") {
    return "";
  }

  let form_field_properties_node_id = runtime_ui_find_child_node_id_by_kind(
    normalized_control_node_id,
    "formFieldProperties"
  );
  if (form_field_properties_node_id == "") {
    return "";
  }

  for (form_field_property_node_id in runtime_ui_list_child_node_ids(form_field_properties_node_id)) {
    let normalized_form_field_property_node_id = Runtime.json_to_str(form_field_property_node_id);
    if (
      normalized_form_field_property_node_id == ""
      || runtime_ui_node_kind(ast.node_to_json(normalized_form_field_property_node_id))
        != "formFieldProperty"
    ) {
      continue;
    }

    let property_key_node_id = runtime_ui_find_child_node_id_by_kind(
      normalized_form_field_property_node_id,
      "formFieldPropertyKey"
    );
    if (property_key_node_id == "") {
      continue;
    }

    let property_key_symbol = runtime_ui_find_first_descendant_symbol_name(property_key_node_id);
    if (property_key_symbol != normalized_property_key_symbol_name) {
      continue;
    }

    let property_handler_symbol = runtime_ui_resolve_form_field_property_handler(
      normalized_form_field_property_node_id,
      [
        normalized_property_key_symbol_name
      ]
    );
    if (property_handler_symbol != "") {
      return property_handler_symbol;
    }
  }

  return "";
}

private function runtime_ui_find_form_field_property_handler(
  control_node_id: string,
  property_key_symbol_names: Json
): string {
  let normalized_control_node_id = Runtime.json_to_str(control_node_id);
  if (normalized_control_node_id == "") {
    return "";
  }

  let normalized_property_key_symbol_names: Json = [];
  let normalized_property_key_symbol_count = 0;
  for (property_key_symbol_name in property_key_symbol_names ?? []) {
    let normalized_property_key_symbol_name = Runtime.json_to_str(property_key_symbol_name);
    if (normalized_property_key_symbol_name == "") {
      continue;
    }
    normalized_property_key_symbol_names[normalized_property_key_symbol_count] =
      normalized_property_key_symbol_name;
    normalized_property_key_symbol_count = normalized_property_key_symbol_count + 1;
  }
  if (normalized_property_key_symbol_count == 0) {
    return "";
  }

  let form_field_property_node_ids: Json = [];
  let form_field_property_node_count = 0;
  let form_field_properties_node_id = runtime_ui_find_child_node_id_by_kind(
    normalized_control_node_id,
    "formFieldProperties"
  );
  if (form_field_properties_node_id != "") {
    for (form_field_property_node_id in runtime_ui_list_child_node_ids(form_field_properties_node_id)) {
      let normalized_form_field_property_node_id = Runtime.json_to_str(form_field_property_node_id);
      if (
        normalized_form_field_property_node_id == ""
        || runtime_ui_node_kind(ast.node_to_json(normalized_form_field_property_node_id))
          != "formFieldProperty"
      ) {
        continue;
      }
      form_field_property_node_ids[form_field_property_node_count] =
        normalized_form_field_property_node_id;
      form_field_property_node_count = form_field_property_node_count + 1;
    }
  } else {
    let form_field_property_nodes = runtime_ui_collect_descendant_node_matches_by_kind(
      normalized_control_node_id,
      "formFieldProperty"
    ) ?? [];
    for (form_field_property_node in form_field_property_nodes) {
      let form_field_property_node_id = runtime_ui_match_node_id(form_field_property_node);
      if (form_field_property_node_id == "") {
        continue;
      }
      form_field_property_node_ids[form_field_property_node_count] = form_field_property_node_id;
      form_field_property_node_count = form_field_property_node_count + 1;
    }
  }

  for (form_field_property_node_id in form_field_property_node_ids) {
    let normalized_form_field_property_node_id = Runtime.json_to_str(form_field_property_node_id);
    if (normalized_form_field_property_node_id == "") {
      continue;
    }

    let property_key_node_id = runtime_ui_find_child_node_id_by_kind(
      normalized_form_field_property_node_id,
      "formFieldPropertyKey"
    );
    if (property_key_node_id == "") {
      continue;
    }

    let property_key_symbols = runtime_ui_collect_descendant_symbol_names(property_key_node_id);
    let matches_all_property_key_symbols = true;
    for (expected_property_key_symbol in normalized_property_key_symbol_names) {
      if (!runtime_ui_symbol_list_contains(property_key_symbols, expected_property_key_symbol)) {
        matches_all_property_key_symbols = false;
        break;
      }
    }
    if (!matches_all_property_key_symbols) {
      continue;
    }

    let property_handler_symbol = runtime_ui_resolve_form_field_property_handler(
      normalized_form_field_property_node_id,
      normalized_property_key_symbol_names
    );
    if (property_handler_symbol != "") {
      return property_handler_symbol;
    }
  }

  return "";
}

private function runtime_ui_cap_grid_column_display_length(display_length: Json): Json {
  let normalized_display_length = Runtime.json_to_i64(display_length);
  if (normalized_display_length <= 0) {
    return null;
  }

  let grid_display_length_cap = 32;
  if (normalized_display_length > grid_display_length_cap) {
    normalized_display_length = grid_display_length_cap;
  }

  return Runtime.json_from_i64(normalized_display_length);
}

private function runtime_ui_build_grid_binding_projection(
  binding_members: Json
): Json {
  let columns: Json = [];
  let column_count = 0;
  let primary_selection_key = "";
  let fallback_selection_key = "";
  let key_field_count = 0;

  for (binding_member in binding_members ?? {}) {
    let field_name = Runtime.json_to_str(binding_member["field_name"]);
    let value_type = Runtime.json_to_str(binding_member["value_type"]);
    if (field_name == "") {
      continue;
    }

    let column_metadata: Json = {
      "id": field_name,
      "key": field_name,
      "field": field_name,
      "name": field_name,
      "label": field_name,
      "keyIdentifier": binding_member["is_key"] == true
    };
    if (value_type != "") {
      column_metadata["type"] = value_type;
      column_metadata["value_type"] = value_type;
    }
    if (binding_member["max_length"] != null) {
      column_metadata["max_length"] = binding_member["max_length"];
    }
    if (binding_member["display_length"] != null) {
      column_metadata["display_length"] = runtime_ui_cap_grid_column_display_length(
        binding_member["display_length"]
      );
    }
    if (binding_member["input_width"] != null) {
      column_metadata["input_width"] = binding_member["input_width"];
    }
    columns[column_count] = column_metadata;
    column_count = column_count + 1;

    if (binding_member["is_primary_key"] == true) {
      if (primary_selection_key != "") {
        primary_selection_key = "";
        key_field_count = 2;
      } else if (key_field_count < 2) {
        primary_selection_key = field_name;
        key_field_count = 1;
      }
      continue;
    }
    if (binding_member["is_key"] == true && primary_selection_key == "") {
      if (fallback_selection_key != "") {
        fallback_selection_key = "";
        key_field_count = 2;
      } else if (key_field_count < 2) {
        fallback_selection_key = field_name;
        key_field_count = 1;
      }
    }
  }

  return {
    "columns": columns,
    "selection_key": primary_selection_key != ""
      ? primary_selection_key
      : (key_field_count == 1 ? fallback_selection_key : "")
  };
}

private function runtime_ui_analyze_control_structure(control_node_json: Json): Json {
  let analysis: Json = {
    "control_id": "",
    "control_node_id": "",
    "type_expression_node_id": "",
    "form_field_from_node_id": ""
  };
  if (control_node_json == null) {
    return analysis;
  }

  let control_node_id = runtime_ui_resolve_ast_node_id(control_node_json);
  if (control_node_id == "") {
    return analysis;
  }

  analysis["control_id"] = runtime_ui_resolve_node_symbol_name(control_node_json);
  analysis["control_node_id"] = control_node_id;

  let type_expression_node_id = runtime_ui_find_first_child_node_id_by_kinds(
    control_node_id,
    [
      "typeExpression",
      "formFieldType"
    ]
  );
  analysis["type_expression_node_id"] = type_expression_node_id;
  analysis["form_field_from_node_id"] = runtime_ui_find_child_node_id_by_kind(
    control_node_id,
    "formFieldFrom"
  );

  return analysis;
}

private function runtime_ui_build_control_metadata_from_node(
  control_node_json: Json,
  state_fields: Json
): Json {
  let control_structure = runtime_ui_analyze_control_structure(control_node_json);
  let control_node_id = Runtime.json_to_str(control_structure["control_node_id"]);
  let control_id = Runtime.json_to_str(control_structure["control_id"]);
  let type_expression_node_id = Runtime.json_to_str(control_structure["type_expression_node_id"]);
  let control_type_analysis = runtime_ui_resolve_control_type_analysis(type_expression_node_id);
  let control_type_symbol = Runtime.json_to_str(control_type_analysis["control_type_symbol"]);
  let control_type = "";
  let form_field_from_node_id = Runtime.json_to_str(control_structure["form_field_from_node_id"]);
  let control_child_metadata = runtime_ui_analyze_control_child_metadata(
    control_node_json,
    state_fields,
    control_id
  );
  let selection_field_name = Runtime.json_to_str(control_child_metadata["selection"]);
  let pagination_field_name = Runtime.json_to_str(control_child_metadata["pagination"]);
  let height_lines_symbol = Runtime.json_to_str(control_child_metadata["height_lines"]);
  let grid_binding_type = Runtime.json_to_str(control_type_analysis["grid_binding_type"]);
  let grid_binding_projection = null;
  let source_handler = "";
  let control_declaration_json = control_node_json;
  let declaration_load_handler = "";

  if (control_type_symbol == "DataGrid") {
    control_type = "DataGrid";
  } else if (control_type_symbol == "Grid") {
    control_type = "Grid";
  }

  if (control_id == "" || control_type == "") {
    return null;
  }
  if (control_node_id != "") {
    control_declaration_json = ast.node_to_json(control_node_id);
  }
  declaration_load_handler = runtime_ui_find_declaration_text_property(
    control_declaration_json,
    "on_load"
  );

  if (control_type == "DataGrid" || control_type == "Grid") {
    if (grid_binding_type == "") {
      grid_binding_type = runtime_ui_resolve_control_binding_type_from_form_field_from(
        form_field_from_node_id
      );
    }
    source_handler = runtime_ui_resolve_reflected_control_source_handler(
      control_node_id,
      form_field_from_node_id
    );
    if (source_handler == "" && declaration_load_handler != "") {
      source_handler = declaration_load_handler;
    }
    if (grid_binding_type != "") {
      grid_binding_projection = runtime_ui_build_grid_binding_projection_for_type(
        grid_binding_type
      );
    }
    if (selection_field_name == "" && grid_binding_type != "") {
      let select_handler = runtime_ui_find_form_field_property_handler(
        control_node_id,
        [
          "select"
        ]
      );
      if (select_handler == "") {
        select_handler = runtime_ui_find_direct_form_field_property_handler_by_key(
          control_node_id,
          "select"
        );
      }
      if (select_handler != "") {
        selection_field_name = runtime_ui_find_first_matching_state_field_name_by_value_type(
          state_fields,
          grid_binding_type
        );
      }
    }
    if (pagination_field_name == "" && source_handler != "") {
      pagination_field_name = runtime_ui_find_matching_pagination_state_field_name(
        state_fields,
        control_id
      );
    }
  }

  let control_metadata: Json = {
    "id": control_id,
    "type": control_type
  };
  let properties: Json = {};
  let grow = runtime_ui_property_value(control_node_json, "grow");
  let selection_mode = Runtime.json_to_str(
    runtime_ui_property_value(control_node_json, "selection_mode")
  );
  let selection_behavior = Runtime.json_to_str(
    runtime_ui_property_value(control_node_json, "selection_behavior")
  );
  let on_select_form = runtime_ui_find_declaration_text_property(
    control_declaration_json,
    "on_select_form"
  );
  let on_double_click_form = runtime_ui_find_declaration_text_property(
    control_declaration_json,
    "on_double_click_form"
  );
  if (selection_mode == "") {
    selection_mode = runtime_ui_find_declaration_text_property(
      control_declaration_json,
      "selection_mode"
    );
  }
  if (selection_behavior == "") {
    selection_behavior = runtime_ui_find_declaration_text_property(
      control_declaration_json,
      "selection_behavior"
    );
  }

  if (selection_field_name != "") {
    control_metadata["selection_path"] = "state." + selection_field_name;
  }
  if (pagination_field_name != "") {
    control_metadata["pagination_path"] = "state." + pagination_field_name;
  }
  if (height_lines_symbol == "maximum") {
    control_metadata["height_lines"] = "maximum";
  }
  if (grow != null) {
    control_metadata["grow"] = grow;
  } else if (control_type == "DataGrid" || control_type == "Grid") {
    control_metadata["grow"] = 1;
  }
  if (grid_binding_projection != null) {
    let grid_columns = grid_binding_projection["columns"];
    if (grid_columns != null) {
      control_metadata["columns"] = grid_columns;
    }
    let grid_selection_key = Runtime.json_to_str(grid_binding_projection["selection_key"]);
    if (grid_selection_key != "") {
      properties["selection_key"] = grid_selection_key;
    }
  }
  if (selection_mode != "") {
    properties["selection_mode"] = selection_mode;
  }
  if (selection_behavior != "") {
    properties["selection_behavior"] = selection_behavior;
  }
  if (source_handler != "") {
    control_metadata["source"] = {
      "name": source_handler,
      "kind": "query"
    };
  }
  if (on_select_form != "") {
    control_metadata["on_select_form"] = on_select_form;
  }
  if (on_double_click_form != "") {
    control_metadata["on_double_click_form"] = on_double_click_form;
  }
  if (runtime_ui_has_any_json_entries(properties)) {
    control_metadata["properties"] = properties;
  }

  return control_metadata;
}

private function runtime_ui_build_controls_from_nodes(
  control_nodes: Json,
  state_fields: Json
): Json {
  let controls: Json = [];
  let control_count = 0;

  for (control_node_json in control_nodes ?? []) {
    let control_metadata = runtime_ui_build_control_metadata_from_node(
      control_node_json,
      state_fields
    );
    if (control_metadata == null) {
      continue;
    }
    controls[control_count] = control_metadata;
    control_count = control_count + 1;
  }

  return controls;
}

private function runtime_ui_collect_form_controls(form_node_json: Json, state_fields: Json): Json {
  let form_node_id = runtime_ui_resolve_ast_node_id(form_node_json);
  let form_metadata_nodes = runtime_ui_collect_form_metadata_nodes(form_node_id);
  return runtime_ui_build_controls_from_nodes(form_metadata_nodes["control_nodes"], state_fields);
}

private function runtime_ui_form_field_property_key_matches_name(
  property_key_symbols: Json,
  property_name: string
): bool {
  let normalized_property_name = Runtime.json_to_str(property_name);
  if (normalized_property_name == "") {
    return false;
  }
  if (runtime_ui_symbol_list_contains(property_key_symbols, normalized_property_name)) {
    return true;
  }

  if (normalized_property_name == "on_load") {
    return runtime_ui_symbol_list_contains(property_key_symbols, "load");
  }
  if (normalized_property_name == "on_select") {
    return runtime_ui_symbol_list_contains(property_key_symbols, "select");
  }
  if (normalized_property_name == "on_select_key") {
    return runtime_ui_symbol_list_contains(property_key_symbols, "select")
      && runtime_ui_symbol_list_contains(property_key_symbols, "key");
  }
  if (normalized_property_name == "on_select_form") {
    return runtime_ui_symbol_list_contains(property_key_symbols, "select")
      && runtime_ui_symbol_list_contains(property_key_symbols, "form");
  }
  if (normalized_property_name == "on_double_click_form") {
    return runtime_ui_symbol_list_contains(property_key_symbols, "double")
      && runtime_ui_symbol_list_contains(property_key_symbols, "click")
      && runtime_ui_symbol_list_contains(property_key_symbols, "form");
  }

  return false;
}

private function runtime_ui_resolve_form_field_property_text_value(
  form_field_property_node_id: string
): string {
  let normalized_form_field_property_node_id = Runtime.json_to_str(form_field_property_node_id);
  if (normalized_form_field_property_node_id == "") {
    return "";
  }

  for (child_node_id in runtime_ui_list_child_node_ids(normalized_form_field_property_node_id)) {
    let normalized_child_node_id = Runtime.json_to_str(child_node_id);
    if (normalized_child_node_id == "") {
      continue;
    }
    if (
      runtime_ui_node_kind(ast.node_to_json(normalized_child_node_id))
      == "formFieldPropertyKey"
    ) {
      continue;
    }

    let literal_text = runtime_ui_find_first_descendant_literal_text(normalized_child_node_id);
    if (literal_text != "") {
      return literal_text;
    }

    let symbol_name = runtime_ui_resolve_node_symbol_name(ast.node_to_json(normalized_child_node_id));
    if (symbol_name != "") {
      return symbol_name;
    }

    symbol_name = runtime_ui_find_first_descendant_symbol_name(normalized_child_node_id);
    if (symbol_name != "") {
      return symbol_name;
    }
  }

  return "";
}

private function runtime_ui_resolve_shorthand_ui_from_from_control_nodes(control_nodes: Json): string {
  for (control_node_json in control_nodes ?? []) {
    let control_structure = runtime_ui_analyze_control_structure(control_node_json);
    if (Runtime.json_to_str(control_structure["control_id"]) != "ui") {
      continue;
    }

    let control_node_id = Runtime.json_to_str(control_structure["control_node_id"]);
    if (control_node_id == "") {
      continue;
    }

    let type_expression_node_id = Runtime.json_to_str(control_structure["type_expression_node_id"]);
    if (type_expression_node_id != "") {
      continue;
    }

    let form_field_from_node_id = Runtime.json_to_str(control_structure["form_field_from_node_id"]);
    let ui_from = runtime_ui_find_first_descendant_symbol_name(form_field_from_node_id);
    if (ui_from != "") {
      return ui_from;
    }
  }

  return "";
}

private function runtime_ui_has_any_controls(controls: Json): bool {
  for (control in controls ?? []) {
    return true;
  }

  return false;
}

private function runtime_ui_build_form_body_metadata(controls: Json): Json {
  return {
    "controls": controls ?? []
  };
}

private function runtime_ui_form_controls(form_metadata: Json): Json {
  let form_body = form_metadata["form_body"];
  if (form_body == null) {
    form_body = form_metadata["body"];
  }
  return runtime_ui_property_container_value(form_body, "controls") ?? [];
}

private function runtime_ui_has_any_json_entries(value: Json): bool {
  for (_ in value ?? {}) {
    return true;
  }

  return false;
}

private function runtime_ui_resolve_default_control_kind_from_binding_member(
  binding_member: Json
): string {
  if (binding_member == null) {
    return "";
  }

  let explicit_control_kind = Runtime.json_to_str(binding_member["control_kind"]);
  if (explicit_control_kind != "") {
    return explicit_control_kind;
  }

  let normalized_value_type = Runtime.json_to_str(binding_member["value_type"]);
  if (normalized_value_type == "bool" || normalized_value_type == "boolean") {
    return "toggle";
  }
  if (
    normalized_value_type == "byte"
    || normalized_value_type == "short"
    || normalized_value_type == "int"
    || normalized_value_type == "integer"
    || normalized_value_type == "long"
    || normalized_value_type == "uint"
    || normalized_value_type == "ulong"
    || normalized_value_type == "float"
    || normalized_value_type == "double"
    || normalized_value_type == "number"
  ) {
    return "number";
  }
  if (normalized_value_type == "decimal") {
    return "currency";
  }
  if (normalized_value_type == "date"
    || normalized_value_type == "datetime"
    || normalized_value_type == "timestamp") {
    return "date";
  }
  if (normalized_value_type == "multiline" || normalized_value_type == "textarea") {
    return "textarea";
  }
  return "text";
}

private function runtime_ui_build_default_control_metadata_from_binding_member(
  binding_member: Json
): Json {
  let field_name = Runtime.json_to_str(binding_member["field_name"]);
  let value_type = Runtime.json_to_str(binding_member["value_type"]);
  if (field_name == "") {
    return null;
  }

  let control_metadata: Json = {
    "id": field_name,
    "binding_path": "state." + field_name,
    "type": runtime_ui_resolve_default_control_kind_from_binding_member(binding_member)
  };
  if (value_type != "") {
    control_metadata["value_type"] = value_type;
  }
  if (binding_member["max_length"] != null) {
    control_metadata["max_length"] = binding_member["max_length"];
  }
  if (binding_member["display_length"] != null) {
    control_metadata["display_length"] = binding_member["display_length"];
  }
  if (binding_member["input_width"] != null) {
    control_metadata["input_width"] = binding_member["input_width"];
  }

  return control_metadata;
}

private function runtime_ui_build_form_controls_from_binding_members(binding_members: Json): Json {
  let controls: Json = [];
  let control_count = 0;

  for (binding_member in binding_members ?? {}) {
    let control_metadata = runtime_ui_build_default_control_metadata_from_binding_member(
      binding_member
    );
    if (control_metadata == null) {
      continue;
    }
    controls[control_count] = control_metadata;
    control_count = control_count + 1;
  }

  return controls;
}

private function runtime_ui_collect_property_node_analyses(
  node_json: Json,
  property_node_kinds: Json
): Json {
  let property_analyses: Json = [];
  if (node_json == null) {
    return property_analyses;
  }

  let node_id = runtime_ui_resolve_ast_node_id(node_json);
  if (node_id == "") {
    return property_analyses;
  }

  let property_analysis_count = 0;
  for (property_node_kind in property_node_kinds ?? []) {
    let property_matches = runtime_ui_collect_descendant_node_matches_by_kind(
      node_id,
      Runtime.json_to_str(property_node_kind)
    ) ?? [];
    for (property_match in property_matches) {
      let property_node_id = runtime_ui_match_node_id(property_match);
      if (property_node_id == "") {
        continue;
      }

      property_analyses[property_analysis_count] = runtime_ui_analyze_property_node(
        property_node_id
      );
      property_analysis_count = property_analysis_count + 1;
    }
  }

  return property_analyses;
}

private function runtime_ui_collect_button_property_node_analyses(button_node_json: Json): Json {
  return runtime_ui_collect_property_node_analyses(
    button_node_json,
    ["buttonProperty"]
  );
}

private function runtime_ui_collect_button_property_metadata(button_node_json: Json): Json {
  let property_metadata: Json = {};
  let button_property_analyses = runtime_ui_collect_button_property_node_analyses(button_node_json);
  for (button_property_analysis in button_property_analyses ?? []) {
    let property_literal_text = Runtime.json_to_str(button_property_analysis["literal_text"]);
    let property_symbol_names = button_property_analysis["symbol_names"] ?? [];
    for (property_symbol_name in property_symbol_names) {
      let normalized_property_symbol_name = Runtime.json_to_str(property_symbol_name);

      if (
        (
          normalized_property_symbol_name == "label"
          || normalized_property_symbol_name == "icon"
          || normalized_property_symbol_name == "shortcut"
          || normalized_property_symbol_name == "aria_label"
          || normalized_property_symbol_name == "description"
          || normalized_property_symbol_name == "ribbon_size"
          || normalized_property_symbol_name == "placement"
        )
        && property_metadata[normalized_property_symbol_name] == null
        && property_literal_text != ""
      ) {
        property_metadata[normalized_property_symbol_name] = property_literal_text;
        continue;
      }

      if (
        (
          normalized_property_symbol_name == "icon_only"
          || normalized_property_symbol_name == "requires_selection"
          || normalized_property_symbol_name == "visible"
          || normalized_property_symbol_name == "enabled"
        )
        && property_metadata["has_" + normalized_property_symbol_name] == null
      ) {
        if (property_literal_text == "true") {
          property_metadata["has_" + normalized_property_symbol_name] = true;
          property_metadata[normalized_property_symbol_name] = true;
        } else if (property_literal_text == "false") {
          property_metadata["has_" + normalized_property_symbol_name] = true;
          property_metadata[normalized_property_symbol_name] = false;
        }
      }
    }
  }
  return property_metadata;
}

private function runtime_ui_build_button_metadata_from_node(
  button_node_json: Json,
  state_fields: Json,
  current_form_binding_type: string,
  default_selection_path: string
): Json {
  let button_id = runtime_ui_resolve_node_symbol_name(button_node_json);
  let explicit_selection_field_name = runtime_ui_find_matching_state_field_property(
    button_node_json,
    "selection",
    state_fields,
    [button_id]
  );
  let button_metadata: Json = {
    "id": button_id
  };

  if (button_id == "") {
    return null;
  }
  let button_argument_analysis = runtime_ui_analyze_button_argument_metadata(button_node_json);
  let button_event_analysis = runtime_ui_analyze_button_event_metadata(button_node_json);
  let inferred_selection_path = Runtime.json_to_str(button_argument_analysis["selection_path"]);
  if (inferred_selection_path == "") {
    inferred_selection_path = Runtime.json_to_str(button_event_analysis["selection_path"]);
  }
  if (explicit_selection_field_name != "") {
    button_metadata["selection_path"] = "state." + explicit_selection_field_name;
  } else if (inferred_selection_path != "") {
    button_metadata["selection_path"] = inferred_selection_path;
  }

  let button_property_metadata = runtime_ui_collect_button_property_metadata(button_node_json);
  let button_visual_defaults = runtime_ui_resolve_button_visual_defaults(
    button_node_json,
    button_argument_analysis
  );
  let button_label = Runtime.json_to_str(button_property_metadata["label"]);
  if (button_label == "") {
    button_label = Runtime.json_to_str(button_visual_defaults["label"]);
  }
  let button_icon = Runtime.json_to_str(button_property_metadata["icon"]);
  if (button_icon == "") {
    button_icon = Runtime.json_to_str(button_visual_defaults["icon"]);
  }
  let button_shortcut = Runtime.json_to_str(button_property_metadata["shortcut"]);
  let button_aria_label = Runtime.json_to_str(button_property_metadata["aria_label"]);
  let button_description = Runtime.json_to_str(button_property_metadata["description"]);
  let button_ribbon_size = Runtime.json_to_str(button_property_metadata["ribbon_size"]);
  let button_placement = Runtime.json_to_str(button_property_metadata["placement"]);
  let button_icon_only = button_property_metadata["icon_only"] == true;
  let has_button_requires_selection = button_property_metadata["has_requires_selection"] == true;
  let button_requires_selection = button_property_metadata["requires_selection"] == true;
  let has_button_visible = button_property_metadata["has_visible"] == true;
  let button_visible = button_property_metadata["visible"] == true;
  let has_button_enabled = button_property_metadata["has_enabled"] == true;
  let button_enabled = button_property_metadata["enabled"] == true;
  let button_form_arg_expr = Runtime.json_to_str(button_argument_analysis["form_arg_expr"]);
  if (button_form_arg_expr == "") {
    button_form_arg_expr = Runtime.json_to_str(button_event_analysis["form_arg_expr"]);
  }
  if (
    Runtime.json_to_str(button_metadata["selection_path"]) == ""
    && button_requires_selection
  ) {
    let inferred_selection_field_name = "";
    if (Runtime.json_to_str(current_form_binding_type) != "") {
      inferred_selection_field_name = runtime_ui_find_first_matching_state_field_name_by_value_type(
        state_fields,
        current_form_binding_type
      );
    }
    if (inferred_selection_field_name != "") {
      let inferred_selection_path = "state." + inferred_selection_field_name;
      button_metadata["selection_path"] = inferred_selection_path;
      if (button_form_arg_expr == "form" && Runtime.json_to_str(current_form_binding_type) == "") {
        button_form_arg_expr = inferred_selection_path;
      }
    } else if (Runtime.json_to_str(default_selection_path) != "") {
      button_metadata["selection_path"] = default_selection_path;
      if (button_form_arg_expr == "form") {
        button_form_arg_expr = Runtime.json_to_str(default_selection_path);
      }
    }
  }
  if (button_label != "") {
    button_metadata["label"] = button_label;
  }
  if (button_icon != "") {
    button_metadata["icon"] = button_icon;
  }
  if (button_shortcut != "") {
    button_metadata["shortcut"] = button_shortcut;
  }
  if (button_aria_label != "") {
    button_metadata["aria_label"] = button_aria_label;
  }
  if (button_description != "") {
    button_metadata["description"] = button_description;
  }
  if (button_ribbon_size != "") {
    button_metadata["ribbon_size"] = button_ribbon_size;
  }
  if (button_placement != "") {
    button_metadata["placement"] = button_placement;
  }
  if (button_icon_only) {
    button_metadata["icon_only"] = true;
  }
  if (has_button_requires_selection) {
    button_metadata["requires_selection"] = button_requires_selection;
  }
  if (has_button_visible) {
    button_metadata["visible"] = button_visible;
  }
  if (has_button_enabled) {
    button_metadata["enabled"] = button_enabled;
  }
  if (button_form_arg_expr != "") {
    button_metadata["form_arg_expr"] = button_form_arg_expr;
  }
  let navigate_target_form = Runtime.json_to_str(button_event_analysis["navigate_target_form"]);
  let click_dispatch_target = Runtime.json_to_str(button_event_analysis["click_dispatch_target"]);
  let click_handler = Runtime.json_to_str(button_event_analysis["click_handler"]);
  if (click_handler != "" || click_dispatch_target != "" || navigate_target_form != "") {
    let click_event_metadata: Json = {};
    if (click_handler != "") {
      click_event_metadata["handler"] = click_handler;
    }
    if (click_dispatch_target != "") {
      click_event_metadata["dispatch_target"] = click_dispatch_target;
    }
    if (navigate_target_form != "") {
      click_event_metadata["form_id"] = navigate_target_form;
    }
    button_metadata["events"] = {
      "on_click": click_event_metadata
    };
  }

  let button_menu_items = runtime_ui_build_button_menu_items_from_node(
    button_node_json,
    state_fields
  );
  if (button_menu_items != null && button_menu_items[0] != null) {
    button_metadata["items"] = button_menu_items;
  }

  return button_metadata;
}

private function runtime_ui_resolve_button_visual_defaults(
  button_node_json: Json,
  button_argument_analysis: Json
): Json {
  let defaults: Json = {};
  if (button_node_json == null) {
    return defaults;
  }

  let button_declaration_symbol = Runtime.json_to_str(
    button_argument_analysis["declaration_symbol"]
  );
  if (button_declaration_symbol == "CreateFormButton") {
    defaults["label"] = "New";
    defaults["icon"] = "add";
    return defaults;
  }
  if (
    button_declaration_symbol == "ViewSelectionButton"
    || button_declaration_symbol == "ViewRecordButton"
  ) {
    defaults["label"] = "View";
    defaults["icon"] = "view";
    return defaults;
  }
  if (
    button_declaration_symbol == "EditSelectionButton"
    || button_declaration_symbol == "EditRecordButton"
  ) {
    defaults["label"] = "Edit";
    defaults["icon"] = "edit";
    return defaults;
  }

  return defaults;
}

private function runtime_ui_build_button_menu_items_from_node(
  menu_owner_node_json: Json,
  state_fields: Json
): Json {
  if (menu_owner_node_json == null) {
    return [];
  }

  let menu_owner_node_id = runtime_ui_resolve_ast_node_id(menu_owner_node_json);
  if (menu_owner_node_id == "") {
    return [];
  }

  let button_menu_node_id = runtime_ui_find_child_node_id_by_kind(
    menu_owner_node_id,
    "buttonMenuDeclaration"
  );
  if (button_menu_node_id == "") {
    return [];
  }

  let menu_items: Json = [];
  let menu_item_count = 0;
  for (child_node_id in runtime_ui_list_child_node_ids(button_menu_node_id)) {
    let child_node_json = ast.node_to_json(child_node_id);
    let child_kind = runtime_ui_node_kind(child_node_json);
    if (child_kind == "buttonMenuOptionDeclaration") {
      let menu_item_metadata = runtime_ui_build_button_metadata_from_node(
        child_node_json,
        state_fields,
        "",
        ""
      );
      if (menu_item_metadata != null) {
        menu_items[menu_item_count] = menu_item_metadata;
        menu_item_count = menu_item_count + 1;
      }
    } else if (child_kind == "buttonMenuSeparatorDeclaration") {
      menu_items[menu_item_count] = {
        "separator": true
      };
      menu_item_count = menu_item_count + 1;
    }
  }

  return menu_items;
}

private function runtime_ui_resolve_node_name_fragment_value(
  node_json: Json,
  field_name: string
): string {
  let normalized_field_name = Runtime.json_to_str(field_name);
  if (node_json == null || normalized_field_name == "") {
    return "";
  }

  let direct_value = Runtime.json_to_str(runtime_ui_property_value(node_json, normalized_field_name));
  if (direct_value != "") {
    return direct_value;
  }

  let name_fragments = node_json["name_fragments"] ?? [];
  for (name_fragment in name_fragments) {
    if (Runtime.json_to_str(name_fragment["field"]) != normalized_field_name) {
      continue;
    }
    let fragment_value = Runtime.json_to_str(name_fragment["value"]);
    if (fragment_value != "") {
      return fragment_value;
    }
  }

  return "";
}

private function runtime_ui_find_first_matching_descendant_value_internal(
  node_id: string,
  property_name: string,
  name_fragment_field_name: string,
  expected_kind: string,
  expected_symbol_name: string
): string {
  return runtime_ui_find_first_descendant_result_internal(
    node_id,
    "value",
    property_name,
    name_fragment_field_name,
    expected_kind,
    expected_symbol_name,
    "",
    false
  );
}

private function runtime_ui_find_first_descendant_result_internal(
  node_id: string,
  match_mode: string,
  property_name: string,
  name_fragment_field_name: string,
  expected_kind: string,
  expected_symbol_name: string,
  skipped_kind: string,
  callable_only: bool
): string {
  let normalized_node_id = Runtime.json_to_str(node_id);
  let normalized_match_mode = Runtime.json_to_str(match_mode);
  let normalized_property_name = Runtime.json_to_str(property_name);
  let normalized_name_fragment_field_name = Runtime.json_to_str(name_fragment_field_name);
  let normalized_expected_kind = Runtime.json_to_str(expected_kind);
  let normalized_expected_symbol_name = Runtime.json_to_str(expected_symbol_name);
  let normalized_skipped_kind = Runtime.json_to_str(skipped_kind);
  if (normalized_node_id == "") {
    return "";
  }

  let node_json = ast.node_to_json(normalized_node_id);
  if (normalized_match_mode == "symbol") {
    if (
      normalized_skipped_kind != ""
      && runtime_ui_node_kind(node_json) == normalized_skipped_kind
    ) {
      return "";
    }

    if (callable_only == true && runtime_ui_node_kind(node_json) == "postfixExpression") {
      let primary_expression_node_id = runtime_ui_find_child_node_id_by_kind(
        normalized_node_id,
        "primaryExpression"
      );
      let postfix_suffix_node_id = runtime_ui_find_child_node_id_by_kind(
        normalized_node_id,
        "postfixSuffix"
      );
      if (
        primary_expression_node_id != ""
        && postfix_suffix_node_id != ""
        && runtime_ui_node_or_descendant_has_kind(postfix_suffix_node_id, "arguments")
      ) {
        let callable_symbol = runtime_ui_find_first_descendant_symbol_name(
          primary_expression_node_id
        );
        if (callable_symbol != "") {
          return callable_symbol;
        }
      }
    }

    if (callable_only != true) {
      let symbol_name = runtime_ui_resolve_node_symbol_name(node_json);
      if (symbol_name != "") {
        return symbol_name;
      }
    }
  } else {
    if (
      normalized_expected_kind != ""
      && runtime_ui_node_kind(node_json) == normalized_expected_kind
    ) {
      return normalized_expected_kind;
    }
    if (
      normalized_expected_symbol_name != ""
      && runtime_ui_direct_node_symbol_name(node_json) == normalized_expected_symbol_name
    ) {
      return normalized_expected_symbol_name;
    }
    if (normalized_property_name != "") {
      let property_text = Runtime.json_to_str(
        runtime_ui_property_value(node_json, normalized_property_name)
      );
      if (property_text != "") {
        return property_text;
      }
    }
    if (normalized_name_fragment_field_name != "") {
      let fragment_value = runtime_ui_resolve_node_name_fragment_value(
        node_json,
        normalized_name_fragment_field_name
      );
      if (fragment_value != "") {
        return fragment_value;
      }
    }
  }

  for (child_node_id in runtime_ui_list_child_node_ids(normalized_node_id)) {
    let child_value = runtime_ui_find_first_descendant_result_internal(
      Runtime.json_to_str(child_node_id),
      normalized_match_mode,
      normalized_property_name,
      normalized_name_fragment_field_name,
      normalized_expected_kind,
      normalized_expected_symbol_name,
      normalized_skipped_kind,
      callable_only
    );
    if (child_value != "") {
      return child_value;
    }
  }

  return "";
}

private function runtime_ui_find_first_descendant_text_value_internal(
  node_id: string,
  property_name: string,
  name_fragment_field_name: string
): string {
  return runtime_ui_find_first_matching_descendant_value_internal(
    node_id,
    property_name,
    name_fragment_field_name,
    "",
    ""
  );
}

private function runtime_ui_find_first_descendant_name_fragment_value(
  node_id: string,
  field_name: string
): string {
  let normalized_field_name = Runtime.json_to_str(field_name);
  if (normalized_field_name == "") {
    return "";
  }
  return runtime_ui_find_first_descendant_text_value_internal(
    node_id,
    "",
    normalized_field_name
  );
}

private function runtime_ui_build_synthesized_callable_alias(node_json: Json): string {
  let normalized_node_id = runtime_ui_resolve_canonical_ast_node_id(node_json);
  if (normalized_node_id == "") {
    return "";
  }
  return "ui_local_" + normalized_node_id;
}

private function runtime_ui_resolve_button_event_navigate_reference(
  button_event_node_id: string
): string {
  let normalized_button_event_node_id = Runtime.json_to_str(button_event_node_id);
  if (normalized_button_event_node_id == "") {
    return "";
  }

  let navigate_expression_nodes = runtime_ui_collect_descendant_node_matches_by_kind(
    normalized_button_event_node_id,
    "navigateExpression"
  ) ?? [];
  for (navigate_expression_match in navigate_expression_nodes) {
    let navigate_expression_node_id = runtime_ui_match_node_id(navigate_expression_match);
    if (navigate_expression_node_id == "") {
      continue;
    }
    let constructor_type_node_id = runtime_ui_find_child_node_id_by_kind(
      navigate_expression_node_id,
      "constructorType"
    );
    let navigate_target_reference = runtime_ui_find_first_descendant_symbol_name(
      constructor_type_node_id != "" ? constructor_type_node_id : navigate_expression_node_id
    );
    if (navigate_target_reference != "") {
      return navigate_target_reference;
    }
  }

  return "";
}

private function runtime_ui_analyze_button_event_argument_metadata(
  button_event_node_id: string
): Json {
  let analysis: Json = {};
  let normalized_button_event_node_id = Runtime.json_to_str(button_event_node_id);
  if (normalized_button_event_node_id == "") {
    return analysis;
  }

  let navigate_expression_nodes = runtime_ui_collect_descendant_node_matches_by_kind(
    normalized_button_event_node_id,
    "navigateExpression"
  ) ?? [];
  for (navigate_expression_match in navigate_expression_nodes) {
    let navigate_expression_node_id = runtime_ui_match_node_id(navigate_expression_match);
    if (navigate_expression_node_id == "") {
      continue;
    }

    let arguments_node_id = runtime_ui_find_child_node_id_by_kind(
      navigate_expression_node_id,
      "arguments"
    );
    if (arguments_node_id == "") {
      continue;
    }

    let argument_list_node_id = runtime_ui_find_child_node_id_by_kind(
      arguments_node_id,
      "argumentList"
    );
    if (argument_list_node_id == "") {
      continue;
    }

    let argument_children = ast.list_children(argument_list_node_id) ?? [];
    for (argument_child in argument_children) {
      let argument_node_id = runtime_ui_match_node_id(argument_child);
      if (argument_node_id == "") {
        continue;
      }
      if (runtime_ui_node_kind(ast.node_to_json(argument_node_id)) != "argument") {
        continue;
      }

      let argument_expression = runtime_ui_resolve_button_argument_expression(argument_node_id);
      if (
        Runtime.json_to_str(analysis["form_arg_expr"]) == ""
        && argument_expression != ""
      ) {
        analysis["form_arg_expr"] = argument_expression;
      }
      if (
        Runtime.json_to_str(analysis["selection_path"]) == ""
        && argument_expression != ""
        && argument_expression != "form"
      ) {
        analysis["selection_path"] = argument_expression;
      }
      if (
        Runtime.json_to_str(analysis["form_arg_expr"]) != ""
        && Runtime.json_to_str(analysis["selection_path"]) != ""
      ) {
        return analysis;
      }
    }
  }

  return analysis;
}

private function runtime_ui_analyze_button_event_metadata(button_node_json: Json): Json {
  let analysis: Json = {};
  if (button_node_json == null) {
    return analysis;
  }

  let button_node_id = runtime_ui_resolve_ast_node_id(button_node_json);
  if (button_node_id == "") {
    return analysis;
  }

  let navigate_target_reference = "";
  let button_event_nodes = runtime_ui_collect_descendant_node_matches_by_kind(
    button_node_id,
    "buttonEvent"
  ) ?? [];
  for (button_event_match in button_event_nodes) {
    let button_event_node_id = runtime_ui_match_node_id(button_event_match);
    if (button_event_node_id == "") {
      continue;
    }

    let button_event_argument_analysis = runtime_ui_analyze_button_event_argument_metadata(
      button_event_node_id
    );
    if (Runtime.json_to_str(analysis["form_arg_expr"]) == "") {
      let event_form_arg_expr = Runtime.json_to_str(
        button_event_argument_analysis["form_arg_expr"]
      );
      if (event_form_arg_expr != "") {
        analysis["form_arg_expr"] = event_form_arg_expr;
      }
    }
    if (Runtime.json_to_str(analysis["selection_path"]) == "") {
      let event_selection_path = Runtime.json_to_str(
        button_event_argument_analysis["selection_path"]
      );
      if (event_selection_path != "") {
        analysis["selection_path"] = event_selection_path;
      }
    }

    let button_event_node_json = ast.node_to_json(button_event_node_id);
    if (Runtime.json_to_str(analysis["click_dispatch_target"]) == "") {
      let callable_alias = runtime_ui_resolve_node_name_fragment_value(
        button_event_node_json,
        "callable_alias"
      );
      if (callable_alias != "") {
        analysis["click_dispatch_target"] = callable_alias;
      } else {
        let button_event_symbol = runtime_ui_direct_node_symbol_name(button_event_node_json);
        if (button_event_symbol != "") {
          analysis["click_dispatch_target"] = button_event_symbol;
        } else {
          let synthesized_dispatch_target = runtime_ui_build_synthesized_callable_alias(
            button_event_node_json
          );
          if (synthesized_dispatch_target != "") {
            analysis["click_dispatch_target"] = synthesized_dispatch_target;
          }
        }
      }
    }

    if (navigate_target_reference == "") {
      navigate_target_reference = runtime_ui_resolve_button_event_navigate_reference(
        button_event_node_id
      );
      if (navigate_target_reference != "") {
        analysis["navigate_target_reference"] = navigate_target_reference;
      }
    }

    if (Runtime.json_to_str(analysis["navigate_target_form"]) == "") {
      let navigate_target_form = "";
      if (navigate_target_reference != "") {
        navigate_target_form = runtime_ui_resolve_button_navigate_target_form_reference(
          button_node_json,
          navigate_target_reference
        );
      }
      if (navigate_target_form == "") {
        navigate_target_form = runtime_ui_resolve_button_target_form_from_node(
          button_node_json,
          button_event_node_id
        );
      }
      if (navigate_target_form != "") {
        analysis["navigate_target_form"] = navigate_target_form;
      }
    }
  }

  if (Runtime.json_to_str(analysis["navigate_target_form"]) == "") {
    let button_declaration_node_id = runtime_ui_find_button_declaration_node_id(button_node_id);
    if (button_declaration_node_id != "") {
      let declaration_target_form = runtime_ui_resolve_button_target_form_from_node(
        button_node_json,
        button_declaration_node_id
      );
      if (declaration_target_form != "") {
        analysis["navigate_target_form"] = declaration_target_form;
      }
    }
  }

  if (Runtime.json_to_str(analysis["navigate_target_form"]) == "") {
    let descendant_target_form = runtime_ui_find_first_descendant_form_symbol_name(button_node_id);
    if (descendant_target_form != "") {
      analysis["navigate_target_form"] = descendant_target_form;
    }
  }

  let navigate_target_form = Runtime.json_to_str(analysis["navigate_target_form"]);
  let click_dispatch_target = Runtime.json_to_str(analysis["click_dispatch_target"]);
  if (click_dispatch_target != "" && click_dispatch_target != navigate_target_form) {
    analysis["click_handler"] = click_dispatch_target;
  } else {
    let reflected_handler = runtime_ui_find_declaration_symbol_property(button_node_json, "on_click");
    if (reflected_handler == "") {
      reflected_handler = runtime_ui_find_declaration_symbol_property(button_node_json, "click");
    }
    if (reflected_handler != "" && reflected_handler != navigate_target_form) {
      analysis["click_handler"] = reflected_handler;
    }
  }

  return analysis;
}

private function runtime_ui_resolve_button_click_dispatch_target_from_analysis(
  button_event_analysis: Json
): string {
  return Runtime.json_to_str(button_event_analysis["click_dispatch_target"]);
}

private function runtime_ui_resolve_button_click_dispatch_target(
  button_node_json: Json
): string {
  return runtime_ui_resolve_button_click_dispatch_target_from_analysis(
    runtime_ui_analyze_button_event_metadata(button_node_json)
  );
}

private function runtime_ui_resolve_button_navigate_reference_from_analysis(button_event_analysis: Json): string {
  return Runtime.json_to_str(button_event_analysis["navigate_target_reference"]);
}

private function runtime_ui_resolve_button_navigate_reference(button_node_json: Json): string {
  return runtime_ui_resolve_button_navigate_reference_from_analysis(
    runtime_ui_analyze_button_event_metadata(button_node_json)
  );
}

private function runtime_ui_resolve_button_navigate_target_form_reference(
  button_node_json: Json,
  navigate_target_reference: string
): string {
  let normalized_navigate_target_reference = Runtime.json_to_str(navigate_target_reference);
  if (button_node_json == null || normalized_navigate_target_reference == "") {
    return "";
  }

  if (
    runtime_ui_find_named_declaration_node_by_kind(
      "formDeclaration",
      normalized_navigate_target_reference
    ) != null
  ) {
    return normalized_navigate_target_reference;
  }

  return runtime_ui_resolve_mounted_form_target_for_source(
    button_node_json,
    normalized_navigate_target_reference
  );
}

private function runtime_ui_resolve_button_target_form(button_node_json: Json): string {
  return runtime_ui_resolve_button_target_form_from_analysis(
    runtime_ui_analyze_button_event_metadata(button_node_json)
  );
}

private function runtime_ui_resolve_button_target_form_from_analysis(button_event_analysis: Json): string {
  return Runtime.json_to_str(button_event_analysis["navigate_target_form"]);
}

private function runtime_ui_find_button_declaration_node_id(button_node_id: string): string {
  return runtime_ui_find_first_child_node_id_by_kinds(
    button_node_id,
    [
      "buttonInstanceDeclaration",
      "buttonTemplateDeclaration"
    ]
  );
}

private function runtime_ui_resolve_button_form_arg_expression(button_node_json: Json): string {
  return Runtime.json_to_str(
    runtime_ui_analyze_button_argument_metadata(button_node_json)["form_arg_expr"]
  );
}

private function runtime_ui_analyze_button_argument_metadata(button_node_json: Json): Json {
  let analysis: Json = {};
  if (button_node_json == null) {
    return analysis;
  }

  let button_node_id = runtime_ui_resolve_ast_node_id(button_node_json);
  if (button_node_id == "") {
    return analysis;
  }

  let button_declaration_node_id = runtime_ui_find_button_declaration_node_id(button_node_id);
  if (button_declaration_node_id == "") {
    return analysis;
  }

  let declaration_symbol = runtime_ui_find_first_descendant_symbol_name(button_declaration_node_id);
  if (declaration_symbol != "") {
    analysis["declaration_symbol"] = declaration_symbol;
  }

  let arguments_node_id = runtime_ui_find_child_node_id_by_kind(
    button_declaration_node_id,
    "arguments"
  );
  if (arguments_node_id == "") {
    return analysis;
  }

  let argument_list_node_id = runtime_ui_find_child_node_id_by_kind(
    arguments_node_id,
    "argumentList"
  );
  if (argument_list_node_id == "") {
    return analysis;
  }

  let argument_children = ast.list_children(argument_list_node_id) ?? [];
  for (argument_child in argument_children) {
    let argument_node_id = runtime_ui_match_node_id(argument_child);
    if (argument_node_id == "") {
      continue;
    }
    if (runtime_ui_node_kind(ast.node_to_json(argument_node_id)) != "argument") {
      continue;
    }
    let argument_expression = runtime_ui_resolve_button_argument_expression(argument_node_id);
    if (
      Runtime.json_to_str(analysis["form_arg_expr"]) == "" &&
      argument_expression != ""
    ) {
      analysis["form_arg_expr"] = argument_expression;
    }
    if (
      Runtime.json_to_str(analysis["selection_path"]) == "" &&
      argument_expression != "" &&
      argument_expression != "form"
    ) {
      analysis["selection_path"] = argument_expression;
    }
    if (
      Runtime.json_to_str(analysis["form_arg_expr"]) != "" &&
      Runtime.json_to_str(analysis["selection_path"]) != ""
    ) {
      break;
    }
  }

  return analysis;
}

private function runtime_ui_resolve_button_argument_expression(argument_node_id: string): string {
  let normalized_argument_node_id = Runtime.json_to_str(argument_node_id);
  if (normalized_argument_node_id == "") {
    return "";
  }

  let member_access_name_nodes = runtime_ui_collect_descendant_node_matches_by_kind(
    normalized_argument_node_id,
    "memberAccessName"
  ) ?? [];
  let member_owner_reference_nodes = runtime_ui_collect_descendant_node_matches_by_kind(
    normalized_argument_node_id,
    "memberOwnerReference"
  ) ?? [];
  for (member_owner_reference_match in member_owner_reference_nodes) {
    let member_owner_reference_node_json = ast.node_to_json(
      runtime_ui_match_node_id(member_owner_reference_match)
    );
    let member_owner_literal = Runtime.json_to_str(
      runtime_ui_property_value(member_owner_reference_node_json, "literal_text")
    );
    if (member_owner_literal == "form") {
      return "form";
    }
    if (member_owner_literal == "state") {
      for (member_access_name_match in member_access_name_nodes) {
        let member_access_name_node_id = runtime_ui_match_node_id(member_access_name_match);
        if (member_access_name_node_id == "") {
          continue;
        }
        let member_name = runtime_ui_find_first_descendant_symbol_name(member_access_name_node_id);
        if (member_name != "") {
          return "state." + member_name;
        }
      }
    }
  }

  let keyword_identifier_nodes = runtime_ui_collect_descendant_node_matches_by_kind(
    normalized_argument_node_id,
    "keywordIdentifier"
  ) ?? [];
  for (keyword_identifier_match in keyword_identifier_nodes) {
    let keyword_identifier_node_json = ast.node_to_json(
      runtime_ui_match_node_id(keyword_identifier_match)
    );
    if (runtime_ui_resolve_node_symbol_name(keyword_identifier_node_json) == "form") {
      return "form";
    }
  }

  return "";
}

private function runtime_ui_resolve_button_selection_path(button_node_json: Json): string {
  return Runtime.json_to_str(
    runtime_ui_analyze_button_argument_metadata(button_node_json)["selection_path"]
  );
}

private function runtime_ui_collect_descendant_form_target_symbol_names(node_id: string): Json {
  let normalized_node_id = Runtime.json_to_str(node_id);
  let collected_symbol_names: Json = [];
  let collected_count = 0;
  if (normalized_node_id == "") {
    return collected_symbol_names;
  }

  let descendant_identifier_node_ids = runtime_ui_collect_descendant_node_ids_by_kinds(
    normalized_node_id,
    [
      "qualifiedIdentifier",
      "identifier"
    ]
  ) ?? [];
  for (descendant_identifier_node_id in descendant_identifier_node_ids) {
    let identifier_node_json = ast.node_to_json(
      Runtime.json_to_str(descendant_identifier_node_id)
    );
    let descendant_symbol_name = runtime_ui_resolve_node_symbol_name(identifier_node_json);
    if (descendant_symbol_name == "") {
      continue;
    }
    collected_symbol_names[collected_count] = descendant_symbol_name;
    collected_count = collected_count + 1;
  }

  return collected_symbol_names;
}

private function runtime_ui_collect_descendant_node_ids_by_kinds(
  node_id: string,
  descendant_kinds: Json
): Json {
  return runtime_ui_collect_ordered_node_ids_by_kinds(node_id, descendant_kinds, "descendant");
}

private function runtime_ui_find_first_matching_descendant_form_target_symbol_name(
  button_node_json: Json,
  node_id: string,
  resolution_mode: string
): string {
  let descendant_symbol_names = runtime_ui_collect_descendant_form_target_symbol_names(node_id);
  for (descendant_symbol_name in descendant_symbol_names) {
    let normalized_descendant_symbol_name = Runtime.json_to_str(descendant_symbol_name);
    if (normalized_descendant_symbol_name == "") {
      continue;
    }
    if (resolution_mode == "mounted") {
      let mounted_target_form = runtime_ui_resolve_mounted_form_target_for_source(
        button_node_json,
        normalized_descendant_symbol_name
      );
      if (mounted_target_form != "") {
        return mounted_target_form;
      }
      continue;
    }
    if (
      runtime_ui_find_named_declaration_node_by_kind(
        "formDeclaration",
        normalized_descendant_symbol_name
      ) != null
    ) {
      return normalized_descendant_symbol_name;
    }
  }

  return "";
}

private function runtime_ui_find_first_descendant_mounted_form_symbol_name(
  button_node_json: Json,
  node_id: string
): string {
  return runtime_ui_find_first_matching_descendant_form_target_symbol_name(
    button_node_json,
    node_id,
    "mounted"
  );
}

private function runtime_ui_find_first_descendant_form_symbol_name(node_id: string): string {
  return runtime_ui_find_first_matching_descendant_form_target_symbol_name(
    null,
    node_id,
    "form"
  );
}

private function runtime_ui_resolve_button_target_form_from_node(
  button_node_json: Json,
  node_id: string
): string {
  let target_form = runtime_ui_find_first_descendant_form_symbol_name(node_id);
  if (target_form != "") {
    return target_form;
  }

  return runtime_ui_find_first_descendant_mounted_form_symbol_name(
    button_node_json,
    node_id
  );
}

private function runtime_ui_collect_form_buttons(form_node_json: Json, state_fields: Json): Json {
  let form_node_id = runtime_ui_resolve_ast_node_id(form_node_json);
  let form_metadata_nodes = runtime_ui_collect_form_metadata_nodes(form_node_id);
  let direct_form_structure = runtime_ui_analyze_direct_form_structure(form_node_json);
  return runtime_ui_build_buttons_from_nodes(
    form_metadata_nodes["button_nodes"],
    state_fields,
    Runtime.json_to_str(direct_form_structure["ui_from"]),
    runtime_ui_resolve_default_selection_field_name(
      form_metadata_nodes["control_nodes"],
      state_fields
    )
  );
}

private function runtime_ui_build_buttons_from_nodes(
  button_nodes: Json,
  state_fields: Json,
  current_form_binding_type: string,
  default_selection_field_name: string
): Json {
  let buttons: Json = [];
  let button_count = 0;

  for (button_node_json in button_nodes ?? []) {
    let button_metadata = runtime_ui_build_button_metadata_from_node(
      button_node_json,
      state_fields,
      current_form_binding_type,
      default_selection_field_name
    );
    if (button_metadata == null) {
      continue;
    }
    buttons[button_count] = button_metadata;
    button_count = button_count + 1;
  }

  return buttons;
}

private function runtime_ui_collect_form_metadata_nodes_internal(
  form_node_id: string,
  collect_control_nodes: bool
): Json {
  let normalized_form_node_id = Runtime.json_to_str(form_node_id);
  let collected_nodes: Json = {
    "state_nodes": [],
    "control_nodes": [],
    "button_nodes": []
  };
  let state_count = 0;
  let control_count = 0;
  let button_count = 0;

  if (normalized_form_node_id == "") {
    return collected_nodes;
  }

  for (child_node_id in runtime_ui_list_child_node_ids(normalized_form_node_id)) {
    let normalized_child_node_id = Runtime.json_to_str(child_node_id);
    if (normalized_child_node_id == "") {
      continue;
    }

    let child_node_json = ast.node_to_json(normalized_child_node_id);
    let child_kind = runtime_ui_node_kind(child_node_json);
    if (child_kind == "formStateDeclaration") {
      collected_nodes["state_nodes"][state_count] = child_node_json;
      state_count = state_count + 1;
      continue;
    } else if (child_kind == "formField") {
      if (collect_control_nodes) {
        collected_nodes["control_nodes"][control_count] = child_node_json;
        control_count = control_count + 1;
      }
      continue;
    } else if (child_kind == "formInlineControlField") {
      if (collect_control_nodes) {
        collected_nodes["control_nodes"][control_count] = child_node_json;
        control_count = control_count + 1;
      }
      continue;
    } else if (child_kind == "buttonDeclaration") {
      collected_nodes["button_nodes"][button_count] = child_node_json;
      button_count = button_count + 1;
      continue;
    } else if (child_kind == "formBodySection") {
      let descendant_nodes = runtime_ui_collect_form_metadata_nodes_internal(
        normalized_child_node_id,
        true
      );
      for (state_node_json in descendant_nodes["state_nodes"] ?? []) {
        collected_nodes["state_nodes"][state_count] = state_node_json;
        state_count = state_count + 1;
      }
      for (control_node_json in descendant_nodes["control_nodes"] ?? []) {
        collected_nodes["control_nodes"][control_count] = control_node_json;
        control_count = control_count + 1;
      }
      for (button_node_json in descendant_nodes["button_nodes"] ?? []) {
        collected_nodes["button_nodes"][button_count] = button_node_json;
        button_count = button_count + 1;
      }
      continue;
    } else if (
      child_kind == "formEvent"
      || child_kind == "formLayoutSection"
      || child_kind == "formHeaderProperty"
      || child_kind == "formInlineHeaderProperty"
    ) {
      continue;
    }

    let descendant_nodes = runtime_ui_collect_form_metadata_nodes_internal(
      normalized_child_node_id,
      collect_control_nodes
    );
    for (state_node_json in descendant_nodes["state_nodes"] ?? []) {
      collected_nodes["state_nodes"][state_count] = state_node_json;
      state_count = state_count + 1;
    }
    for (control_node_json in descendant_nodes["control_nodes"] ?? []) {
      collected_nodes["control_nodes"][control_count] = control_node_json;
      control_count = control_count + 1;
    }
    for (button_node_json in descendant_nodes["button_nodes"] ?? []) {
      collected_nodes["button_nodes"][button_count] = button_node_json;
      button_count = button_count + 1;
    }
  }

  return collected_nodes;
}

private function runtime_ui_resolve_default_selection_field_name(
  control_nodes: Json,
  state_fields: Json
): string {
  for (control_node_json in control_nodes ?? []) {
    let control_metadata = runtime_ui_build_control_metadata_from_node(
      control_node_json,
      state_fields
    );
    let selection_path = Runtime.json_to_str(control_metadata["selection_path"]);
    if (selection_path == "") {
      continue;
    }
    return selection_path;
  }
  return "";
}

private function runtime_ui_collect_form_metadata_nodes(form_node_id: string): Json {
  return runtime_ui_collect_form_metadata_nodes_internal(form_node_id, true);
}

private function runtime_ui_collect_form_button_nodes_in_source_order(form_node_id: string): Json {
  let normalized_form_node_id = Runtime.json_to_str(form_node_id);
  let button_nodes: Json = [];
  let button_count = 0;

  if (normalized_form_node_id == "") {
    return button_nodes;
  }

  let child_node_ids = runtime_ui_list_child_node_ids(normalized_form_node_id);
  for (child_node_id in child_node_ids) {
    let normalized_child_node_id = Runtime.json_to_str(child_node_id);
    if (normalized_child_node_id == "") {
      continue;
    }

    let child_node_json = ast.node_to_json(normalized_child_node_id);
    let child_kind = Runtime.json_to_str(child_node_json["kind_name"]);
    if (child_kind == "") {
      child_kind = Runtime.json_to_str(child_node_json["kind"]);
    }
    if (child_kind == "buttonDeclaration") {
      button_nodes[button_count] = child_node_json;
      button_count = button_count + 1;
      continue;
    }

    let descendant_button_nodes = runtime_ui_collect_form_button_nodes_in_source_order(
      normalized_child_node_id
    ) ?? [];
    for (descendant_button_node in descendant_button_nodes) {
      button_nodes[button_count] = descendant_button_node;
      button_count = button_count + 1;
    }
  }

  return button_nodes;
}

private function runtime_ui_find_button_node_in_form(form_node_json: Json, button_id: string): Json {
  let normalized_button_id = Runtime.json_to_str(button_id);
  let form_node_id = runtime_ui_resolve_ast_node_id(form_node_json);
  if (normalized_button_id == "" || form_node_id == "") {
    return null;
  }

  let button_nodes = runtime_ui_collect_form_button_nodes_in_source_order(form_node_id) ?? [];
  for (button_node_json in button_nodes) {
    if (runtime_ui_resolve_node_symbol_name(button_node_json) == normalized_button_id) {
      return button_node_json;
    }
  }

  return null;
}

private function runtime_ui_button_metadata_starts_before(
  form_node_json: Json,
  left_button_metadata: Json,
  right_button_metadata: Json
): bool {
  let left_button_id = Runtime.json_to_str(left_button_metadata["id"]);
  let right_button_id = Runtime.json_to_str(right_button_metadata["id"]);
  if (left_button_id == "" || right_button_id == "") {
    return false;
  }

  let left_button_node_json = runtime_ui_find_button_node_in_form(form_node_json, left_button_id);
  let right_button_node_json = runtime_ui_find_button_node_in_form(form_node_json, right_button_id);
  if (left_button_node_json == null || right_button_node_json == null) {
    return false;
  }

  return runtime_ui_node_starts_before(
    runtime_ui_resolve_ast_node_id(left_button_node_json),
    runtime_ui_resolve_ast_node_id(right_button_node_json)
  );
}

private function runtime_ui_sort_button_metadata_entries_by_source_order(
  form_node_json: Json,
  buttons: Json
): Json {
  let ordered_buttons: Json = [];
  let ordered_button_count = 0;

  for (button_metadata in buttons ?? []) {
    let insert_index = ordered_button_count;
    let compare_index = 0;
    for (ordered_button_metadata in ordered_buttons) {
      if (
        runtime_ui_button_metadata_starts_before(
          form_node_json,
          button_metadata,
          ordered_button_metadata
        )
      ) {
        insert_index = compare_index;
        break;
      }
      compare_index = compare_index + 1;
    }

    let shift_index = ordered_button_count;
    while (shift_index > insert_index) {
      ordered_buttons[shift_index] = ordered_buttons[shift_index - 1];
      shift_index = shift_index - 1;
    }
    ordered_buttons[insert_index] = button_metadata;
    ordered_button_count = ordered_button_count + 1;
  }

  return ordered_buttons;
}

private function runtime_ui_build_form_binding_blueprint_metadata(
  binding_type: string,
  binding_kind: string,
  binding_members: Json,
  state_fields: Json
): Json {
  let blueprint: Json = {
    "form": {
      "kind": "root",
      "binding_type": binding_type,
      "binding_kind": binding_kind
    },
    "state": {
      "kind": "root",
      "binding_type": binding_type,
      "binding_kind": binding_kind
    }
  };

  for (state_field in state_fields ?? []) {
    let field_name = Runtime.json_to_str(state_field["name"]);
    if (field_name == "") {
      continue;
    }
    blueprint["form." + field_name] = {
      "kind": "field",
      "field_name": field_name
    };
    blueprint["state." + field_name] = {
      "kind": "field",
      "field_name": field_name
    };
  }

  for (binding_member in binding_members ?? []) {
    let field_name = Runtime.json_to_str(binding_member["field_name"]);
    if (field_name == "") {
      continue;
    }
    if (blueprint["form." + field_name] == null) {
      blueprint["form." + field_name] = binding_member;
    }
    if (blueprint["state." + field_name] == null) {
      blueprint["state." + field_name] = binding_member;
    }
  }

  return blueprint;
}

private function runtime_ui_analyze_symbol_property_subtree(node_id: string): Json {
  let normalized_node_id = Runtime.json_to_str(node_id);
  let analysis: Json = {
    "symbol_names": [],
    "first_callable_symbol": ""
  };
  if (normalized_node_id == "") {
    return analysis;
  }

  let child_symbol_names = runtime_ui_collect_descendant_symbol_names(normalized_node_id);
  analysis["symbol_names"] = child_symbol_names;
  analysis["first_callable_symbol"] = runtime_ui_find_first_descendant_callable_symbol_name(
    normalized_node_id
  );

  return analysis;
}

private function runtime_ui_find_declaration_symbol_property(
  node_json: Json,
  property_name: string
): string {
  let normalized_property_name = Runtime.json_to_str(property_name);
  if (node_json == null || normalized_property_name == "") {
    return "";
  }

  let node_id = runtime_ui_resolve_ast_node_id(node_json);
  if (node_id == "") {
    return "";
  }

  let child_nodes = ast.list_children(node_id) ?? [];
  for (child_node in child_nodes) {
    let child_node_id = runtime_ui_match_node_id(child_node);
    let child_property_analysis = runtime_ui_analyze_symbol_property_subtree(child_node_id);
    let property_symbol_target = runtime_ui_resolve_symbol_property_target_from_analysis(
      child_property_analysis,
      normalized_property_name
    );
    if (property_symbol_target != "") {
      return property_symbol_target;
    }
  }

  return "";
}

private function runtime_ui_resolve_symbol_property_target_from_analysis(
  property_analysis: Json,
  property_name: string
): string {
  let normalized_property_name = Runtime.json_to_str(property_name);
  if (normalized_property_name == "") {
    return "";
  }

  let property_symbol_names = property_analysis["symbol_names"] ?? [];
  if (!runtime_ui_symbol_list_contains(property_symbol_names, normalized_property_name)) {
    return "";
  }

  let callable_symbol = Runtime.json_to_str(property_analysis["first_callable_symbol"]);
  if (callable_symbol != "" && callable_symbol != normalized_property_name) {
    return callable_symbol;
  }

  for (child_symbol_name in property_symbol_names) {
    let normalized_child_symbol_name = Runtime.json_to_str(child_symbol_name);
    if (
      normalized_child_symbol_name != ""
      && normalized_child_symbol_name != normalized_property_name
    ) {
      return normalized_child_symbol_name;
    }
  }

  return "";
}

private function runtime_ui_find_form_header_symbol_property_internal(
  node_id: string,
  property_name: string
): string {
  let normalized_node_id = Runtime.json_to_str(node_id);
  let normalized_property_name = Runtime.json_to_str(property_name);
  if (normalized_node_id == "" || normalized_property_name == "") {
    return "";
  }

  let header_property_kinds: Json = [
    "formHeaderProperty",
    "formInlineHeaderProperty"
  ];
  let wrapper_kinds: Json = [
    "formHeader",
    "formDeclarationWithHeader",
    "formDeclarationWithoutHeader",
    "formInlineBodyItem",
    "formBody",
    "formBodyMember",
    "formSection"
  ];

  for (child_node_id in runtime_ui_list_child_node_ids(normalized_node_id)) {
    let normalized_child_node_id = Runtime.json_to_str(child_node_id);
    if (normalized_child_node_id == "") {
      continue;
    }
    let child_node_json = ast.node_to_json(normalized_child_node_id);
    let child_kind = runtime_ui_node_kind(child_node_json);

    if (runtime_ui_symbol_list_contains(header_property_kinds, child_kind)) {
      let child_symbol_names = runtime_ui_collect_descendant_symbol_names(
        normalized_child_node_id
      );
      if (!runtime_ui_symbol_list_contains(child_symbol_names, normalized_property_name)) {
        continue;
      }

      let callable_symbol = runtime_ui_find_first_descendant_callable_symbol_name(
        normalized_child_node_id
      );
      if (callable_symbol != "" && callable_symbol != normalized_property_name) {
        return callable_symbol;
      }

      for (child_symbol_name in child_symbol_names) {
        let normalized_child_symbol_name = Runtime.json_to_str(child_symbol_name);
        if (
          normalized_child_symbol_name != ""
          && normalized_child_symbol_name != normalized_property_name
        ) {
          return normalized_child_symbol_name;
        }
      }
      continue;
    }

    if (runtime_ui_symbol_list_contains(wrapper_kinds, child_kind)) {
      let nested_match = runtime_ui_find_form_header_symbol_property_internal(
        normalized_child_node_id,
        normalized_property_name
      );
      if (nested_match != "") {
        return nested_match;
      }
    }
  }

  return "";
}

private function runtime_ui_find_form_header_symbol_property(
  form_node_json: Json,
  property_name: string
): string {
  let normalized_property_name = Runtime.json_to_str(property_name);
  if (form_node_json == null || normalized_property_name == "") {
    return "";
  }

  let form_node_id = runtime_ui_resolve_ast_node_id(form_node_json);
  if (form_node_id == "") {
    return "";
  }

  return runtime_ui_find_form_header_symbol_property_internal(
    form_node_id,
    normalized_property_name
  );
}

private function runtime_ui_form_has_direct_modifier(
  form_node_id: string,
  expected_modifier_kind: string
): bool {
  return runtime_ui_find_direct_child_node_id_by_kind(form_node_id, expected_modifier_kind) != "";
}

private function runtime_ui_find_first_descendant_symbol_name_by_mode_internal(
  node_id: string,
  skipped_kind: string,
  callable_only: bool
): string {
  return runtime_ui_find_first_descendant_result_internal(
    node_id,
    "symbol",
    "",
    "",
    "",
    "",
    skipped_kind,
    callable_only
  );
}

private function runtime_ui_find_first_descendant_callable_symbol_name(node_id: string): string {
  return runtime_ui_find_first_descendant_symbol_name_by_mode_internal(node_id, "", true);
}

private function runtime_ui_analyze_direct_form_structure(form_node_json: Json): Json {
  let analysis: Json = {
    "has_ui_field": false,
    "ui_from": null,
    "has_load_property": false,
    "load_handler": ""
  };
  let form_node_id = runtime_ui_resolve_ast_node_id(form_node_json);
  if (form_node_id == "") {
    return analysis;
  }

  for (child_node_id in runtime_ui_list_child_node_ids(form_node_id)) {
    let normalized_child_node_id = Runtime.json_to_str(child_node_id);
    if (normalized_child_node_id == "") {
      continue;
    }

    let child_node_json = ast.node_to_json(normalized_child_node_id);
    let child_kind = runtime_ui_node_kind(child_node_json);

    if (child_kind == "formField" || child_kind == "formInlineControlField") {
      let identifier_node_id = runtime_ui_find_child_node_id_by_kind(
        normalized_child_node_id,
        "identifier"
      );
      if (runtime_ui_direct_node_symbol_name(ast.node_to_json(identifier_node_id)) == "ui") {
        analysis["has_ui_field"] = true;
        let control_structure = runtime_ui_analyze_control_structure(child_node_json);
        let control_type_analysis = runtime_ui_resolve_control_type_analysis(
          Runtime.json_to_str(control_structure["type_expression_node_id"])
        );
        let control_type_symbol = Runtime.json_to_str(
          control_type_analysis["control_type_symbol"]
        );
        if (Runtime.json_to_str(analysis["ui_from"]) == "") {
          let field_from_node_id = runtime_ui_find_child_node_id_by_kind(
            normalized_child_node_id,
            "formFieldFrom"
          );
          let ui_from = runtime_ui_find_first_descendant_symbol_name(field_from_node_id);
          if (
            ui_from != ""
            && control_type_symbol != "DataGrid"
            && control_type_symbol != "Grid"
          ) {
            analysis["ui_from"] = ui_from;
          }
        }
        if (Runtime.json_to_str(analysis["load_handler"]) == "") {
          let ui_load_handler = runtime_ui_find_form_field_property_handler(
            normalized_child_node_id,
            [
              "load"
            ]
          );
          if (ui_load_handler == "") {
            ui_load_handler = runtime_ui_find_direct_form_field_property_handler_by_key(
              normalized_child_node_id,
              "load"
            );
          }
          if (
            ui_load_handler != ""
            && control_type_symbol != "DataGrid"
            && control_type_symbol != "Grid"
          ) {
            analysis["has_load_property"] = true;
            analysis["load_handler"] = ui_load_handler;
          }
        }
      }
    } else if (
      child_kind == "formHeaderProperty"
      || child_kind == "formInlineHeaderProperty"
    ) {
      let child_symbol_names = runtime_ui_collect_descendant_symbol_names(
        normalized_child_node_id
      );
      if (runtime_ui_symbol_list_contains(child_symbol_names, "load")) {
        analysis["has_load_property"] = true;
      }
    } else if (
      child_kind == "formDeclarationWithHeader"
      || child_kind == "formDeclarationWithoutHeader"
      || child_kind == "formInlineBodyItem"
      || child_kind == "formBody"
      || child_kind == "formBodyMember"
      || child_kind == "formBodySection"
      || child_kind == "formSection"
    ) {
      let child_analysis = runtime_ui_analyze_direct_form_structure(child_node_json);
      if (child_analysis["has_ui_field"] == true) {
        analysis["has_ui_field"] = true;
      }
      if (Runtime.json_to_str(analysis["ui_from"]) == "") {
        analysis["ui_from"] = child_analysis["ui_from"];
      }
      if (child_analysis["has_load_property"] == true) {
        analysis["has_load_property"] = true;
      }
      if (Runtime.json_to_str(analysis["load_handler"]) == "") {
        analysis["load_handler"] = Runtime.json_to_str(child_analysis["load_handler"]);
      }
    }

    if (
      analysis["has_load_property"] == true
      && analysis["has_ui_field"] == true
      && Runtime.json_to_str(analysis["ui_from"]) != ""
    ) {
      break;
    }
  }

  return analysis;
}

private function runtime_ui_analyze_property_node(property_node_id: string): Json {
  let normalized_property_node_id = Runtime.json_to_str(property_node_id);
  let analysis: Json = {
    "literal_text": "",
    "symbol_names": []
  };
  let symbol_count = 0;
  if (normalized_property_node_id == "") {
    return analysis;
  }

  let property_node_json = ast.node_to_json(normalized_property_node_id);
  let property_node_kind = runtime_ui_node_kind(property_node_json);
  let literal_text = Runtime.json_to_str(
    runtime_ui_property_value(property_node_json, "literal_text")
  );
  if (literal_text != "") {
    analysis["literal_text"] = literal_text;
  }

  let symbol_name = runtime_ui_direct_node_symbol_name(property_node_json);
  if (symbol_name != "") {
    analysis["symbol_names"][symbol_count] = symbol_name;
    symbol_count = symbol_count + 1;
  }

  if (property_node_kind == "onPropertyKey") {
    let on_property_suffix = "";
    let on_property_child_ids = runtime_ui_list_child_node_ids(normalized_property_node_id);
    let on_property_child_count = 0;
    for (_ in on_property_child_ids ?? []) {
      on_property_child_count = on_property_child_count + 1;
    }
    let on_property_child_index = on_property_child_count - 1;
    while (on_property_child_index >= 0) {
      let on_property_child_id = Runtime.json_to_str(
        on_property_child_ids[on_property_child_index]
      );
      let on_property_child_symbol = runtime_ui_direct_node_symbol_name(
        ast.node_to_json(on_property_child_id)
      );
      if (on_property_child_symbol != "") {
        on_property_suffix = on_property_suffix != ""
          ? on_property_suffix + "_" + on_property_child_symbol
          : on_property_child_symbol;
      }
      on_property_child_index = on_property_child_index - 1;
    }
    if (on_property_suffix != "") {
      analysis["symbol_names"][symbol_count] = "on_" + on_property_suffix;
      symbol_count = symbol_count + 1;
    }
  }

  for (child_node_id in runtime_ui_list_child_node_ids(normalized_property_node_id)) {
    let child_analysis = runtime_ui_analyze_property_node(Runtime.json_to_str(child_node_id));
    if (Runtime.json_to_str(analysis["literal_text"]) == "") {
      let child_literal_text = Runtime.json_to_str(child_analysis["literal_text"]);
      if (child_literal_text != "") {
        analysis["literal_text"] = child_literal_text;
      }
    }
    for (child_symbol_name in child_analysis["symbol_names"] ?? []) {
      analysis["symbol_names"][symbol_count] = child_symbol_name;
      symbol_count = symbol_count + 1;
    }
  }

  return analysis;
}

private function runtime_ui_collect_form_header_property_analysis(form_node_json: Json): Json {
  let analysis: Json = {
    "text_properties": {},
    "symbol_properties": {}
  };
  if (form_node_json == null) {
    return analysis;
  }

  let form_node_id = runtime_ui_resolve_ast_node_id(form_node_json);
  if (form_node_id == "") {
    return analysis;
  }

  let property_node_kinds: Json = [
    "formHeaderProperty",
    "formInlineHeaderProperty"
  ];
  let text_property_names: Json = [
    "title",
    "description",
    "icon",
    "technical",
    "load_param"
  ];
  let symbol_property_names: Json = [
    "load"
  ];

  let property_node_analyses: Json = [];
  let property_analysis_count = 0;
  for (child_node_id in runtime_ui_list_child_node_ids(form_node_id)) {
    let normalized_child_node_id = Runtime.json_to_str(child_node_id);
    if (normalized_child_node_id == "") {
      continue;
    }

    let child_node_json = ast.node_to_json(normalized_child_node_id);
    let child_kind = runtime_ui_node_kind(child_node_json);
    if (!runtime_ui_symbol_list_contains(property_node_kinds, child_kind)) {
      if (child_kind == "formHeader") {
        for (header_child_node_id in runtime_ui_list_child_node_ids(normalized_child_node_id)) {
          let normalized_header_child_node_id = Runtime.json_to_str(header_child_node_id);
          if (normalized_header_child_node_id == "") {
            continue;
          }
          let header_child_node_json = ast.node_to_json(normalized_header_child_node_id);
          let header_child_kind = runtime_ui_node_kind(header_child_node_json);
          if (!runtime_ui_symbol_list_contains(property_node_kinds, header_child_kind)) {
            continue;
          }
          property_node_analyses[property_analysis_count] = runtime_ui_analyze_property_node(
            normalized_header_child_node_id
          );
          property_analysis_count = property_analysis_count + 1;
        }
      }
      continue;
    }

    property_node_analyses[property_analysis_count] = runtime_ui_analyze_property_node(
      normalized_child_node_id
    );
    property_analysis_count = property_analysis_count + 1;
  }

  for (property_node_analysis in property_node_analyses ?? []) {
    let property_node_id = Runtime.json_to_str(property_node_analysis["node_id"]);
    runtime_ui_assign_text_properties_from_property_analysis(
      analysis["text_properties"],
      property_node_analysis,
      text_property_names
    );

    for (symbol_property_name in symbol_property_names) {
      let normalized_symbol_property_name = Runtime.json_to_str(symbol_property_name);
      if (
        normalized_symbol_property_name == ""
        || Runtime.json_to_str(analysis["symbol_properties"][normalized_symbol_property_name]) != ""
      ) {
        continue;
      }

      let property_symbol_target = runtime_ui_resolve_symbol_property_target_from_analysis(
        property_node_analysis,
        normalized_symbol_property_name
      );
      if (property_symbol_target != "") {
        analysis["symbol_properties"][normalized_symbol_property_name] = property_symbol_target;
      }
    }
  }

  for (symbol_property_name in symbol_property_names) {
    let normalized_symbol_property_name = Runtime.json_to_str(symbol_property_name);
    if (
      normalized_symbol_property_name == ""
      || Runtime.json_to_str(analysis["symbol_properties"][normalized_symbol_property_name]) != ""
    ) {
      continue;
    }

    let reflected_symbol_target = runtime_ui_find_form_header_symbol_property(
      form_node_json,
      normalized_symbol_property_name
    );
    if (reflected_symbol_target != "") {
      analysis["symbol_properties"][normalized_symbol_property_name] = reflected_symbol_target;
    }
  }

  return analysis;
}

private function runtime_ui_assign_text_properties_from_property_analysis(
  target_properties: Json,
  property_node_analysis: Json,
  property_names: Json
): Json {
  let property_symbol_names = property_node_analysis["symbol_names"] ?? [];
  let property_literal_text = Runtime.json_to_str(property_node_analysis["literal_text"]);
  for (property_name in property_names ?? []) {
    let normalized_property_name = Runtime.json_to_str(property_name);
    if (
      normalized_property_name != ""
      && Runtime.json_to_str(target_properties[normalized_property_name]) == ""
      && property_literal_text != ""
      && runtime_ui_symbol_list_contains(property_symbol_names, normalized_property_name)
    ) {
      target_properties[normalized_property_name] = property_literal_text;
    }
  }

  return target_properties;
}

private function runtime_ui_resolve_published_string_property_with_reflected_text(
  node_json: Json,
  property_name: string,
  reflected_text_properties: Json
): string {
  let normalized_property_name = Runtime.json_to_str(property_name);
  if (normalized_property_name == "") {
    return "";
  }

  let resolved_value = Runtime.json_to_str(
    runtime_ui_published_property_value(node_json, normalized_property_name)
  );
  if (resolved_value == "") {
    resolved_value = Runtime.json_to_str(reflected_text_properties[normalized_property_name]);
  }

  return resolved_value;
}

private function runtime_ui_build_form_metadata_core(
  form_node_json: Json,
  include_runtime_details: bool
): Json {
  form_node_json = runtime_ui_resolve_canonical_declaration_node(form_node_json);
  let form_analysis_node_json = runtime_ui_resolve_form_analysis_node(form_node_json);
  let form_id = runtime_ui_resolve_declaration_primary_symbol_name(form_node_json);
  let direct_form_structure = runtime_ui_analyze_direct_form_structure(form_analysis_node_json);
  let form_header_property_analysis = runtime_ui_collect_form_header_property_analysis(
    form_analysis_node_json
  );
  let form_text_properties = form_header_property_analysis["text_properties"] ?? {};
  let form_title = runtime_ui_resolve_published_string_property_with_reflected_text(
    form_node_json,
    "title",
    form_text_properties
  );
  if (form_title == "" || form_title == form_id) {
    let declared_form_title = runtime_ui_find_declaration_text_property(
      form_node_json,
      "title"
    );
    if (declared_form_title != "") {
      form_title = declared_form_title;
    }
  }
  let form_description = runtime_ui_resolve_published_string_property_with_reflected_text(
    form_node_json,
    "description",
    form_text_properties
  );
  let form_icon = runtime_ui_resolve_published_string_property_with_reflected_text(
    form_node_json,
    "icon",
    form_text_properties
  );
  let form_technical = runtime_ui_resolve_published_string_property_with_reflected_text(
    form_node_json,
    "technical",
    form_text_properties
  );
  let canonical_form_node_id = runtime_ui_resolve_ast_node_id(form_node_json);
  let form_node_id = runtime_ui_resolve_ast_node_id(form_analysis_node_json);
  let published_state_fields = runtime_ui_published_property_value(form_analysis_node_json, "state_fields");
  let state_fields = published_state_fields;
  let published_body = runtime_ui_published_property_value(form_analysis_node_json, "body");
  let published_controls = published_body != null ? published_body["controls"] : null;
  let controls = published_controls;
  let published_buttons = runtime_ui_published_property_value(form_analysis_node_json, "buttons");
  let buttons = published_buttons;
  let reflected_shorthand_ui_from = "";
  if (include_runtime_details) {
    let direct_form_metadata_nodes = runtime_ui_collect_form_metadata_nodes(form_node_id);
    let direct_form_structure = runtime_ui_analyze_direct_form_structure(form_analysis_node_json);
    let direct_form_binding_type = Runtime.json_to_str(direct_form_structure["ui_from"]);
    let base_state_fields = runtime_ui_build_state_fields_from_nodes(
      direct_form_metadata_nodes["state_nodes"]
    );
    state_fields = published_state_fields != null
      ? runtime_ui_merge_state_field_metadata_entries(base_state_fields, published_state_fields)
      : base_state_fields;
    let base_controls = runtime_ui_build_controls_from_nodes(
      direct_form_metadata_nodes["control_nodes"],
      state_fields
    );
    controls = published_controls != null
      ? runtime_ui_merge_control_metadata_entries(base_controls, published_controls)
      : base_controls;
    controls = runtime_ui_complete_controls_runtime_metadata(controls, state_fields);
    let base_buttons = runtime_ui_build_buttons_from_nodes(
      direct_form_metadata_nodes["button_nodes"],
      state_fields,
      direct_form_binding_type,
      runtime_ui_resolve_default_selection_field_name(
        direct_form_metadata_nodes["control_nodes"],
        state_fields
      )
    );
    buttons = published_buttons != null
      ? runtime_ui_merge_button_metadata_entries(base_buttons, published_buttons)
      : base_buttons;
    reflected_shorthand_ui_from = runtime_ui_resolve_shorthand_ui_from_from_control_nodes(
      direct_form_metadata_nodes["control_nodes"]
    );
  }
  let ui_from = runtime_ui_published_property_value(form_analysis_node_json, "ui_from");
  if (
    include_runtime_details
    && Runtime.json_to_str(ui_from) == ""
    && reflected_shorthand_ui_from != ""
  ) {
    ui_from = reflected_shorthand_ui_from;
  }
  if (
    include_runtime_details
    && Runtime.json_to_str(ui_from) == ""
    && direct_form_structure["has_ui_field"] == true
  ) {
    ui_from = direct_form_structure["ui_from"];
  }
  let load_handler = runtime_ui_published_property_value(form_analysis_node_json, "load");
  let reflected_load_handler = "";
  if (include_runtime_details) {
    if (direct_form_structure["has_load_property"] == true) {
      reflected_load_handler = Runtime.json_to_str(direct_form_structure["load_handler"]);
    }
    if (reflected_load_handler == "") {
      reflected_load_handler = runtime_ui_find_form_header_symbol_property(
        form_node_json,
        "load"
      );
    }
    if (reflected_load_handler == "") {
      reflected_load_handler = Runtime.json_to_str(
        form_header_property_analysis["symbol_properties"]["load"]
      );
    }
  }
  let load_handler_name = Runtime.json_to_str(load_handler);
  if (load_handler_name != "") {
    load_handler = {
      "handler": load_handler_name
    };
  } else if (load_handler != null && load_handler["handler"] == null && load_handler["dispatch_target"] == null) {
    load_handler = null;
  }
  if (include_runtime_details && reflected_load_handler != "") {
    load_handler = runtime_ui_merge_flat_json_object(
      load_handler,
      {
        "handler": reflected_load_handler
      }
    );
  }
  let reflected_load_return_binding_type = "";
  if (
    include_runtime_details
    && load_handler != null
    && Runtime.json_to_str(load_handler["handler"]) != ""
  ) {
    reflected_load_return_binding_type = runtime_ui_find_handler_return_reference_symbol_name(
      Runtime.json_to_str(load_handler["handler"])
    );
    let reflected_load_return_binding_kind = runtime_ui_resolve_binding_declaration_kind(
      reflected_load_return_binding_type
    );
    if (
      Runtime.json_to_str(ui_from) == ""
      && reflected_load_return_binding_kind != ""
    ) {
      ui_from = reflected_load_return_binding_type;
    }
  }
  let load_param = runtime_ui_published_property_value(form_analysis_node_json, "load_param");
  if (include_runtime_details && Runtime.json_to_str(load_param) == "") {
    let reflected_load_param = Runtime.json_to_str(form_text_properties["load_param"]);
    if (reflected_load_param != "") {
      load_param = reflected_load_param;
    }
  }
  let binding_kind = runtime_ui_published_property_value(form_analysis_node_json, "binding_kind");
  let binding_members = runtime_ui_published_property_value(form_analysis_node_json, "binding_members");
  let binding_key_fields = runtime_ui_published_property_value(form_analysis_node_json, "binding_key_fields");
  let recovered_binding_type = "";
  if (include_runtime_details && Runtime.json_to_str(ui_from) != "") {
    if (Runtime.json_to_str(binding_kind) == "") {
      let reflected_binding_kind = runtime_ui_resolve_binding_declaration_kind(
        Runtime.json_to_str(ui_from)
      );
      binding_kind = reflected_binding_kind;
    }
    if (!runtime_ui_has_any_items(binding_members)) {
      let reflected_binding_members = runtime_ui_build_binding_members_for_type(
        Runtime.json_to_str(ui_from)
      );
      binding_members = reflected_binding_members;
    }
    if (!runtime_ui_has_any_items(binding_key_fields)) {
      binding_key_fields = runtime_ui_build_binding_key_fields_from_members(binding_members);
    }
    if (!runtime_ui_has_any_controls(controls)) {
      controls = runtime_ui_build_form_controls_from_binding_members(binding_members);
    }
  }
  let reflected_load_return_binding_kind = runtime_ui_resolve_binding_declaration_kind(
    reflected_load_return_binding_type
  );
  let should_repair_binding_from_load_return =
    include_runtime_details
    && reflected_load_return_binding_type != ""
    && reflected_load_return_binding_kind != ""
    && (
      Runtime.json_to_str(ui_from) == ""
      || Runtime.json_to_str(binding_kind) == ""
      || !runtime_ui_has_any_items(binding_members)
      || !runtime_ui_has_any_items(binding_key_fields)
      || !runtime_ui_has_any_controls(controls)
    );
  if (should_repair_binding_from_load_return) {
    ui_from = reflected_load_return_binding_type;
    if (Runtime.json_to_str(binding_kind) == "") {
      binding_kind = reflected_load_return_binding_kind;
    }
    if (!runtime_ui_has_any_items(binding_members)) {
      binding_members = runtime_ui_build_binding_members_for_type(
        reflected_load_return_binding_type
      );
    }
    if (!runtime_ui_has_any_items(binding_key_fields)) {
      binding_key_fields = runtime_ui_build_binding_key_fields_from_members(binding_members);
    }
    if (!runtime_ui_has_any_controls(controls)) {
      controls = runtime_ui_build_form_controls_from_binding_members(binding_members);
    }
  }
  if (include_runtime_details && !runtime_ui_has_any_controls(controls)) {
    recovered_binding_type = Runtime.json_to_str(ui_from);
    if (recovered_binding_type == "") {
      recovered_binding_type = Runtime.json_to_str(direct_form_structure["ui_from"]);
    }
    if (recovered_binding_type == "" && reflected_shorthand_ui_from != "") {
      recovered_binding_type = reflected_shorthand_ui_from;
    }
    if (
      recovered_binding_type == ""
      && load_handler != null
      && Runtime.json_to_str(load_handler["handler"]) != ""
    ) {
      recovered_binding_type = runtime_ui_find_handler_return_reference_symbol_name(
        Runtime.json_to_str(load_handler["handler"])
      );
    }
    if (recovered_binding_type != "") {
      if (Runtime.json_to_str(ui_from) == "") {
        ui_from = recovered_binding_type;
      }
      if (Runtime.json_to_str(binding_kind) == "") {
        let reflected_binding_kind = runtime_ui_resolve_binding_declaration_kind(
          recovered_binding_type
        );
        binding_kind = reflected_binding_kind;
      }
      if (!runtime_ui_has_any_items(binding_members)) {
        let reflected_binding_members = runtime_ui_build_binding_members_for_type(
          recovered_binding_type
        );
        binding_members = reflected_binding_members;
      }
      if (!runtime_ui_has_any_items(binding_key_fields)) {
        let reflected_binding_key_fields = runtime_ui_build_binding_key_fields_from_members(
          binding_members
        );
        binding_key_fields = reflected_binding_key_fields;
      }
      if (!runtime_ui_has_any_controls(controls)) {
        let reflected_controls = runtime_ui_build_form_controls_from_binding_members(
          binding_members
        );
        controls = reflected_controls;
      }
    }
  }
  let inferred_load_param = "";
  if (
    Runtime.json_to_str(load_param) == ""
    && load_handler != null
    && Runtime.json_to_str(load_handler["handler"]) != ""
  ) {
    inferred_load_param = runtime_ui_find_handler_first_parameter_name(
      Runtime.json_to_str(load_handler["handler"])
    );
    if (inferred_load_param != "") {
      load_param = inferred_load_param;
    }
  }
  if (
    load_handler != null
    && binding_key_fields != null
    && binding_key_fields[0] != null
    && Runtime.json_to_str(binding_key_fields[0]) != ""
  ) {
    let binding_key_field = Runtime.json_to_str(binding_key_fields[0]);
    if (
      Runtime.json_to_str(load_param) == ""
      || (
        inferred_load_param != ""
        && Runtime.json_to_str(load_param) == inferred_load_param
        && binding_key_field != inferred_load_param
      )
    ) {
      load_param = binding_key_fields[0];
    }
  }
  let form_metadata: Json = {
    "form_id": form_id,
    "id": form_id,
    "title": form_title != "" ? form_title : form_id,
    "description": form_description != "" ? form_description : null,
    "icon": form_icon != "" ? form_icon : null,
    "technical": form_technical != "" ? form_technical : form_id,
    "form_technical_name": form_technical != "" ? form_technical : null,
    "startup_form_id": runtime_ui_published_property_value(form_node_json, "startup_form_id"),
    "readonly": runtime_ui_form_has_direct_modifier(canonical_form_node_id, "formModifier")
      || runtime_ui_form_has_direct_modifier(form_node_id, "formModifier")
      || runtime_ui_resolve_metadata_bool_flag(form_node_json, "readonly"),
    "load": load_handler,
    "load_param": load_param,
    "ui_from": ui_from,
    "binding_kind": binding_kind,
    "binding_members": binding_members,
    "binding_key_fields": binding_key_fields,
    "binding_blueprint": runtime_ui_build_form_binding_blueprint_metadata(
      Runtime.json_to_str(ui_from),
      Runtime.json_to_str(binding_kind),
      binding_members,
      state_fields
    ),
    "state_fields": state_fields,
    "form_body": runtime_ui_build_form_body_metadata(controls),
    "buttons": buttons,
    "_form_header_property_analysis": form_header_property_analysis,
    "source_path": runtime_ui_node_source_path(form_node_json),
    "debug": runtime_ui_build_node_debug_descriptor(form_node_json)
  };

  return form_metadata;
}

private function runtime_ui_build_public_form_metadata(form_metadata: Json): Json {
  if (form_metadata == null) {
    return null;
  }

  return {
    "form_id": form_metadata["form_id"],
    "id": form_metadata["id"],
    "title": form_metadata["title"],
    "description": form_metadata["description"],
    "icon": form_metadata["icon"],
    "technical": form_metadata["technical"],
    "form_technical_name": form_metadata["form_technical_name"],
    "startup_form_id": form_metadata["startup_form_id"],
    "readonly": form_metadata["readonly"],
    "load": form_metadata["load"],
    "load_param": form_metadata["load_param"],
    "binding_key_fields": form_metadata["binding_key_fields"],
    "ui_from": form_metadata["ui_from"],
    "controls": runtime_ui_form_controls(form_metadata),
    "state_fields": form_metadata["state_fields"],
    "body": form_metadata["form_body"] ?? form_metadata["body"],
    "buttons": form_metadata["buttons"],
    "source_path": form_metadata["source_path"],
    "debug": form_metadata["debug"]
  };
}

private function runtime_ui_build_master_grid_column_info(column_metadata: Json): Json {
  if (column_metadata == null) {
    return null;
  }

  let value_name = Runtime.json_to_str(column_metadata["field"]);
  if (value_name == "") {
    value_name = Runtime.json_to_str(column_metadata["key"]);
  }
  if (value_name == "") {
    value_name = Runtime.json_to_str(column_metadata["name"]);
  }

  let column_info: Json = {
    "id": column_metadata["id"],
    "label": column_metadata["label"],
    "value": value_name
  };
  if (column_metadata["max_length"] != null) {
    column_info["max_length"] = column_metadata["max_length"];
  }
  if (column_metadata["display_length"] != null) {
    column_info["display_length"] = column_metadata["display_length"];
  }
  if (column_metadata["input_width"] != null) {
    column_info["input_width"] = column_metadata["input_width"];
  }
  return column_info;
}

private function runtime_ui_build_master_grid_columns(columns_metadata: Json): Json {
  let master_columns: Json = [];
  let master_column_count = 0;

  for (column_metadata in columns_metadata ?? []) {
    let master_column_info = runtime_ui_build_master_grid_column_info(column_metadata);
    if (master_column_info == null) {
      continue;
    }
    master_columns[master_column_count] = master_column_info;
    master_column_count = master_column_count + 1;
  }

  return master_columns;
}

private function runtime_ui_build_master_field_info(control_metadata: Json): Json {
  if (control_metadata == null) {
    return null;
  }

  let control_type = Runtime.json_to_str(control_metadata["type"]);
  if (control_type == "DataGrid" || control_type == "Grid") {
    return null;
  }

  let field_type = control_metadata["value_type"];
  if (field_type == null) {
    field_type = control_metadata["type"];
  }

  let field_info: Json = {
    "id": control_metadata["id"],
    "kind": "field",
    "field_type": field_type,
    "label": control_metadata["label"],
    "bind": control_metadata["binding_path"]
  };
  if (control_metadata["max_length"] != null) {
    field_info["max_length"] = control_metadata["max_length"];
  }
  if (control_metadata["display_length"] != null) {
    field_info["display_length"] = control_metadata["display_length"];
  }
  if (control_metadata["input_width"] != null) {
    field_info["input_width"] = control_metadata["input_width"];
  }
  return field_info;
}

private function runtime_ui_build_master_fields(form_metadata: Json): Json {
  let master_fields: Json = [];
  let master_field_count = 0;

  for (control_metadata in runtime_ui_form_controls(form_metadata)) {
    let master_field_info = runtime_ui_build_master_field_info(control_metadata);
    if (master_field_info == null) {
      continue;
    }
    master_fields[master_field_count] = master_field_info;
    master_field_count = master_field_count + 1;
  }

  return master_fields;
}

private function runtime_ui_build_master_controls(form_metadata: Json): Json {
  let master_fields: Json = [];
  let master_field_count = 0;
  let master_datagrids: Json = [];
  let master_datagrid_count = 0;

  for (control_metadata in runtime_ui_form_controls(form_metadata)) {
    let master_field_info = runtime_ui_build_master_field_info(control_metadata);
    if (master_field_info != null) {
      master_fields[master_field_count] = master_field_info;
      master_field_count = master_field_count + 1;
      continue;
    }

    let master_datagrid_info = runtime_ui_build_master_datagrid_info(
      control_metadata,
      form_metadata["state_fields"]
    );
    if (master_datagrid_info != null) {
      master_datagrids[master_datagrid_count] = master_datagrid_info;
      master_datagrid_count = master_datagrid_count + 1;
    }
  }

  return {
    "fields": master_fields,
    "datagrids": master_datagrids
  };
}

private function runtime_ui_build_master_datagrid_info(
  control_metadata: Json,
  state_fields: Json
): Json {
  if (control_metadata == null) {
    return null;
  }

  let control_type = Runtime.json_to_str(control_metadata["type"]);
  if (control_type != "DataGrid" && control_type != "Grid") {
    return null;
  }

  let source_metadata = control_metadata["source"];
  let compact_source = null;
  let debug_state_fields_count = 0;
  for (_ in state_fields ?? []) {
    debug_state_fields_count = debug_state_fields_count + 1;
  }
  let debug_control_id = Runtime.json_to_str(control_metadata["id"]);
  let debug_normalized_control_id = runtime_ui_normalize_identifier_text(debug_control_id);
  let debug_normalized_control_base = runtime_ui_trim_grid_suffix(debug_normalized_control_id);
  let debug_pagination_field_name = "";
  let preferred_pagination_field_name = "";
  let on_select_form = runtime_ui_property_value(control_metadata, "on_select_form");
  let on_double_click_form = runtime_ui_property_value(control_metadata, "on_double_click_form");
  if (on_select_form == null) {
    let declared_select_form = runtime_ui_find_declaration_text_property(control_metadata, "on_select_form");
    if (declared_select_form != "") {
      on_select_form = declared_select_form;
    }
  }
  if (on_double_click_form == null) {
    let declared_double_click_form = runtime_ui_find_declaration_text_property(control_metadata, "on_double_click_form");
    if (declared_double_click_form != "") {
      on_double_click_form = declared_double_click_form;
    }
  }
  let events_metadata = control_metadata["events"];
  if (on_select_form == null) {
    let select_event = events_metadata["select"];
    let select_navigate = select_event["navigate"];
    if (select_navigate != null) {
      on_select_form = select_navigate["target_form_id"];
    }
  }
  if (on_double_click_form == null) {
    let row_double_click_event = events_metadata["row_double_click"];
    let row_double_click_navigate = row_double_click_event["navigate"];
    if (row_double_click_navigate != null) {
      on_double_click_form = row_double_click_navigate["target_form_id"];
    }
  }
  if (source_metadata != null) {
    compact_source = {
      "type": source_metadata["kind"],
      "name": source_metadata["name"],
    };
  }

  let effective_pagination_path = control_metadata["pagination_path"];
  let properties = control_metadata["properties"] ?? {};
  if (runtime_ui_control_has_source_metadata(control_metadata)) {
    preferred_pagination_field_name = runtime_ui_find_matching_pagination_state_field_name(
      state_fields,
      Runtime.json_to_str(control_metadata["id"])
    );
    debug_pagination_field_name = preferred_pagination_field_name;
    if (
      preferred_pagination_field_name != ""
      && (
        effective_pagination_path == null
        || Runtime.json_to_str(effective_pagination_path) == ""
        || (
          Runtime.json_to_str(effective_pagination_path) == "state.limiter"
          && preferred_pagination_field_name != "limiter"
        )
      )
    ) {
      effective_pagination_path = "state." + preferred_pagination_field_name;
    }
  }
  if (effective_pagination_path != null) {
  }

  let master_datagrid: Json = {
    "id": control_metadata["id"],
    "kind": "datagrid",
    "label": control_metadata["label"],
    "columns": runtime_ui_build_master_grid_columns(control_metadata["columns"]),
    "source": compact_source
  };

  if (control_metadata["selection_path"] != null) {
    master_datagrid["selection_path"] = control_metadata["selection_path"];
  }
  if (control_metadata["height_lines"] != null) {
    master_datagrid["height_lines"] = control_metadata["height_lines"];
  }
  if (effective_pagination_path != null) {
    master_datagrid["pagination_path"] = effective_pagination_path;
  }
  if (properties["filter_mode"] != null) {
    master_datagrid["filter_mode"] = properties["filter_mode"];
  }
  if (properties["server_side_filtering"] != null) {
    master_datagrid["server_side_filtering"] = properties["server_side_filtering"];
  }
  if (on_select_form != null) {
    master_datagrid["on_select_form"] = on_select_form;
  }
  if (on_double_click_form != null) {
    master_datagrid["on_double_click_form"] = on_double_click_form;
  }
  master_datagrid["_debug_state_fields_count"] = debug_state_fields_count;
  master_datagrid["_debug_control_id"] = debug_control_id;
  master_datagrid["_debug_normalized_control_id"] = debug_normalized_control_id;
  master_datagrid["_debug_normalized_control_base"] = debug_normalized_control_base;
  master_datagrid["_debug_pagination_field_name"] = debug_pagination_field_name;
  master_datagrid["_debug_state_fields"] = state_fields;
  master_datagrid["_debug_effective_pagination_path"] = effective_pagination_path;

  return master_datagrid;
}

private function runtime_ui_build_master_datagrids(form_metadata: Json): Json {
  let master_datagrids: Json = [];
  let master_datagrid_count = 0;

  for (control_metadata in runtime_ui_form_controls(form_metadata)) {
    let master_datagrid_info = runtime_ui_build_master_datagrid_info(
      control_metadata,
      form_metadata["state_fields"]
    );
    if (master_datagrid_info == null) {
      continue;
    }
    master_datagrids[master_datagrid_count] = master_datagrid_info;
    master_datagrid_count = master_datagrid_count + 1;
  }

  return master_datagrids;
}

private function runtime_ui_build_master_button_events(events_metadata: Json): Json {
  let master_events: Json = {};
  if (events_metadata == null) {
    return master_events;
  }

  let click_metadata = events_metadata["on_click"];
  if (click_metadata == null) {
    click_metadata = events_metadata["click"];
  }
  if (click_metadata != null) {
    let click_event: Json = {
      "event_name": "click"
    };
    if (click_metadata["handler"] != null) {
      click_event["handler"] = click_metadata["handler"];
    }
    if (click_metadata["dispatch_target"] != null) {
      click_event["dispatch_target"] = click_metadata["dispatch_target"];
    }
    if (click_metadata["form_id"] != null) {
      click_event["form_id"] = click_metadata["form_id"];
    }
    master_events["click"] = click_event;
  }

  return master_events;
}

private function runtime_ui_build_master_button_info(button_metadata: Json): Json {
  if (button_metadata == null) {
    return null;
  }

  let button_info: Json = {
    "id": button_metadata["id"],
    "label": button_metadata["label"],
    "events": runtime_ui_build_master_button_events(button_metadata["events"])
  };

  if (button_metadata["icon"] != null) {
    button_info["icon"] = button_metadata["icon"];
  }
  if (button_metadata["aria_label"] != null) {
    button_info["aria_label"] = button_metadata["aria_label"];
  }
  if (button_metadata["placement"] != null) {
    button_info["placement"] = button_metadata["placement"];
  }
  if (button_metadata["icon_only"] == true) {
    button_info["icon_only"] = true;
  }
  if (button_metadata["requires_selection"] == true) {
    button_info["requires_selection"] = true;
  }
  if (button_metadata["selection_path"] != null) {
    button_info["selection_path"] = button_metadata["selection_path"];
  }
  if (button_metadata["record_path"] != null) {
    button_info["record_path"] = button_metadata["record_path"];
  }
  if (button_metadata["form_arg_expr"] != null) {
    button_info["form_arg_expr"] = button_metadata["form_arg_expr"];
  }

  return button_info;
}

private function runtime_ui_build_master_buttons(form_metadata: Json): Json {
  let master_buttons: Json = [];
  let master_button_count = 0;

  for (button_metadata in form_metadata["buttons"] ?? []) {
    let master_button_info = runtime_ui_build_master_button_info(button_metadata);
    if (master_button_info == null) {
      continue;
    }
    master_buttons[master_button_count] = master_button_info;
    master_button_count = master_button_count + 1;
  }

  return master_buttons;
}

private function runtime_ui_build_master_buttons_and_toolbar(form_metadata: Json): Json {
  let master_buttons: Json = [];
  let master_button_count = 0;
  let toolbar_items: Json = [];
  let toolbar_item_count = 0;

  for (button_metadata in form_metadata["buttons"] ?? []) {
    let master_button_info = runtime_ui_build_master_button_info(button_metadata);
    if (master_button_info != null) {
      master_buttons[master_button_count] = master_button_info;
      master_button_count = master_button_count + 1;
    }

    let placement = Runtime.json_to_str(button_metadata["placement"]);
    if (placement != "" && placement != "toolbar") {
      continue;
    }
    let button_id = Runtime.json_to_str(button_metadata["id"]);
    if (button_id == "") {
      continue;
    }
    toolbar_items[toolbar_item_count] = button_id;
    toolbar_item_count = toolbar_item_count + 1;
  }

  return {
    "buttons": master_buttons,
    "toolbar": {
      "id": Runtime.json_to_str(form_metadata["form_id"]) + ".toolbar",
      "items": toolbar_items
    }
  };
}

private function runtime_ui_build_master_toolbar_info(form_metadata: Json): Json {
  let toolbar_items: Json = [];
  let toolbar_item_count = 0;

  for (button_metadata in form_metadata["buttons"] ?? []) {
    let placement = Runtime.json_to_str(button_metadata["placement"]);
    if (placement != "" && placement != "toolbar") {
      continue;
    }
    let button_id = Runtime.json_to_str(button_metadata["id"]);
    if (button_id == "") {
      continue;
    }
    toolbar_items[toolbar_item_count] = button_id;
    toolbar_item_count = toolbar_item_count + 1;
  }

  return {
    "id": Runtime.json_to_str(form_metadata["form_id"]) + ".toolbar",
    "items": toolbar_items
  };
}

private function runtime_ui_find_binding_blueprint_member(
  blueprint: Json,
  field_name: string
): Json {
  let normalized_field_name = Runtime.json_to_str(field_name);
  if (blueprint == null || normalized_field_name == "") {
    return null;
  }

  return blueprint["form." + normalized_field_name];
}

private function runtime_ui_apply_binding_member_sizing(entry: Json, binding_member: Json): Json {
  if (entry == null || binding_member == null) {
    return entry;
  }

  if (binding_member["max_length"] != null) {
    entry["max_length"] = binding_member["max_length"];
  }
  if (binding_member["display_length"] != null) {
    entry["display_length"] = binding_member["display_length"];
  }
  if (binding_member["input_width"] != null) {
    entry["input_width"] = binding_member["input_width"];
  }

  return entry;
}

private function runtime_ui_apply_master_field_sizing_from_blueprint(
  fields: Json,
  blueprint: Json
): Json {
  for (field_entry in fields ?? []) {
    runtime_ui_apply_binding_member_sizing(
      field_entry,
      runtime_ui_find_binding_blueprint_member(blueprint, field_entry["id"])
    );
  }

  return fields;
}

private function runtime_ui_apply_master_datagrid_sizing_from_blueprint(
  datagrids: Json,
  blueprint: Json
): Json {
  for (datagrid_entry in datagrids ?? []) {
    let columns = datagrid_entry["columns"] ?? [];
    for (column_entry in columns) {
      runtime_ui_apply_binding_member_sizing(
        column_entry,
        runtime_ui_find_binding_blueprint_member(blueprint, column_entry["value"])
      );
    }
  }

  return datagrids;
}

private function runtime_ui_build_master_form_info(form_metadata: Json): Json {
  if (form_metadata == null) {
    return null;
  }

  let master_controls = runtime_ui_build_master_controls(form_metadata);
  let blueprint = form_metadata["binding_blueprint"];
  let fields = runtime_ui_apply_master_field_sizing_from_blueprint(
    master_controls["fields"] ?? [],
    blueprint
  );
  let datagrids = runtime_ui_apply_master_datagrid_sizing_from_blueprint(
    master_controls["datagrids"] ?? [],
    blueprint
  );
  let master_buttons_and_toolbar = runtime_ui_build_master_buttons_and_toolbar(form_metadata);
  let form_kind = "form";
  let toolbars: Json = [];
  toolbars[0] = master_buttons_and_toolbar["toolbar"];
  if (datagrids[0] != null) {
    form_kind = "list";
  }

  return {
    "form_id": form_metadata["form_id"],
    "title": form_metadata["title"],
    "kind": form_kind,
    "readonly": form_metadata["readonly"],
    "load": form_metadata["load"],
    "load_param": form_metadata["load_param"],
    "binding_key_fields": form_metadata["binding_key_fields"],
    "fields": fields,
    "datagrids": datagrids,
    "buttons": master_buttons_and_toolbar["buttons"] ?? [],
    "toolbars": toolbars
  };
}

private function runtime_ui_build_master_forms(forms_metadata: Json): Json {
  let master_forms: Json = [];
  let master_form_count = 0;

  for (form_metadata in forms_metadata ?? []) {
    let master_form_info = runtime_ui_build_master_form_info(form_metadata);
    if (master_form_info == null) {
      continue;
    }
    master_forms[master_form_count] = master_form_info;
    master_form_count = master_form_count + 1;
  }

  return master_forms;
}

private function runtime_ui_build_master_form_metadata(form_node_json: Json): Json {
  let form_metadata = runtime_ui_build_form_metadata_core(form_node_json, true);
  let form_id = Runtime.json_to_str(form_metadata["form_id"]);
  let state_fields = form_metadata["state_fields"];
  if (!runtime_ui_has_any_items(state_fields)) {
    state_fields = runtime_ui_collect_form_state_fields(form_node_json);
  }
  let published_body = runtime_ui_published_property_value(form_node_json, "body");
  let published_controls = published_body != null ? published_body["controls"] : null;
  let published_buttons = runtime_ui_published_property_value(form_node_json, "buttons");
  let base_controls = runtime_ui_form_controls(form_metadata);
  let merged_controls = published_controls != null
    ? runtime_ui_merge_control_metadata_entries(base_controls, published_controls)
    : base_controls;
  merged_controls = runtime_ui_complete_controls_runtime_metadata(
    merged_controls,
    state_fields
  );
  let merged_buttons = published_buttons != null
    ? runtime_ui_merge_button_metadata_entries(form_metadata["buttons"], published_buttons)
    : (form_metadata["buttons"] ?? []);
  let form_title = Runtime.json_to_str(
    runtime_ui_published_property_value(form_node_json, "title")
  );
  if (form_title == "") {
    form_title = runtime_ui_find_declaration_text_property(form_node_json, "title");
  }
  if (
    form_metadata["load"] == null
    || Runtime.json_to_str(form_metadata["load"]["handler"]) == ""
  ) {
    let form_header_property_analysis = form_metadata["_form_header_property_analysis"] ?? {};
    let reflected_load_handler = runtime_ui_find_form_header_symbol_property(
      form_node_json,
      "load"
    );
    if (reflected_load_handler == "") {
      reflected_load_handler = Runtime.json_to_str(
        form_header_property_analysis["symbol_properties"]["load"]
      );
    }
    if (reflected_load_handler != "") {
      form_metadata["load"] = runtime_ui_merge_flat_json_object(
        form_metadata["load"],
        {
          "handler": reflected_load_handler
        }
      );
    }
  }
  if (
    Runtime.json_to_str(form_metadata["load_param"]) == ""
    && form_metadata["load"] != null
    && Runtime.json_to_str(form_metadata["load"]["handler"]) != ""
  ) {
    let inferred_load_param = runtime_ui_find_handler_first_parameter_name(
      Runtime.json_to_str(form_metadata["load"]["handler"])
    );
    if (inferred_load_param != "") {
      form_metadata["load_param"] = inferred_load_param;
    }
  }
  if (
    form_metadata["load"] != null
    && form_metadata["binding_key_fields"] != null
    && form_metadata["binding_key_fields"][0] != null
    && Runtime.json_to_str(form_metadata["binding_key_fields"][0]) != ""
  ) {
    let binding_key_field = Runtime.json_to_str(form_metadata["binding_key_fields"][0]);
    let normalized_load_param = Runtime.json_to_str(form_metadata["load_param"]);
    let inferred_load_param = runtime_ui_find_handler_first_parameter_name(
      Runtime.json_to_str(form_metadata["load"]["handler"])
    );
    if (
      normalized_load_param == ""
      || (
        inferred_load_param != ""
        && normalized_load_param == inferred_load_param
        && binding_key_field != inferred_load_param
      )
    ) {
      form_metadata["load_param"] = binding_key_field;
    }
  }

  return {
    "form_id": form_id,
    "id": form_id,
    "title": form_title != "" ? form_title : (form_metadata["title"] ?? form_id),
    "readonly": form_metadata["readonly"],
    "load": form_metadata["load"],
    "load_param": form_metadata["load_param"],
    "binding_key_fields": form_metadata["binding_key_fields"],
    "state_fields": state_fields,
    "binding_blueprint": form_metadata["binding_blueprint"],
    "form_body": runtime_ui_build_form_body_metadata(merged_controls),
    "buttons": merged_buttons
  };
}

private function runtime_ui_build_master_forms_from_lookup(form_lookup: Json): Json {
  let master_forms: Json = [];
  let master_form_count = 0;

  for (form_node_json in form_lookup["ordered"] ?? []) {
    let master_form_metadata = runtime_ui_build_master_form_metadata(form_node_json);
    let master_form_info = runtime_ui_build_master_form_info(master_form_metadata);
    if (master_form_info == null) {
      continue;
    }
    master_forms[master_form_count] = master_form_info;
    master_form_count = master_form_count + 1;
  }

  return master_forms;
}

private function runtime_ui_build_master_app_info(app_metadata: Json): Json {
  if (app_metadata == null) {
    return null;
  }

  return {
    "app_id": app_metadata["app_id"],
    "startup_form_id": app_metadata["startup_form_id"],
    "forms": runtime_ui_build_master_forms(app_metadata["forms"])
  };
}

private function runtime_ui_build_master_app_info_from_lookup(
  app_node_json: Json,
  form_lookup: Json
): Json {
  if (app_node_json == null) {
    return null;
  }

  return {
    "app_id": runtime_ui_resolve_app_id(app_node_json),
    "startup_form_id": runtime_ui_find_startup_form_id_with_mounted_targets(
      app_node_json,
      form_lookup["mounted_targets"]
    ),
    "forms": runtime_ui_build_master_forms_from_lookup(form_lookup)
  };
}

private function runtime_ui_build_form_metadata(form_node_json: Json): Json {
  return runtime_ui_build_form_metadata_core(form_node_json, true);
}

private function runtime_ui_build_form_summary(form_node_json: Json): Json {
  let form_metadata = runtime_ui_build_form_metadata_core(form_node_json, false);
  let form_header_property_analysis = form_metadata["_form_header_property_analysis"] ?? {};
  let reflected_load_handler = runtime_ui_find_form_header_symbol_property(
    form_node_json,
    "load"
  );
  if (reflected_load_handler == "") {
    reflected_load_handler = Runtime.json_to_str(
      form_header_property_analysis["symbol_properties"]["load"]
    );
  }
  if (reflected_load_handler != "") {
    form_metadata["load"] = runtime_ui_merge_flat_json_object(
      form_metadata["load"],
      {
        "handler": reflected_load_handler
      }
    );
  }
  if (Runtime.json_to_str(form_metadata["load_param"]) == "") {
    let reflected_load_param = Runtime.json_to_str(
      form_header_property_analysis["text_properties"]["load_param"]
    );
    if (reflected_load_param != "") {
      form_metadata["load_param"] = reflected_load_param;
    }
  }
  if (
    Runtime.json_to_str(form_metadata["load_param"]) == ""
    && form_metadata["load"] != null
    && Runtime.json_to_str(form_metadata["load"]["handler"]) != ""
  ) {
    let inferred_load_param = runtime_ui_find_handler_first_parameter_name(
      Runtime.json_to_str(form_metadata["load"]["handler"])
    );
    if (inferred_load_param != "") {
      form_metadata["load_param"] = inferred_load_param;
    }
  }
  if (
    form_metadata["load"] != null
    && form_metadata["binding_key_fields"] != null
    && form_metadata["binding_key_fields"][0] != null
    && Runtime.json_to_str(form_metadata["binding_key_fields"][0]) != ""
  ) {
    let binding_key_field = Runtime.json_to_str(form_metadata["binding_key_fields"][0]);
    let normalized_load_param = Runtime.json_to_str(form_metadata["load_param"]);
    let inferred_load_param = runtime_ui_find_handler_first_parameter_name(
      Runtime.json_to_str(form_metadata["load"]["handler"])
    );
    if (
      normalized_load_param == ""
      || (
        inferred_load_param != ""
        && normalized_load_param == inferred_load_param
        && binding_key_field != inferred_load_param
      )
    ) {
      form_metadata["load_param"] = binding_key_field;
    }
  }
  return {
    "form_id": form_metadata["form_id"],
    "id": form_metadata["id"],
    "title": form_metadata["title"],
    "description": form_metadata["description"],
    "icon": form_metadata["icon"],
    "technical": form_metadata["technical"],
    "form_technical_name": form_metadata["form_technical_name"],
    "startup_form_id": form_metadata["startup_form_id"],
    "readonly": form_metadata["readonly"],
    "load": form_metadata["load"],
    "load_param": form_metadata["load_param"],
    "source_path": form_metadata["source_path"],
    "debug": form_metadata["debug"]
  };
}

private function runtime_ui_collect_forms_from_lookup_with_builder(
  form_lookup: Json,
  use_detailed_metadata: bool
): Json {
  return runtime_ui_collect_form_nodes_with_builder(
    form_lookup.ordered ?? [],
    use_detailed_metadata
  );
}

private function runtime_ui_resolve_app_form_lookup(app_node_json: Json): Json {
  return runtime_ui_build_form_node_lookup_for_app(app_node_json);
}

private function runtime_ui_collect_forms_for_app_with_builder(
  app_node_json: Json,
  use_detailed_metadata: bool
): Json {
  return runtime_ui_collect_forms_from_lookup_with_builder(
    runtime_ui_resolve_app_form_lookup(app_node_json),
    use_detailed_metadata
  );
}

private function runtime_ui_collect_form_nodes_with_builder(
  form_nodes: Json,
  use_detailed_metadata: bool
): Json {
  let forms: Json = [];
  let form_count = 0;

  for (form_node_json in form_nodes) {
    forms[form_count] = use_detailed_metadata
      ? runtime_ui_build_form_metadata(form_node_json)
      : runtime_ui_build_form_summary(form_node_json);
    form_count = form_count + 1;
  }

  return forms;
}

private function runtime_ui_collect_forms_for_app(app_node_json: Json): Json {
  return runtime_ui_collect_forms_for_app_with_builder(app_node_json, false);
}

private function runtime_ui_form_node_matches_mounted_form_id(
  app_node_json: Json,
  form_node_json: Json
): bool {
  let mounted_form_ids = runtime_ui_published_property_value(app_node_json, "mounted_form_ids") ?? [];
  let form_symbol_name = runtime_ui_resolve_declaration_primary_symbol_name(form_node_json);
  let form_declared_id = Runtime.json_to_str(runtime_ui_published_property_value(form_node_json, "form_id"));

  if (form_symbol_name == "" && form_declared_id == "") {
    return false;
  }

  for (mounted_form_id in mounted_form_ids) {
    let normalized_mounted_form_id = Runtime.json_to_str(mounted_form_id);
    if (normalized_mounted_form_id == "") {
      continue;
    }
    if (
      normalized_mounted_form_id == form_symbol_name
      || normalized_mounted_form_id == form_declared_id
    ) {
      return true;
    }
  }

  return false;
}

private function runtime_ui_form_node_belongs_to_app(app_node_json: Json, form_node_json: Json): bool {
  let source_path = runtime_ui_node_source_path(app_node_json);
  if (runtime_ui_form_node_matches_mounted_form_id(app_node_json, form_node_json)) {
    return true;
  }
  if (source_path == "") {
    return true;
  }

  return runtime_ui_node_source_path(form_node_json) == source_path;
}

private function runtime_ui_analyze_form_mount_node(form_mount_node_id: string): Json {
  let analysis: Json = {
    "mounted_target": "",
    "mounted_alias": ""
  };
  let normalized_form_mount_node_id = Runtime.json_to_str(form_mount_node_id);
  if (normalized_form_mount_node_id == "") {
    return analysis;
  }

  for (form_mount_child_node_id in runtime_ui_list_child_node_ids(normalized_form_mount_node_id)) {
    let form_mount_child_node_json = ast.node_to_json(Runtime.json_to_str(form_mount_child_node_id));
    let form_mount_child_kind = runtime_ui_node_kind(form_mount_child_node_json);
    if (
      form_mount_child_kind != "identifier"
      && form_mount_child_kind != "qualifiedIdentifier"
    ) {
      continue;
    }
    let form_mount_child_symbol = runtime_ui_resolve_node_symbol_name(form_mount_child_node_json);
    if (form_mount_child_symbol == "") {
      continue;
    }
    if (Runtime.json_to_str(analysis["mounted_target"]) == "") {
      analysis["mounted_target"] = form_mount_child_symbol;
      continue;
    }
    if (Runtime.json_to_str(analysis["mounted_alias"]) == "") {
      analysis["mounted_alias"] = form_mount_child_symbol;
      break;
    }
  }

  return analysis;
}

private function runtime_ui_build_mounted_form_target_index_for_app(app_node_json: Json): Json {
  let mounted_targets: Json = {};
  let app_node_id = runtime_ui_resolve_ast_node_id(app_node_json);
  if (app_node_json == null || app_node_id == "") {
    return mounted_targets;
  }

  let form_mount_nodes = runtime_ui_collect_descendant_node_matches_by_kind(
    app_node_id,
    "formMount"
  ) ?? [];
  for (form_mount_match in form_mount_nodes) {
    let form_mount_node_id = runtime_ui_match_node_id(form_mount_match);
    if (form_mount_node_id == "") {
      continue;
    }
    let form_mount_analysis = runtime_ui_analyze_form_mount_node(form_mount_node_id);
    let mounted_target = Runtime.json_to_str(form_mount_analysis["mounted_target"]);
    let mounted_alias = Runtime.json_to_str(form_mount_analysis["mounted_alias"]);
    if (mounted_alias != "" && mounted_target != "") {
      mounted_targets[mounted_alias] = mounted_target;
    }
  }

  return mounted_targets;
}

private function runtime_ui_build_form_node_lookup_for_app(app_node_json: Json): Json {
  let by_id: Json = {};
  let ordered: Json = [];
  let ordered_count = 0;
  let form_nodes = runtime_ui_collect_form_declaration_matches();
  let mounted_targets = runtime_ui_build_mounted_form_target_index_for_app(app_node_json);

  for (form_node_match in form_nodes) {
    let form_node_json = ast.node_to_json(runtime_ui_match_node_id(form_node_match));
    if (!runtime_ui_form_node_belongs_to_app(app_node_json, form_node_json)) {
      continue;
    }
    ordered[ordered_count] = form_node_json;
    ordered_count = ordered_count + 1;

    let form_symbol_name = runtime_ui_resolve_declaration_primary_symbol_name(form_node_json);
    let form_declared_id = Runtime.json_to_str(
      runtime_ui_published_property_value(form_node_json, "form_id")
    );
    if (form_symbol_name != "") {
      by_id[form_symbol_name] = form_node_json;
    }
    if (form_declared_id != "") {
      by_id[form_declared_id] = form_node_json;
    }
  }

  for (mounted_alias in mounted_targets ?? {}) {
    let mounted_target = Runtime.json_to_str(mounted_targets[mounted_alias]);
    if (mounted_target == "") {
      continue;
    }
    let target_form_node_json = by_id[mounted_target];
    if (target_form_node_json != null) {
      by_id[Runtime.json_to_str(mounted_alias)] = target_form_node_json;
    }
  }

  return {
    "ordered": ordered,
    "by_id": by_id,
    "mounted_targets": mounted_targets
  };
}

private function runtime_ui_find_form_node_for_app(app_node_json: Json, form_id: string): Json {
  let form_lookup = runtime_ui_resolve_app_form_lookup(app_node_json);
  return runtime_ui_find_form_node_in_lookup(form_lookup, form_id);
}

private function runtime_ui_find_form_node_in_lookup(form_lookup: Json, form_id: string): Json {
  let normalized_form_id = Runtime.json_to_str(form_id);
  let resolved_form_id = normalized_form_id;
  if (normalized_form_id == "") {
    return null;
  }
  let mounted_form_target = Runtime.json_to_str(form_lookup.mounted_targets[normalized_form_id]);
  if (mounted_form_target != "") {
    resolved_form_id = mounted_form_target;
  }

  return form_lookup.by_id[resolved_form_id];
}

private function runtime_ui_find_detailed_form_metadata_in_lookup(
  form_lookup: Json,
  form_id: string
): Json {
  let form_node_json = runtime_ui_find_form_node_in_lookup(form_lookup, form_id);
  if (form_node_json == null) {
    return null;
  }
  return runtime_ui_build_form_metadata(form_node_json);
}

private function runtime_ui_has_any_items(items: Json): bool {
  for (_ in items ?? []) {
    return true;
  }
  return false;
}

private function runtime_ui_build_lightweight_open_form_metadata(
  form_node_json: Json
): Json {
  if (form_node_json == null) {
    return null;
  }

  let form_metadata = runtime_ui_build_form_metadata_core(form_node_json, true);
  let control_metadata = runtime_ui_form_controls(form_metadata);
  let button_metadata = form_metadata["buttons"] ?? [];
  let state_fields = form_metadata["state_fields"] ?? [];
  let binding_type = Runtime.json_to_str(form_metadata["ui_from"]);
  let has_runtime_surface = runtime_ui_has_any_items(control_metadata)
    || runtime_ui_has_any_items(button_metadata)
    || runtime_ui_has_any_items(state_fields)
    || binding_type != "";

  if (!has_runtime_surface) {
    return null;
  }

  if (
    binding_type != ""
    && (
      Runtime.json_to_str(form_metadata["binding_kind"]) == ""
      || form_metadata["binding_members"] == null
      || form_metadata["binding_key_fields"] == null
    )
  ) {
    return null;
  }

  return form_metadata;
}

private function runtime_ui_build_published_unbound_open_form_metadata(
  form_node_json: Json
): Json {
  if (form_node_json == null) {
    return null;
  }

  form_node_json = runtime_ui_resolve_canonical_declaration_node(form_node_json);
  let form_id = runtime_ui_resolve_declaration_primary_symbol_name(form_node_json);
  let published_body = runtime_ui_published_property_value(form_node_json, "body");
  let published_controls = published_body != null ? published_body["controls"] : null;
  let published_buttons = runtime_ui_published_property_value(form_node_json, "buttons");
  let published_state_fields = runtime_ui_published_property_value(form_node_json, "state_fields");
  let form_title = Runtime.json_to_str(
    runtime_ui_published_property_value(form_node_json, "title")
  );
  if (form_title == "") {
    form_title = runtime_ui_find_declaration_text_property(form_node_json, "title");
  }
  let has_runtime_surface = runtime_ui_has_any_items(published_controls)
    || runtime_ui_has_any_items(published_buttons)
    || runtime_ui_has_any_items(published_state_fields);
  let has_grid_like_control = false;

  for (control_metadata in published_controls ?? []) {
    let control_type = Runtime.json_to_str(control_metadata["type"]);
    if (control_type == "DataGrid" || control_type == "Grid") {
      has_grid_like_control = true;
      break;
    }
  }

  if (!has_runtime_surface) {
    return null;
  }
  if (!has_grid_like_control) {
    return null;
  }

  return {
    "form_id": form_id,
    "id": form_id,
    "title": form_title != "" ? form_title : form_id,
    "state_fields": published_state_fields ?? [],
    "form_body": runtime_ui_build_form_body_metadata(published_controls),
    "buttons": published_buttons ?? []
  };
}

private function runtime_ui_build_minimal_deferred_grid_open_control_metadata(
  control_node_json: Json
): Json {
  let control_structure = runtime_ui_analyze_control_structure(control_node_json);
  let control_id = Runtime.json_to_str(control_structure["control_id"]);
  let type_expression_node_id = Runtime.json_to_str(control_structure["type_expression_node_id"]);
  let control_type_analysis = runtime_ui_resolve_control_type_analysis(type_expression_node_id);
  let control_type_symbol = Runtime.json_to_str(control_type_analysis["control_type_symbol"]);
  let control_type = "";

  if (control_type_symbol == "DataGrid") {
    control_type = "DataGrid";
  } else if (control_type_symbol == "Grid") {
    control_type = "Grid";
  }

  if (control_id == "" || control_type == "") {
    return null;
  }

  return {
    "id": control_id,
    "type": control_type,
    "source": {
      "name": "__deferred_grid_load__",
      "kind": "query"
    }
  };
}

private function runtime_ui_build_minimal_deferred_grid_open_form_metadata(
  form_node_json: Json
): Json {
  if (form_node_json == null) {
    return null;
  }

  form_node_json = runtime_ui_resolve_canonical_declaration_node(form_node_json);
  let form_id = runtime_ui_resolve_declaration_primary_symbol_name(form_node_json);
  let form_title = Runtime.json_to_str(
    runtime_ui_published_property_value(form_node_json, "title")
  );
  if (form_title == "") {
    form_title = runtime_ui_find_declaration_text_property(form_node_json, "title");
  }
  let published_buttons = runtime_ui_published_property_value(form_node_json, "buttons");
  let published_state_fields = runtime_ui_published_property_value(form_node_json, "state_fields");
  let published_body = runtime_ui_published_property_value(form_node_json, "body");
  let published_controls = published_body != null ? published_body["controls"] : null;

  let minimal_controls: Json = [];
  let minimal_control_count = 0;

  for (control_metadata in published_controls ?? []) {
    let control_id = Runtime.json_to_str(control_metadata["id"]);
    let control_type = Runtime.json_to_str(control_metadata["type"]);
    if (control_id == "") {
      return null;
    }
    if (control_type != "DataGrid" && control_type != "Grid") {
      return null;
    }
    minimal_controls[minimal_control_count] = {
      "id": control_id,
      "type": control_type,
      "source": {
        "name": "__deferred_grid_load__",
        "kind": "query"
      }
    };
    minimal_control_count = minimal_control_count + 1;
  }

  if (minimal_control_count == 0) {
    return null;
  }

  return {
    "form_id": form_id,
    "id": form_id,
    "title": form_title != "" ? form_title : form_id,
    "state_fields": published_state_fields ?? [],
    "form_body": runtime_ui_build_form_body_metadata(minimal_controls),
    "buttons": published_buttons ?? []
  };
}

private function runtime_ui_find_open_form_metadata_in_lookup(
  form_lookup: Json,
  form_id: string,
  prefer_lightweight_runtime_metadata: bool
): Json {
  let form_node_json = runtime_ui_find_form_node_in_lookup(form_lookup, form_id);
  if (form_node_json == null) {
    return null;
  }

  if (prefer_lightweight_runtime_metadata) {
    let minimal_deferred_grid_form_metadata = runtime_ui_build_minimal_deferred_grid_open_form_metadata(
      form_node_json
    );
    if (minimal_deferred_grid_form_metadata != null) {
      return minimal_deferred_grid_form_metadata;
    }
    let published_form_metadata = runtime_ui_build_published_unbound_open_form_metadata(
      form_node_json
    );
    if (published_form_metadata != null) {
      return published_form_metadata;
    }
    let lightweight_form_metadata = runtime_ui_build_lightweight_open_form_metadata(
      form_node_json
    );
    if (lightweight_form_metadata != null) {
      return lightweight_form_metadata;
    }
  }

  return runtime_ui_build_form_metadata(form_node_json);
}

private function runtime_ui_find_detailed_form_metadata_for_app(
  app_node_json: Json,
  form_id: string
): Json {
  return runtime_ui_find_detailed_form_metadata_in_lookup(
    runtime_ui_resolve_app_form_lookup(app_node_json),
    form_id
  );
}

private function runtime_ui_resolve_app_mounted_targets(app_node_json: Json): Json {
  return runtime_ui_build_mounted_form_target_index_for_app(app_node_json);
}

private function runtime_ui_find_mounted_form_target_for_app(
  app_node_json: Json,
  mounted_form_id: string
): string {
  return runtime_ui_find_mounted_form_target_in_index(
    runtime_ui_resolve_app_mounted_targets(app_node_json),
    mounted_form_id
  );
}

private function runtime_ui_find_mounted_form_target_in_index(
  mounted_targets: Json,
  mounted_form_id: string
): string {
  let normalized_mounted_form_id = Runtime.json_to_str(mounted_form_id);
  if (normalized_mounted_form_id == "") {
    return "";
  }
  return Runtime.json_to_str(mounted_targets[normalized_mounted_form_id]);
}

private function runtime_ui_find_mounted_form_target_in_app_mounts(
  app_node_json: Json,
  mounted_form_id: string
): string {
  return runtime_ui_find_mounted_form_target_for_app(app_node_json, mounted_form_id);
}

private function runtime_ui_analyze_startup_form_reference(node_id: string): Json {
  let normalized_node_id = Runtime.json_to_str(node_id);
  let analysis: Json = {
    "has_startup_section": false,
    "first_symbol_name": ""
  };
  if (normalized_node_id == "") {
    return analysis;
  }

  let node_json = ast.node_to_json(normalized_node_id);
  if (runtime_ui_node_kind(node_json) == "startupSection") {
    analysis["has_startup_section"] = true;
  }

  let direct_symbol_name = runtime_ui_direct_node_symbol_name(node_json);
  if (direct_symbol_name != "") {
    analysis["first_symbol_name"] = direct_symbol_name;
  }

  for (child_node_id in runtime_ui_list_child_node_ids(normalized_node_id)) {
    let child_analysis = runtime_ui_analyze_startup_form_reference(
      Runtime.json_to_str(child_node_id)
    );
    if (child_analysis["has_startup_section"] == true) {
      analysis["has_startup_section"] = true;
    }
    if (
      Runtime.json_to_str(analysis["first_symbol_name"]) == ""
      && Runtime.json_to_str(child_analysis["first_symbol_name"]) != ""
    ) {
      analysis["first_symbol_name"] = child_analysis["first_symbol_name"];
    }
    if (
      analysis["has_startup_section"] == true
      && Runtime.json_to_str(analysis["first_symbol_name"]) != ""
    ) {
      break;
    }
  }

  return analysis;
}

private function runtime_ui_resolve_mounted_form_target_for_source(
  source_node_json: Json,
  mounted_form_reference: string
): string {
  let source_path = runtime_ui_node_source_path(source_node_json);
  let normalized_mounted_form_reference = Runtime.json_to_str(mounted_form_reference);
  if (source_path == "" || normalized_mounted_form_reference == "") {
    return "";
  }

  let app_nodes = runtime_ui_collect_app_declaration_matches();
  for (app_node_match in app_nodes) {
    let app_node_json = ast.node_to_json(runtime_ui_match_node_id(app_node_match));
    if (runtime_ui_node_source_path(app_node_json) != source_path) {
      continue;
    }
    let mounted_target_form = runtime_ui_find_mounted_form_target_in_app_mounts(
      app_node_json,
      normalized_mounted_form_reference
    );
    if (mounted_target_form != "") {
      return mounted_target_form;
    }
  }

  return "";
}

private function runtime_ui_find_startup_form_id_with_mounted_targets(
  app_node_json: Json,
  mounted_targets: Json
): string {
  if (app_node_json == null) {
    return "";
  }

  let node_id = runtime_ui_resolve_ast_node_id(app_node_json);
  if (node_id == "") {
    return "";
  }

  let child_nodes = ast.list_children(node_id) ?? [];
  for (child_node in child_nodes) {
    let child_node_id = runtime_ui_match_node_id(child_node);
    let startup_form_reference_analysis = runtime_ui_analyze_startup_form_reference(child_node_id);
    if (startup_form_reference_analysis["has_startup_section"] != true) {
      continue;
    }

    let startup_form_id = Runtime.json_to_str(
      startup_form_reference_analysis["first_symbol_name"]
    );
    if (startup_form_id != "") {
      return runtime_ui_resolve_startup_form_id_against_mounted_targets(
        mounted_targets,
        startup_form_id
      );
    }
  }

  return runtime_ui_resolve_direct_startup_form_id_with_mounted_targets(
    app_node_json,
    mounted_targets
  );
}

private function runtime_ui_resolve_startup_form_id_against_mounted_targets(
  mounted_targets: Json,
  startup_form_id: string
): string {
  let normalized_startup_form_id = Runtime.json_to_str(startup_form_id);
  if (normalized_startup_form_id == "") {
    return "";
  }

  let mounted_startup_form_id = runtime_ui_find_mounted_form_target_in_index(
    mounted_targets,
    normalized_startup_form_id
  );
  if (mounted_startup_form_id != "") {
    return mounted_startup_form_id;
  }

  return normalized_startup_form_id;
}

private function runtime_ui_resolve_direct_startup_form_id_with_mounted_targets(
  app_node_json: Json,
  mounted_targets: Json
): string {
  let direct_startup_form_id = Runtime.json_to_str(
    runtime_ui_property_value(app_node_json, "startup_form_id")
  );
  if (direct_startup_form_id == "") {
    return "";
  }

  return runtime_ui_resolve_startup_form_id_against_mounted_targets(
    mounted_targets,
    direct_startup_form_id
  );
}

private function runtime_ui_find_startup_form_id(app_node_json: Json): string {
  return runtime_ui_find_startup_form_id_with_mounted_targets(
    app_node_json,
    runtime_ui_build_mounted_form_target_index_for_app(app_node_json)
  );
}

private function runtime_ui_build_app_metadata_with_forms_and_mounted_targets(
  app_node_json: Json,
  forms: Json,
  mounted_targets: Json
): Json {
  app_node_json = runtime_ui_resolve_canonical_declaration_node(app_node_json);
  let app_id = runtime_ui_resolve_declaration_primary_symbol_name(app_node_json);
  let form_count = 0;
  let app_text_properties = runtime_ui_collect_declaration_text_properties(
    app_node_json,
    ["title", "description", "icon", "module", "technical"]
  );
  let app_title = runtime_ui_resolve_published_string_property_with_reflected_text(
    app_node_json,
    "title",
    app_text_properties
  );
  let app_description = runtime_ui_resolve_published_string_property_with_reflected_text(
    app_node_json,
    "description",
    app_text_properties
  );
  let app_icon = runtime_ui_resolve_published_string_property_with_reflected_text(
    app_node_json,
    "icon",
    app_text_properties
  );
  let app_module = runtime_ui_resolve_published_string_property_with_reflected_text(
    app_node_json,
    "module",
    app_text_properties
  );
  let app_technical = runtime_ui_resolve_published_string_property_with_reflected_text(
    app_node_json,
    "technical",
    app_text_properties
  );
  let startup_form_id = runtime_ui_resolve_direct_startup_form_id_with_mounted_targets(
    app_node_json,
    mounted_targets
  );
  if (startup_form_id == "") {
    startup_form_id = runtime_ui_find_startup_form_id_with_mounted_targets(
      app_node_json,
      mounted_targets
    );
  }

  for (_ in forms) {
    form_count = form_count + 1;
  }

  return {
    "app_id": app_id,
    "id": app_id,
    "title": app_title != "" ? app_title : app_id,
    "description": app_description != "" ? app_description : null,
    "icon": app_icon != "" ? app_icon : null,
    "module": app_module != "" ? app_module : null,
    "technical": app_technical != "" ? app_technical : app_id,
    "technical_name": app_technical != "" ? app_technical : null,
    "startup_form_id": startup_form_id != "" ? startup_form_id : null,
    "forms": forms,
    "form_count": form_count,
    "source_path": runtime_ui_node_source_path(app_node_json),
    "debug": runtime_ui_build_node_debug_descriptor(app_node_json)
  };
}

private function runtime_ui_build_app_metadata_with_forms(app_node_json: Json, forms: Json): Json {
  return runtime_ui_build_app_metadata_with_forms_and_mounted_targets(
    app_node_json,
    forms,
    runtime_ui_resolve_app_mounted_targets(app_node_json)
  );
}

private function runtime_ui_build_app_metadata_from_lookup(
  app_node_json: Json,
  form_lookup: Json
): Json {
  return runtime_ui_build_app_metadata_from_lookup_mode(
    app_node_json,
    form_lookup,
    false
  );
}

private function runtime_ui_build_app_metadata_from_lookup_mode(
  app_node_json: Json,
  form_lookup: Json,
  use_detailed_metadata: bool
): Json {
  return runtime_ui_build_app_metadata_with_forms_and_mounted_targets(
    app_node_json,
    runtime_ui_collect_form_nodes_with_builder(form_lookup.ordered ?? [], use_detailed_metadata),
    form_lookup.mounted_targets
  );
}

private function runtime_ui_build_app_metadata_with_lookup_mode(
  app_node_json: Json,
  use_detailed_metadata: bool
): Json {
  let form_lookup = runtime_ui_resolve_app_form_lookup(app_node_json);
  return use_detailed_metadata
    ? runtime_ui_build_detailed_app_metadata_from_lookup(app_node_json, form_lookup)
    : runtime_ui_build_app_metadata_from_lookup(app_node_json, form_lookup);
}

private function runtime_ui_build_app_metadata(app_node_json: Json): Json {
  return runtime_ui_build_app_metadata_with_lookup_mode(app_node_json, false);
}

private function runtime_ui_collect_detailed_forms_for_app(app_node_json: Json): Json {
  return runtime_ui_collect_forms_for_app_with_builder(app_node_json, true);
}

private function runtime_ui_build_detailed_app_metadata_from_lookup(
  app_node_json: Json,
  form_lookup: Json
): Json {
  return runtime_ui_build_app_metadata_from_lookup_mode(
    app_node_json,
    form_lookup,
    true
  );
}

private function runtime_ui_build_detailed_app_metadata(app_node_json: Json): Json {
  return runtime_ui_build_app_metadata_with_lookup_mode(app_node_json, true);
}

private function runtime_ui_resolve_node_normalized_symbol_name(node_json: Json): string {
  if (node_json == null) {
    return "";
  }

  let normalized_symbol_name = Runtime.json_to_str(
    runtime_ui_property_value(node_json, "normalized_symbol_name")
  );
  if (normalized_symbol_name != "") {
    return normalized_symbol_name;
  }

  let node_id = runtime_ui_resolve_ast_node_id(node_json);
  if (node_id == "") {
    return "";
  }

  let node_kind = runtime_ui_node_kind(node_json);
  let event_declaration_kinds: Json = [
    "buttonEvent",
    "controlEvent",
    "formEvent"
  ];
  if (runtime_ui_symbol_list_contains(event_declaration_kinds, node_kind)) {
    let event_callable_alias = runtime_ui_find_first_descendant_name_fragment_value(
      node_id,
      "callable_alias"
    );
    if (event_callable_alias != "") {
      return event_callable_alias;
    }
    return "";
  }
  let identifier_node_id = runtime_ui_find_symbol_identifier_node_id(node_json);
  if (identifier_node_id == "") {
    return "";
  }

  let identifier_node_json = ast.node_to_json(identifier_node_id);
  return Runtime.json_to_str(
    runtime_ui_property_value(identifier_node_json, "normalized_symbol_name")
  );
}

private function runtime_ui_matches_app_id(app_node_json: Json, app_id: string): bool {
  let normalized_app_id = Runtime.json_to_str(app_id);
  if (app_node_json == null || normalized_app_id == "") {
    return false;
  }

  let canonical_app_id = Runtime.json_to_str(
    runtime_ui_published_property_value(app_node_json, "app_id")
  );
  if (canonical_app_id == normalized_app_id) {
    return true;
  }

  let symbol_name = runtime_ui_resolve_declaration_primary_symbol_name(app_node_json);
  if (symbol_name == normalized_app_id) {
    return true;
  }

  let normalized_symbol_name = runtime_ui_resolve_node_normalized_symbol_name(app_node_json);
  if (normalized_symbol_name == "") {
    return false;
  }

  if (normalized_symbol_name == normalized_app_id) {
    return true;
  }

  if ("app." + normalized_symbol_name == normalized_app_id) {
    return true;
  }

  return "app/" + normalized_symbol_name == normalized_app_id;
}

private function runtime_ui_resolve_app_id(app_node_json: Json): string {
  if (app_node_json == null) {
    return "";
  }

  let canonical_app_id = Runtime.json_to_str(
    runtime_ui_published_property_value(app_node_json, "app_id")
  );
  if (canonical_app_id != "") {
    return canonical_app_id;
  }

  return runtime_ui_resolve_declaration_primary_symbol_name(app_node_json);
}

private function runtime_ui_find_app_node(app_id: string): Json {
  let normalized_app_id = Runtime.json_to_str(app_id);
  let app_nodes = runtime_ui_collect_app_declaration_matches();

  if (normalized_app_id == "") {
    return null;
  }

  for (app_node_match in app_nodes) {
    let app_node_id = runtime_ui_match_node_id(app_node_match);
    if (app_node_id == "") {
      continue;
    }
    let app_node_json = ast.node_to_json(app_node_id);
    if (runtime_ui_matches_app_id(app_node_json, normalized_app_id)) {
      return app_node_json;
    }
  }

  return null;
}

private function runtime_ui_find_app_metadata(app_id: string): Json {
  return runtime_ui_find_app_metadata_with_detail_mode(app_id, false);
}

private function runtime_ui_find_app_metadata_with_detail_mode(
  app_id: string,
  use_detailed_metadata: bool
): Json {
  let app_node_json = runtime_ui_find_app_node(app_id);
  if (app_node_json == null) {
    return null;
  }

  return use_detailed_metadata
    ? runtime_ui_build_detailed_app_metadata(app_node_json)
    : runtime_ui_build_app_metadata(app_node_json);
}

private function runtime_ui_find_detailed_app_metadata(app_id: string): Json {
  return runtime_ui_find_app_metadata_with_detail_mode(app_id, true);
}

private function runtime_ui_find_form_metadata(app_metadata: Json, form_id: string): Json {
  let forms = app_metadata["forms"] ?? [];

  for (form_metadata in forms) {
    if (Runtime.json_to_str(form_metadata["form_id"]) == form_id) {
      return form_metadata;
    }
  }

  return null;
}

private function runtime_ui_find_control_metadata(form_metadata: Json, control_id: string): Json {
  let controls = runtime_ui_form_controls(form_metadata);

  for (control_metadata in controls) {
    if (Runtime.json_to_str(control_metadata["id"]) == control_id) {
      return control_metadata;
    }
  }

  return null;
}

private function runtime_ui_find_button_metadata(form_metadata: Json, button_id: string): Json {
  let buttons = form_metadata["buttons"] ?? [];

  for (button_metadata in buttons) {
    if (Runtime.json_to_str(button_metadata["id"]) == button_id) {
      return button_metadata;
    }
  }

  return null;
}

private function runtime_ui_find_first_node_match_by_symbol_name(
  node_matches: Json,
  symbol_name: string
): Json {
  let normalized_symbol_name = Runtime.json_to_str(symbol_name);
  if (normalized_symbol_name == "") {
    return null;
  }

  for (node_match in node_matches ?? []) {
    let node_json = ast.node_to_json(runtime_ui_match_node_id(node_match));
    if (runtime_ui_resolve_node_symbol_name(node_json) == normalized_symbol_name) {
      return node_json;
    }
  }

  return null;
}

private function runtime_ui_find_button_node_in_form_lookup(
  form_lookup: Json,
  form_id: string,
  button_id: string
): Json {
  let normalized_button_id = Runtime.json_to_str(button_id);
  if (normalized_button_id == "") {
    return null;
  }

  let form_node_json = runtime_ui_find_form_node_in_lookup(form_lookup, form_id);
  if (form_node_json == null) {
    return null;
  }

  let form_node_id = runtime_ui_resolve_ast_node_id(form_node_json);
  let button_nodes = runtime_ui_collect_descendant_node_matches_by_kind(
    form_node_id,
    "buttonDeclaration"
  ) ?? [];
  return runtime_ui_find_first_node_match_by_symbol_name(button_nodes, normalized_button_id);
}

private function runtime_ui_find_button_node_for_form(
  app_node_json: Json,
  form_id: string,
  button_id: string
): Json {
  return runtime_ui_find_button_node_in_form_lookup(
    runtime_ui_resolve_app_form_lookup(app_node_json),
    form_id,
    button_id
  );
}

private function runtime_ui_resolve_button_click_dispatch_target_in_lookup(
  form_lookup: Json,
  form_id: string,
  button_id: string
): string {
  let button_node_json = runtime_ui_find_button_node_in_form_lookup(form_lookup, form_id, button_id);
  if (button_node_json == null) {
    return "";
  }

  let button_event_analysis = runtime_ui_analyze_button_event_metadata(button_node_json);
  return runtime_ui_resolve_button_click_dispatch_target_from_analysis(button_event_analysis);
}

private function runtime_ui_resolve_button_click_dispatch_target_for_form(
  app_node_json: Json,
  form_id: string,
  button_id: string
): string {
  return runtime_ui_resolve_button_click_dispatch_target_in_lookup(
    runtime_ui_resolve_app_form_lookup(app_node_json),
    form_id,
    button_id
  );
}

private function runtime_ui_build_initial_form_state(
  form_metadata: Json,
  open_args: Json?
): Json {
  let state_fields = form_metadata["state_fields"] ?? [];
  let form_state: Json = {};
  let state_field_count = 0;

  for (state_field in state_fields) {
    let field_name = Runtime.json_to_str(state_field["name"]);
    if (field_name == "") {
      continue;
    }
    state_field_count = state_field_count + 1;
    if (open_args != null && open_args[field_name] != null) {
      form_state[field_name] = open_args[field_name];
    } else {
      form_state[field_name] = runtime_ui_build_default_state_field_value(state_field);
    }
  }

  if (state_field_count == 0 && open_args != null) {
    return open_args;
  }

  return form_state;
}

private function runtime_ui_resolve_form_binding_type(form_metadata: Json): string {
  if (form_metadata == null) {
    return "";
  }

  return Runtime.json_to_str(form_metadata["ui_from"]);
}

private function runtime_ui_find_child_node_id_by_kind(
  parent_node_id: string,
  child_kind: string
): string {
  return runtime_ui_find_direct_child_node_id_by_kind(parent_node_id, child_kind);
}

private function runtime_ui_find_direct_child_node_id_by_kind(
  parent_node_id: string,
  child_kind: string
): string {
  let normalized_parent_node_id = Runtime.json_to_str(parent_node_id);
  let normalized_child_kind = Runtime.json_to_str(child_kind);
  if (normalized_parent_node_id == "" || normalized_child_kind == "") {
    return "";
  }

  for (child_node_id in runtime_ui_list_child_node_ids(normalized_parent_node_id)) {
    let child_node_json = ast.node_to_json(Runtime.json_to_str(child_node_id));
    if (runtime_ui_node_kind(child_node_json) == normalized_child_kind) {
      return Runtime.json_to_str(child_node_id);
    }
  }

  return "";
}

private function runtime_ui_find_first_child_node_id_by_kinds(
  parent_node_id: string,
  child_kinds: Json
): string {
  let ordered_child_node_ids = runtime_ui_collect_ordered_node_ids_by_kinds(
    parent_node_id,
    child_kinds,
    "child"
  ) ?? [];
  return Runtime.json_to_str(ordered_child_node_ids[0]);
}

private function runtime_ui_collect_ordered_node_ids_by_kinds(
  node_id: string,
  node_kinds: Json,
  traversal_scope: string
): Json {
  let normalized_node_id = Runtime.json_to_str(node_id);
  let normalized_traversal_scope = Runtime.json_to_str(traversal_scope);
  let collected_node_ids: Json = [];
  let collected_count = 0;
  if (normalized_node_id == "" || normalized_traversal_scope == "") {
    return collected_node_ids;
  }

  for (node_kind in node_kinds ?? []) {
    let normalized_node_kind = Runtime.json_to_str(node_kind);
    if (normalized_node_kind == "") {
      continue;
    }

    if (normalized_traversal_scope == "child") {
      let child_node_id = runtime_ui_find_child_node_id_by_kind(
        normalized_node_id,
        normalized_node_kind
      );
      if (child_node_id != "") {
        collected_node_ids[collected_count] = child_node_id;
        collected_count = collected_count + 1;
      }
      continue;
    }

    let descendant_matches = runtime_ui_collect_descendant_node_matches_by_kind(
      normalized_node_id,
      normalized_node_kind
    ) ?? [];
    for (descendant_match in descendant_matches) {
      let descendant_node_id = runtime_ui_match_node_id(descendant_match);
      if (descendant_node_id == "") {
        continue;
      }
      collected_node_ids[collected_count] = descendant_node_id;
      collected_count = collected_count + 1;
    }
  }

  return collected_node_ids;
}

private function runtime_ui_identifier_node_has_direct_symbol_name(identifier_node_id: string): bool {
  let normalized_identifier_node_id = Runtime.json_to_str(identifier_node_id);
  if (normalized_identifier_node_id == "") {
    return false;
  }

  return runtime_ui_direct_node_symbol_name(
    ast.node_to_json(normalized_identifier_node_id)
  ) != "";
}

private function runtime_ui_find_symbol_identifier_node_id(node_json: Json): string {
  if (node_json == null) {
    return "";
  }

  let node_id = runtime_ui_resolve_ast_node_id(node_json);
  if (node_id == "") {
    return "";
  }
  let node_kind = runtime_ui_node_kind(node_json);

  let identifier_node_id = "";
  if (node_kind == "buttonDeclaration") {
    let button_declaration_node_id = runtime_ui_find_button_declaration_node_id(node_id);
    if (button_declaration_node_id != "") {
      identifier_node_id = runtime_ui_find_first_child_node_id_by_kinds(
        button_declaration_node_id,
        [
          "identifier",
          "qualifiedIdentifier"
        ]
      );
    }
  }
  if (identifier_node_id == "") {
    identifier_node_id = runtime_ui_find_first_child_node_id_by_kinds(
      node_id,
      [
        "identifier",
        "qualifiedIdentifier"
      ]
    );
  }
  if (
    identifier_node_id != ""
    && !runtime_ui_identifier_node_has_direct_symbol_name(identifier_node_id)
  ) {
    identifier_node_id = "";
  }
  if (identifier_node_id == "") {
    let descendant_identifier_node_ids = runtime_ui_collect_descendant_node_ids_by_kinds(
      node_id,
      [
        "identifier",
        "qualifiedIdentifier"
      ]
    ) ?? [];
    for (descendant_identifier_node_id in descendant_identifier_node_ids) {
      if (
        runtime_ui_identifier_node_has_direct_symbol_name(
          Runtime.json_to_str(descendant_identifier_node_id)
        )
      ) {
        return Runtime.json_to_str(descendant_identifier_node_id);
      }
    }
  }

  return identifier_node_id;
}

private function runtime_ui_resolve_node_symbol_name(node_json: Json): string {
  if (node_json == null) {
    return "";
  }

  let direct_symbol_name = runtime_ui_direct_node_symbol_name(node_json);
  if (direct_symbol_name != "") {
    return direct_symbol_name;
  }

  let node_id = runtime_ui_resolve_ast_node_id(node_json);
  if (node_id == "") {
    return "";
  }

  let identifier_node_id = runtime_ui_find_symbol_identifier_node_id(node_json);
  if (identifier_node_id == "") {
    return "";
  }

  let identifier_node_json = ast.node_to_json(identifier_node_id);
  return runtime_ui_direct_node_symbol_name(identifier_node_json);
}

private function runtime_ui_build_node_debug_descriptor(node_json: Json): Json {
  if (node_json == null) {
    return null;
  }

  let node_id = runtime_ui_resolve_ast_node_id(node_json);
  let kind = runtime_ui_node_kind(node_json);
  let symbol = runtime_ui_resolve_node_symbol_name(node_json);
  let source_path = runtime_ui_node_source_path(node_json);
  let span = runtime_ui_node_span(node_json);

  if (node_id == "" && kind == "" && symbol == "" && source_path == "" && span == null) {
    return null;
  }

  return {
    "node_id": node_id,
    "kind": kind,
    "symbol": symbol,
    "source_path": source_path,
    "span": span
  };
}

private function runtime_ui_collect_declaration_text_properties(
  node_json: Json,
  property_names: Json
): Json {
  let collected_properties: Json = {};
  if (node_json == null) {
    return collected_properties;
  }

  let node_id = runtime_ui_resolve_ast_node_id(node_json);
  if (node_id == "") {
    return collected_properties;
  }

  let property_node_kinds: Json = [];
  let node_kind = runtime_ui_node_kind(node_json);
  if (runtime_ui_is_form_declaration_kind(node_kind)) {
    property_node_kinds = [
      "formHeaderProperty",
      "formInlineHeaderProperty"
    ];
  } else if (node_kind == "controlDeclaration" || node_kind == "formInlineControlField") {
    property_node_kinds = [
      "formFieldProperty",
      "formInlineFieldProperty"
    ];
  } else if (node_kind == "buttonDeclaration" || node_kind == "buttonMenuOptionDeclaration") {
    for (button_property_analysis in runtime_ui_collect_button_property_node_analyses(node_json)) {
      runtime_ui_assign_text_properties_from_property_analysis(
        collected_properties,
        button_property_analysis,
        property_names
      );
    }
  } else if (runtime_ui_is_app_declaration_kind(node_kind)) {
    property_node_kinds = [
      "appHeaderProperty",
      "appInlineHeaderProperty"
    ];
  }

  for (property_node_kind in property_node_kinds) {
    let property_matches = runtime_ui_collect_descendant_node_matches_by_kind(
      node_id,
      Runtime.json_to_str(property_node_kind)
    ) ?? [];
    for (property_match in property_matches) {
      let property_node_id = runtime_ui_match_node_id(property_match);
      if (property_node_id == "") {
        continue;
      }

      if (
        node_kind == "controlDeclaration"
        || node_kind == "formInlineControlField"
      ) {
        let property_key_node_id = runtime_ui_find_child_node_id_by_kind(
          property_node_id,
          "formFieldPropertyKey"
        );
        let property_key_symbols = runtime_ui_collect_descendant_symbol_names(property_key_node_id);
        let property_value_text = runtime_ui_resolve_form_field_property_text_value(
          property_node_id
        );
        if (property_value_text == "") {
          continue;
        }

        for (property_name in property_names ?? []) {
          let normalized_property_name = Runtime.json_to_str(property_name);
          if (
            normalized_property_name != ""
            && Runtime.json_to_str(collected_properties[normalized_property_name]) == ""
            && runtime_ui_form_field_property_key_matches_name(
              property_key_symbols,
              normalized_property_name
            )
          ) {
            collected_properties[normalized_property_name] = property_value_text;
          }
        }
        continue;
      }

      let property_node_analysis = runtime_ui_analyze_property_node(property_node_id);
      let property_literal_text = Runtime.json_to_str(property_node_analysis["literal_text"]);
      if (property_literal_text == "") {
        continue;
      }

      let property_symbol_names = property_node_analysis["symbol_names"] ?? [];
      for (property_name in property_names ?? []) {
        let normalized_property_name = Runtime.json_to_str(property_name);
        if (
          normalized_property_name != ""
          && Runtime.json_to_str(collected_properties[normalized_property_name]) == ""
          && runtime_ui_symbol_list_contains(property_symbol_names, normalized_property_name)
        ) {
          collected_properties[normalized_property_name] = property_literal_text;
        }
      }
    }
  }

  for (property_name in property_names ?? []) {
    let normalized_property_name = Runtime.json_to_str(property_name);
    if (normalized_property_name == "") {
      continue;
    }
    if (Runtime.json_to_str(collected_properties[normalized_property_name]) != "") {
      continue;
    }
    let direct_property_text = Runtime.json_to_str(
      runtime_ui_property_value(node_json, normalized_property_name)
    );
    if (direct_property_text != "") {
      collected_properties[normalized_property_name] = direct_property_text;
    }
  }

  return collected_properties;
}

private function runtime_ui_node_or_descendant_matches_internal(
  node_id: string,
  expected_kind: string,
  expected_symbol_name: string
): bool {
  return runtime_ui_find_first_matching_descendant_value_internal(
    node_id,
    "",
    "",
    expected_kind,
    expected_symbol_name
  ) != "";
}

private function runtime_ui_node_or_descendant_has_kind(
  node_id: string,
  expected_kind: string
): bool {
  return runtime_ui_node_or_descendant_matches_internal(node_id, expected_kind, "");
}

private function runtime_ui_find_first_descendant_symbol_name_internal(
  node_id: string,
  skipped_kind: string
): string {
  return runtime_ui_find_first_descendant_symbol_name_by_mode_internal(
    node_id,
    skipped_kind,
    false
  );
}

private function runtime_ui_find_first_descendant_symbol_name(node_id: string): string {
  return runtime_ui_find_first_descendant_symbol_name_internal(node_id, "");
}

private function runtime_ui_find_first_descendant_symbol_name_skipping_kind(
  node_id: string,
  skipped_kind: string
): string {
  return runtime_ui_find_first_descendant_symbol_name_internal(node_id, skipped_kind);
}

private function runtime_ui_find_first_descendant_literal_text(node_id: string): string {
  return runtime_ui_find_first_descendant_text_value_internal(node_id, "literal_text", "");
}

private function runtime_ui_node_or_descendant_has_symbol_name(
  node_id: string,
  expected_symbol_name: string
): bool {
  return runtime_ui_node_or_descendant_matches_internal(node_id, "", expected_symbol_name);
}

private function runtime_ui_find_declaration_text_property(
  node_json: Json,
  property_name: string
): string {
  let normalized_property_name = Runtime.json_to_str(property_name);
  if (normalized_property_name == "") {
    return "";
  }

  let collected_properties = runtime_ui_collect_declaration_text_properties(
    node_json,
    [normalized_property_name]
  );
  return Runtime.json_to_str(collected_properties[normalized_property_name]);
}

private function runtime_ui_find_named_declaration_node_by_kind(
  declaration_kind: string,
  symbol_name: string
): Json {
  let normalized_declaration_kind = Runtime.json_to_str(declaration_kind);
  let normalized_symbol_name = Runtime.json_to_str(symbol_name);
  if (normalized_declaration_kind == "" || normalized_symbol_name == "") {
    return null;
  }

  let declaration_nodes = ast.list_nodes_by_kind(normalized_declaration_kind) ?? [];
  return runtime_ui_find_first_node_match_by_symbol_name(
    declaration_nodes,
    normalized_symbol_name
  );
}

private function runtime_ui_find_named_declaration_in_kinds(
  declaration_kinds: Json,
  symbol_name: string
): Json {
  let resolution: Json = {
    "node": null,
    "kind": ""
  };
  let normalized_symbol_name = Runtime.json_to_str(symbol_name);
  if (normalized_symbol_name == "") {
    return resolution;
  }

  for (declaration_kind in declaration_kinds ?? []) {
    let normalized_declaration_kind = Runtime.json_to_str(declaration_kind);
    if (normalized_declaration_kind == "") {
      continue;
    }

    let declaration_node = runtime_ui_find_named_declaration_node_by_kind(
      normalized_declaration_kind,
      normalized_symbol_name
    );
    if (declaration_node != null) {
      resolution["node"] = declaration_node;
      resolution["kind"] = normalized_declaration_kind;
      return resolution;
    }
  }

  return resolution;
}

private function runtime_ui_resolve_handler_declaration(handler_symbol: string): Json {
  let resolution: Json = {
    "node": null,
    "is_supported": false
  };
  let normalized_handler_symbol = Runtime.json_to_str(handler_symbol);
  if (normalized_handler_symbol == "") {
    return resolution;
  }

  let supported_declaration_kinds: Json = [
    "functionDeclaration",
    "validationDeclaration",
    "ruleDeclaration",
    "queryDeclaration",
    "methodDeclaration",
    "annotationMethod",
    "formEvent",
    "buttonEvent",
    "controlEvent",
    "serviceLifecycleHook"
  ];

  let supported_resolution = runtime_ui_find_named_declaration_in_kinds(
    supported_declaration_kinds,
    normalized_handler_symbol
  );
  if (supported_resolution["node"] != null) {
    resolution["node"] = supported_resolution["node"];
    resolution["is_supported"] = true;
    return resolution;
  }

  let unsupported_declaration_kinds: Json = [
    "appDeclaration",
    "formDeclaration",
    "buttonDeclaration",
    "controlDeclaration",
    "classDeclaration",
    "tableDeclaration"
  ];

  let unsupported_resolution = runtime_ui_find_named_declaration_in_kinds(
    unsupported_declaration_kinds,
    normalized_handler_symbol
  );
  if (unsupported_resolution["node"] != null) {
    resolution["node"] = unsupported_resolution["node"];
    return resolution;
  }

  return resolution;
}

private function runtime_ui_find_named_handler_declaration_node(handler_symbol: string): Json {
  return runtime_ui_resolve_handler_declaration(handler_symbol)["node"];
}

private function runtime_ui_find_handler_first_parameter_name(handler_symbol: string): string {
  let handler_declaration_node = runtime_ui_find_named_handler_declaration_node(handler_symbol);
  if (handler_declaration_node == null) {
    return "";
  }

  let handler_declaration_node_id = runtime_ui_resolve_ast_node_id(handler_declaration_node);
  if (handler_declaration_node_id == "") {
    return "";
  }

  let parameter_list_node_id = runtime_ui_find_child_node_id_by_kind(
    handler_declaration_node_id,
    "parameterList"
  );
  if (parameter_list_node_id == "") {
    return "";
  }

  for (parameter_node_id in runtime_ui_list_child_node_ids(parameter_list_node_id)) {
    let parameter_name = runtime_ui_find_first_descendant_symbol_name(
      Runtime.json_to_str(parameter_node_id)
    );
    if (parameter_name != "") {
      return parameter_name;
    }
  }

  return "";
}

private function runtime_ui_find_handler_return_type_expression_node_id(
  handler_declaration_node_id: string
): string {
  let normalized_handler_declaration_node_id = Runtime.json_to_str(handler_declaration_node_id);
  if (normalized_handler_declaration_node_id == "") {
    return "";
  }

  let function_return_type_node_id = runtime_ui_find_child_node_id_by_kind(
    normalized_handler_declaration_node_id,
    "functionReturnType"
  );
  if (function_return_type_node_id != "") {
    let wrapped_type_expression_node_id = runtime_ui_find_first_descendant_node_id_by_kind(
      function_return_type_node_id,
      "typeExpression"
    );
    if (wrapped_type_expression_node_id != "") {
      return wrapped_type_expression_node_id;
    }
  }

  return runtime_ui_find_child_node_id_by_kind(
    normalized_handler_declaration_node_id,
    "typeExpression"
  );
}

private function runtime_ui_find_handler_return_reference_symbol_name(handler_symbol: string): string {
  let handler_declaration_node = runtime_ui_find_named_handler_declaration_node(handler_symbol);
  if (handler_declaration_node == null) {
    return "";
  }

  let handler_declaration_node_id = runtime_ui_resolve_ast_node_id(handler_declaration_node);
  if (handler_declaration_node_id == "") {
    return "";
  }

  let handler_return_type_expression_node_id = runtime_ui_find_handler_return_type_expression_node_id(
    handler_declaration_node_id
  );
  if (handler_return_type_expression_node_id == "") {
    return "";
  }

  let handler_return_contract = runtime_ui_build_binding_member_type(
    handler_return_type_expression_node_id
  );
  let handler_return_reference_symbol = Runtime.json_to_str(
    handler_return_contract["symbol_name"]
  );
  if (
    Runtime.json_to_str(handler_return_contract["kind"]) == "reference"
    && runtime_ui_resolve_binding_declaration_kind(handler_return_reference_symbol) != ""
  ) {
    return handler_return_reference_symbol;
  }
  let handler_return_symbol_names = runtime_ui_collect_descendant_symbol_names(
    handler_return_type_expression_node_id
  );
  for (handler_return_symbol_name in handler_return_symbol_names ?? []) {
    let normalized_handler_return_symbol_name = Runtime.json_to_str(
      handler_return_symbol_name
    );
    if (runtime_ui_resolve_binding_declaration_kind(normalized_handler_return_symbol_name) != "") {
      return normalized_handler_return_symbol_name;
    }
  }

  return "";
}

private function runtime_ui_resolve_handler_reference_status(handler_symbol: string): string {
  let normalized_handler_symbol = Runtime.json_to_str(handler_symbol);
  if (normalized_handler_symbol == "") {
    return "resolved";
  }

  let handler_resolution = runtime_ui_resolve_handler_declaration(normalized_handler_symbol);
  let handler_declaration_node = handler_resolution["node"];
  if (handler_declaration_node != null) {
    if (handler_resolution["is_supported"] != true) {
      return "unsupported_kind";
    }
    let handler_declaration_kind = runtime_ui_node_kind(handler_declaration_node);
    let supported_dispatch_declaration_kinds: Json = [
      "functionDeclaration",
      "methodDeclaration",
      "annotationMethod",
      "formEvent",
      "buttonEvent",
      "controlEvent"
    ];
    if (!runtime_ui_symbol_list_contains(
      supported_dispatch_declaration_kinds,
      handler_declaration_kind
    )) {
      return "unsupported_kind";
    }

    if (
      handler_declaration_kind == "formEvent"
      || handler_declaration_kind == "buttonEvent"
      || handler_declaration_kind == "controlEvent"
    ) {
      return "resolved";
    }

    let handler_return_type_expression_node_id = runtime_ui_find_handler_return_type_expression_node_id(
      runtime_ui_resolve_ast_node_id(handler_declaration_node)
    );
    let handler_return_contract = runtime_ui_build_binding_member_type(
      handler_return_type_expression_node_id
    );
    if (
      Runtime.json_to_str(handler_return_contract["kind"]) != "reference"
      || Runtime.json_to_str(handler_return_contract["symbol_name"])
        != "RuntimeUiApplyExecutionResult"
    ) {
      return "invalid_return_contract";
    }

    return "resolved";
  }

  return "unresolved";
}

private function runtime_ui_build_form_debug_context(form_metadata: Json): Json {
  if (form_metadata == null) {
    return null;
  }

  let form_debug = form_metadata["debug"];
  if (form_debug != null) {
    return form_debug;
  }

  let form_id = Runtime.json_to_str(form_metadata["form_id"]);
  if (form_id == "") {
    return null;
  }

  return runtime_ui_build_node_debug_descriptor(
    runtime_ui_find_named_declaration_node_by_kind("formDeclaration", form_id)
  );
}

private function runtime_ui_build_execution_debug_context(
  form_metadata: Json,
  control_id: string,
  control_kind: string,
  handler_symbol: string,
  dispatch_target: string
): Json {
  let form_debug = runtime_ui_build_form_debug_context(form_metadata);
  let handler_debug = runtime_ui_build_node_debug_descriptor(
    runtime_ui_find_named_handler_declaration_node(handler_symbol)
  );
  let dispatch_debug = null;
  if (Runtime.json_to_str(dispatch_target) != "" && dispatch_target != handler_symbol) {
    dispatch_debug = runtime_ui_build_node_debug_descriptor(
      runtime_ui_find_named_handler_declaration_node(dispatch_target)
    );
  }

  let control_debug = null;
  if (Runtime.json_to_str(control_id) != "" || Runtime.json_to_str(control_kind) != "") {
    control_debug = {
      "control_kind": control_kind
    };
  }

  return {
    "form": form_debug,
    "handler": handler_debug,
    "dispatch": dispatch_debug,
    "control": control_debug
  };
}
