    merged_entry["placement"] = placement;
  }

  let visible = runtime_ui_metadata_entry_value(published_entry, base_entry, "visible");
  if (visible != null) {
    merged_entry["visible"] = visible;
  }

  let enabled = runtime_ui_metadata_entry_value(published_entry, base_entry, "enabled");
  if (enabled != null) {
    merged_entry["enabled"] = enabled;
  }

  let selection_path = runtime_ui_metadata_entry_text_value(
