private function runtime_ui_property_container_value(container: Json, key: string): Json {
  if (container == null || key == "") {
    return null;
  }

  let mapped_value = container[key];
  if (mapped_value != null) {
    let nested_mapped_value = mapped_value["value"];
    if (nested_mapped_value != null) {
      return nested_mapped_value;
    }
    return mapped_value;
  }

  for (entry in container ?? []) {
    if (Runtime.json_to_str(entry["key"]) != key) {
      continue;
    }
    let entry_value = entry["value"];
    let nested_entry_value = entry_value["value"];
    if (nested_entry_value != null) {
      return nested_entry_value;
    }
    return entry_value;
  }

  return null;
}

private function runtime_ui_published_property_value(node_json: Json, key: string): Json {
  if (node_json == null) {
    return null;
  }

  let fields = runtime_ui_property_container_value(
    runtime_ui_property_value(node_json, "fields"),
    key
  );
  if (fields != null) {
    return fields;
  }

  let extras = runtime_ui_property_container_value(
    runtime_ui_property_value(node_json, "extras"),
    key
  );
  if (extras != null) {
    return extras;
  }

  let properties = runtime_ui_property_container_value(
    runtime_ui_property_value(node_json, "properties"),
    key
  );
  if (properties != null) {
    return properties;
  }

  return null;
}

private function runtime_ui_resolve_metadata_bool_flag(node_json: Json, key: string): bool {
  let published_value = runtime_ui_published_property_value(node_json, key);
  if (published_value != null) {
    if (published_value == true) {
      return true;
    }
    let published_text = Runtime.json_to_str(published_value);
    if (published_text == "true") {
      return true;
    }
    if (published_text == "false") {
      return false;
    }
  }

  let direct_value = runtime_ui_property_value(node_json, key);
  if (direct_value != null) {
    if (direct_value == true) {
      return true;
    }
    let direct_text = Runtime.json_to_str(direct_value);
    if (direct_text == "true") {
      return true;
    }
    if (direct_text == "false") {
      return false;
    }
  }

  let declaration_text = runtime_ui_find_declaration_text_property(node_json, key);
  if (declaration_text == "true") {
    return true;
  }
  if (declaration_text == "false") {
    return false;
  }

  return false;
}

private function runtime_ui_has_authored_metadata_value(node_json: Json, key: string): bool {
  let normalized_key = Runtime.json_to_str(key);
  if (node_json == null || normalized_key == "") {
    return false;
  }

  if (runtime_ui_published_property_value(node_json, normalized_key) != null) {
    return true;
  }

  if (runtime_ui_property_value(node_json, normalized_key) != null) {
    return true;
  }

  return runtime_ui_find_declaration_text_property(node_json, normalized_key) != "";
}

private function runtime_ui_property_value(node_json: Json, key: string): Json {
  if (node_json == null) {
    return null;
  }

  let direct_value = node_json[key];
  if (direct_value != null) {
    return direct_value;
  }

  let properties = runtime_ui_property_container_value(node_json["properties"], key);
  if (properties != null) {
    return properties;
  }

  let fields = runtime_ui_property_container_value(node_json["fields"], key);
  if (fields != null) {
    return fields;
  }

  let extras = runtime_ui_property_container_value(node_json["extras"], key);
  if (extras != null) {
    return extras;
  }

  return null;
}

private function runtime_ui_find_metadata_entry_by_id(entries: Json, entry_id: string): Json {
  let normalized_entry_id = Runtime.json_to_str(entry_id);
  if (normalized_entry_id == "") {
    return null;
  }

  for (entry in entries ?? []) {
    if (Runtime.json_to_str(entry["id"]) == normalized_entry_id) {
      return entry;
    }
  }

  return null;
}

private function runtime_ui_find_metadata_entry_by_name(entries: Json, entry_name: string): Json {
  let normalized_entry_name = Runtime.json_to_str(entry_name);
  if (normalized_entry_name == "") {
    return null;
  }

  for (entry in entries ?? []) {
    if (Runtime.json_to_str(entry["name"]) == normalized_entry_name) {
      return entry;
    }
  }

  return null;
}

private function runtime_ui_merge_metadata_entry(base_entry: Json, published_entry: Json): Json {
  return runtime_ui_merge_json_objects(base_entry, published_entry);
}

private function runtime_ui_metadata_entry_value(
  published_entry: Json,
  base_entry: Json,
  key: string
): Json {
  let published_value = published_entry[key];
  if (published_value != null) {
    return published_value;
  }

  return base_entry[key];
}

private function runtime_ui_metadata_entry_text_value(
  published_entry: Json,
  base_entry: Json,
  key: string
): Json {
  let published_value = published_entry[key];
  if (published_value != null && Runtime.json_to_str(published_value) != "") {
    return published_value;
  }

  let base_value = base_entry[key];
  if (base_value != null) {
    return base_value;
  }

  return published_value;
}

private function runtime_ui_merge_json_objects(base_value: Json, published_value: Json): Json {
  if (published_value == null) {
    return base_value;
  }
  if (base_value == null) {
    return published_value;
  }

  let merged_value: Json = {};
  for (entry_key in base_value ?? {}) {
    merged_value[entry_key] = base_value[entry_key];
  }
  for (entry_key in published_value ?? {}) {
    merged_value[entry_key] = published_value[entry_key];
  }

  return merged_value;
}

private function runtime_ui_merge_string_lists(base_value: Json, published_value: Json): Json {
  if (published_value == null) {
    return base_value;
  }
  if (base_value == null) {
    return published_value;
  }

  let merged_value: Json = [];
  let merged_count = 0;

  for (published_entry in published_value ?? []) {
    let normalized_published_entry = Runtime.json_to_str(published_entry);
    if (normalized_published_entry == "") {
      continue;
    }
    if (runtime_ui_symbol_list_contains(merged_value, normalized_published_entry)) {
      continue;
    }
    merged_value[merged_count] = normalized_published_entry;
    merged_count = merged_count + 1;
  }

  for (base_entry in base_value ?? []) {
    let normalized_base_entry = Runtime.json_to_str(base_entry);
    if (normalized_base_entry == "") {
      continue;
    }
    if (runtime_ui_symbol_list_contains(merged_value, normalized_base_entry)) {
      continue;
    }
    merged_value[merged_count] = normalized_base_entry;
    merged_count = merged_count + 1;
  }

  return merged_value;
}

private function runtime_ui_merge_flat_json_object(base_value: Json, published_value: Json): Json {
  if (published_value == null) {
    return base_value;
  }
  if (base_value == null) {
    return published_value;
  }

  let merged_value: Json = {};
  for (entry_key in base_value ?? {}) {
    merged_value[entry_key] = base_value[entry_key];
  }
  for (entry_key in published_value ?? {}) {
    if (
      Runtime.json_to_str(published_value[entry_key]) == ""
      && base_value[entry_key] != null
    ) {
      continue;
    }
    merged_value[entry_key] = published_value[entry_key];
  }

  return merged_value;
}

private function runtime_ui_resolve_json_entry_identity(entry: Json): string {
  if (entry == null) {
    return "";
  }

  let id = Runtime.json_to_str(entry["id"]);
  if (id != "") {
    return id;
  }
  let key = Runtime.json_to_str(entry["key"]);
  if (key != "") {
    return key;
  }
  let field = Runtime.json_to_str(entry["field"]);
  if (field != "") {
    return field;
  }
  return Runtime.json_to_str(entry["name"]);
}

private function runtime_ui_find_json_entry_by_identity(entries: Json, entry_identity: string): Json {
  let normalized_entry_identity = Runtime.json_to_str(entry_identity);
  if (normalized_entry_identity == "") {
    return null;
  }

  for (entry in entries ?? []) {
    if (runtime_ui_resolve_json_entry_identity(entry) == normalized_entry_identity) {
      return entry;
    }
  }

  return null;
}

private function runtime_ui_merge_json_entry_object(base_entry: Json, published_entry: Json): Json {
  let merged_entry = runtime_ui_merge_json_objects(base_entry, published_entry);

  let id = runtime_ui_metadata_entry_text_value(published_entry, base_entry, "id");
  if (id != null) {
    merged_entry["id"] = id;
  }

  let key = runtime_ui_metadata_entry_text_value(published_entry, base_entry, "key");
  if (key != null) {
    merged_entry["key"] = key;
  }

  let field = runtime_ui_metadata_entry_text_value(published_entry, base_entry, "field");
  if (field != null) {
    merged_entry["field"] = field;
  }

  let name = runtime_ui_metadata_entry_text_value(published_entry, base_entry, "name");
  if (name != null) {
    merged_entry["name"] = name;
  }

  let label = runtime_ui_metadata_entry_text_value(published_entry, base_entry, "label");
  if (label != null) {
    merged_entry["label"] = label;
  }

  return merged_entry;
}

private function runtime_ui_merge_named_json_entry_object(base_entry: Json, published_entry: Json): Json {
  let merged_entry = runtime_ui_merge_json_objects(base_entry, published_entry);

  let kind = runtime_ui_metadata_entry_text_value(published_entry, base_entry, "kind");
  if (kind != null) {
    merged_entry["kind"] = kind;
  }

  let name = runtime_ui_metadata_entry_text_value(published_entry, base_entry, "name");
  if (name != null) {
    merged_entry["name"] = name;
  }

  let path = runtime_ui_metadata_entry_text_value(published_entry, base_entry, "path");
  if (path != null) {
    merged_entry["path"] = path;
  }

  let handler = runtime_ui_metadata_entry_text_value(published_entry, base_entry, "handler");
  if (handler != null) {
    merged_entry["handler"] = handler;
  }

  let dispatch_target = runtime_ui_metadata_entry_text_value(
    published_entry,
    base_entry,
    "dispatch_target"
  );
  if (dispatch_target != null) {
    merged_entry["dispatch_target"] = dispatch_target;
  }

  let field_name = runtime_ui_metadata_entry_text_value(published_entry, base_entry, "field_name");
  if (field_name != null) {
    merged_entry["field_name"] = field_name;
  }

  let binding_type = runtime_ui_metadata_entry_text_value(
    published_entry,
    base_entry,
    "binding_type"
  );
  if (binding_type != null) {
    merged_entry["binding_type"] = binding_type;
  }

  let binding_kind = runtime_ui_metadata_entry_text_value(
    published_entry,
    base_entry,
    "binding_kind"
  );
  if (binding_kind != null) {
    merged_entry["binding_kind"] = binding_kind;
  }

  let declaration_kind = runtime_ui_metadata_entry_text_value(
    published_entry,
    base_entry,
    "declaration_kind"
  );
  if (declaration_kind != null) {
    merged_entry["declaration_kind"] = declaration_kind;
  }

  let member_declaration_kind = runtime_ui_metadata_entry_text_value(
    published_entry,
    base_entry,
    "member_declaration_kind"
  );
  if (member_declaration_kind != null) {
    merged_entry["member_declaration_kind"] = member_declaration_kind;
  }

  let member_type = runtime_ui_metadata_entry_text_value(
    published_entry,
    base_entry,
    "member_type"
  );
  if (member_type != null) {
    merged_entry["member_type"] = member_type;
  }

  return merged_entry;
}

private function runtime_ui_merge_json_entry_lists(base_value: Json, published_value: Json): Json {
  if (published_value == null) {
    return base_value;
  }
  if (base_value == null) {
    return published_value;
  }

  let merged_value: Json = [];
  let merged_count = 0;

  for (base_entry in base_value ?? []) {
    let base_identity = runtime_ui_resolve_json_entry_identity(base_entry);
    let published_entry = runtime_ui_find_json_entry_by_identity(published_value, base_identity);
    if (published_entry != null) {
      merged_value[merged_count] = runtime_ui_merge_json_entry_object(base_entry, published_entry);
    } else {
      merged_value[merged_count] = base_entry;
    }
    merged_count = merged_count + 1;
  }

  for (published_entry in published_value ?? []) {
    let published_identity = runtime_ui_resolve_json_entry_identity(published_entry);
    if (published_identity == "") {
      continue;
    }
    if (runtime_ui_find_json_entry_by_identity(base_value, published_identity) != null) {
      continue;
    }
    merged_value[merged_count] = published_entry;
    merged_count = merged_count + 1;
  }

  return merged_value;
}

private function runtime_ui_merge_metadata_object_value(
  published_entry: Json,
  base_entry: Json,
  key: string
): Json {
  let published_value = published_entry[key];
  let base_value = base_entry[key];

  return runtime_ui_merge_flat_json_object(base_value, published_value);
}

private function runtime_ui_merge_named_json_objects(base_value: Json, published_value: Json): Json {
  if (published_value == null) {
    return base_value;
  }
  if (base_value == null) {
    return published_value;
  }

  let merged_value = runtime_ui_merge_json_objects(base_value, {});
  for (entry_key in published_value ?? {}) {
    merged_value[entry_key] = runtime_ui_merge_named_json_entry_object(
      base_value[entry_key],
      published_value[entry_key]
    );
  }

  return merged_value;
}

private function runtime_ui_merge_named_metadata_object_value(
  published_entry: Json,
  base_entry: Json,
  key: string
): Json {
  let published_value = published_entry[key];
  let base_value = base_entry[key];

  if (published_value == null) {
    return base_value;
  }
  if (base_value == null) {
    return published_value;
  }

  return runtime_ui_merge_named_json_objects(base_value, published_value);
}

private function runtime_ui_merge_runtime_event_entry(base_event: Json, published_event: Json): Json {
  let merged_event = runtime_ui_merge_named_json_entry_object(base_event, published_event);
  let base_dispatch_target = Runtime.json_to_str(base_event["dispatch_target"]);
  let published_dispatch_target = Runtime.json_to_str(published_event["dispatch_target"]);

  if (
    base_dispatch_target != ""
    && published_dispatch_target != ""
    && base_dispatch_target != published_dispatch_target
    && runtime_ui_resolve_handler_reference_status(base_dispatch_target) == "unresolved"
    && runtime_ui_resolve_handler_reference_status(published_dispatch_target) == "unresolved"
  ) {
    merged_event["dispatch_target"] = base_dispatch_target;
  }

  return merged_event;
}

private function runtime_ui_merge_runtime_event_map(base_events: Json, published_events: Json): Json {
  if (published_events == null) {
    return base_events;
  }
  if (base_events == null) {
    return published_events;
  }

  let merged_events = runtime_ui_merge_json_objects(base_events, {});
  for (event_name in published_events ?? {}) {
    merged_events[event_name] = runtime_ui_merge_runtime_event_entry(
      base_events[event_name],
      published_events[event_name]
    );
  }

  return merged_events;
}

private function runtime_ui_merge_control_source_value(base_entry: Json, published_entry: Json): Json {
  let base_source = base_entry["source"];
  let published_source = published_entry["source"];

  if (published_source == null) {
    return base_source;
  }
  if (base_source == null) {
    return published_source;
  }

  let merged_source = runtime_ui_merge_named_json_entry_object(base_source, published_source);
  let base_name = Runtime.json_to_str(base_source["name"]);
  let published_name = Runtime.json_to_str(published_source["name"]);
  let published_handler = Runtime.json_to_str(published_source["handler"]);
  let published_path = Runtime.json_to_str(published_source["path"]);
  let published_dispatch_target = Runtime.json_to_str(published_source["dispatch_target"]);

  if (
    base_name != ""
    && published_name != ""
    && base_name != published_name
    && published_handler == ""
    && published_path == ""
    && published_dispatch_target == ""
  ) {
    merged_source["name"] = base_name;
    let base_kind = Runtime.json_to_str(base_source["kind"]);
    if (base_kind != "") {
      merged_source["kind"] = base_kind;
    }
  }

  return merged_source;
}

private function runtime_ui_merge_control_metadata_entry(base_entry: Json, published_entry: Json): Json {
  let merged_entry = runtime_ui_merge_metadata_entry(base_entry, published_entry);

  let type = runtime_ui_metadata_entry_text_value(published_entry, base_entry, "type");
  if (type != null) {
    merged_entry["type"] = type;
  }

  let control_id = runtime_ui_metadata_entry_text_value(published_entry, base_entry, "control_id");
  if (control_id != null) {
    merged_entry["control_id"] = control_id;
  }

  let name = runtime_ui_metadata_entry_text_value(published_entry, base_entry, "name");
  if (name != null) {
    merged_entry["name"] = name;
  }

  let grow = runtime_ui_metadata_entry_value(published_entry, base_entry, "grow");
  if (grow != null) {
    merged_entry["grow"] = grow;
  }

  let binding_path = runtime_ui_metadata_entry_text_value(published_entry, base_entry, "binding_path");
  if (binding_path != null) {
    merged_entry["binding_path"] = binding_path;
  }

  let height_lines = runtime_ui_metadata_entry_text_value(published_entry, base_entry, "height_lines");
  if (height_lines != null) {
    merged_entry["height_lines"] = height_lines;
  }

  let max_length = runtime_ui_metadata_entry_value(published_entry, base_entry, "max_length");
  if (max_length != null) {
    merged_entry["max_length"] = max_length;
  }

  let display_length = runtime_ui_metadata_entry_value(
    published_entry,
    base_entry,
    "display_length"
  );
  if (display_length != null) {
    merged_entry["display_length"] = display_length;
  }

  let input_width = runtime_ui_metadata_entry_value(published_entry, base_entry, "input_width");
  if (input_width != null) {
    merged_entry["input_width"] = input_width;
  }

  let columns = runtime_ui_merge_json_entry_lists(base_entry["columns"], published_entry["columns"]);
  if (columns != null) {
    merged_entry["columns"] = columns;
  }

  let selection = runtime_ui_metadata_entry_value(published_entry, base_entry, "selection");
  if (selection != null) {
    merged_entry["selection"] = selection;
  }

  let selection_path = runtime_ui_metadata_entry_text_value(
    published_entry,
    base_entry,
    "selection_path"
  );
  if (selection_path != null) {
    merged_entry["selection_path"] = selection_path;
  }

  let pagination = runtime_ui_metadata_entry_value(published_entry, base_entry, "pagination");
  if (pagination != null) {
    merged_entry["pagination"] = pagination;
  }

  let pagination_path = runtime_ui_metadata_entry_text_value(
    published_entry,
    base_entry,
    "pagination_path"
  );
  if (pagination_path != null) {
    merged_entry["pagination_path"] = pagination_path;
  }

  let source = runtime_ui_merge_control_source_value(base_entry, published_entry);
  if (source != null) {
    merged_entry["source"] = source;
  }

  let table = runtime_ui_metadata_entry_text_value(published_entry, base_entry, "table");
  if (table != null) {
    merged_entry["table"] = table;
  }

  let field = runtime_ui_metadata_entry_text_value(published_entry, base_entry, "field");
  if (field != null) {
    merged_entry["field"] = field;
  }

  let associated_fields = runtime_ui_metadata_entry_value(
    published_entry,
    base_entry,
    "associated_fields"
  );
  if (associated_fields != null) {
    merged_entry["associated_fields"] = associated_fields;
  }

  let display_field = runtime_ui_metadata_entry_text_value(
    published_entry,
    base_entry,
    "display_field"
  );
  if (display_field != null) {
    merged_entry["display_field"] = display_field;
  }

  let record_type = runtime_ui_metadata_entry_text_value(published_entry, base_entry, "record_type");
  if (record_type != null) {
    merged_entry["record_type"] = record_type;
  }

  let properties = runtime_ui_merge_flat_json_object(
    base_entry["properties"],
    published_entry["properties"]
  );
  if (properties != null) {
    merged_entry["properties"] = properties;
  }

  let events = runtime_ui_merge_runtime_event_map(
    base_entry["events"],
    published_entry["events"]
  );
  if (events != null) {
    merged_entry["events"] = events;
  }

  return merged_entry;
}

private function runtime_ui_merge_button_metadata_entry(base_entry: Json, published_entry: Json): Json {
  let merged_entry = runtime_ui_merge_metadata_entry(base_entry, published_entry);

  let label = runtime_ui_metadata_entry_text_value(published_entry, base_entry, "label");
  if (label != null) {
    merged_entry["label"] = label;
  }

  let description = runtime_ui_metadata_entry_text_value(
