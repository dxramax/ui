// ============================================================================
// Module: Runtime UI
// File:   runtime_ui.messages.bl
// Purpose: Message catalog for runtime UI apply-pipeline validation failures.
// ============================================================================

// Raised when a runtime-ui apply event omits the control identifier needed
// to resolve the reflected control runtime context.
message runtime_ui_apply_event_control_id_required {
    code: "BUI-UI-0001";
    severity: error;
    category: validation;
    message: {
        en: "Runtime UI apply event is missing the control identifier";
    };
}

// Raised when a runtime-ui apply event omits the handler symbol needed for
// explicit execution pipeline validation.
message runtime_ui_apply_event_handler_required {
    code: "BUI-UI-0002";
    severity: error;
    category: validation;
    message: {
        en: "Runtime UI apply event is missing the handler symbol";
    };
}

// Raised when a runtime-ui apply event omits the event name.
message runtime_ui_apply_event_name_required {
    code: "BUI-UI-0003";
    severity: error;
    category: validation;
    message: {
        en: "Runtime UI apply event is missing the event name";
    };
}

// Raised when a runtime-ui apply event references a control session that does
// not exist for the current form instance.
message runtime_ui_apply_event_control_session_not_found {
    code: "BUI-UI-0004";
    severity: error;
    category: validation;
    message: {
        en: "Runtime UI apply control session was not found";
    };
}

// Raised when a runtime-ui apply event references control metadata that is not
// reflected in the current form design.
message runtime_ui_apply_event_control_metadata_not_found {
    code: "BUI-UI-0005";
    severity: error;
    category: validation;
    message: {
        en: "Runtime UI apply control metadata was not found";
    };
}

// Raised when a reflected form load handler requires a canonical key-driven
// input value but the current open/runtime state does not provide it.
message runtime_ui_form_load_key_input_required {
    code: "BUI-UI-0006";
    severity: error;
    category: validation;
    message: {
        en: "Runtime UI form load is missing the required key input";
    };
}

// Raised when a requested runtime-ui app identifier is not reflected in the
// current canonical UI catalog.
message runtime_ui_app_not_found {
    code: "BUI-UI-0007";
    severity: error;
    category: validation;
    message: {
        en: "Runtime UI app was not found";
    };
}

// Raised when an open-form request omits the required app identifier.
message runtime_ui_open_form_app_id_required {
    code: "BUI-UI-0008";
    severity: error;
    category: validation;
    message: {
        en: "Runtime UI open form is missing the app identifier";
    };
}

// Raised when an open-form request omits the required form identifier.
message runtime_ui_open_form_form_id_required {
    code: "BUI-UI-0009";
    severity: error;
    category: validation;
    message: {
        en: "Runtime UI open form is missing the form identifier";
    };
}

// Raised when a requested runtime-ui form identifier is not reflected in the
// target app design.
message runtime_ui_form_not_found {
    code: "BUI-UI-0010";
    severity: error;
    category: validation;
    message: {
        en: "Runtime UI form was not found";
    };
}

// Raised when the runtime cannot create or persist the canonical app session
// state needed for an open-form request.
message runtime_ui_open_form_app_session_persist_failed {
    code: "BUI-UI-0011";
    severity: error;
    category: processing;
    message: {
        en: "Runtime UI failed to persist the app session during form open";
    };
}

// Raised when the runtime cannot create or persist the canonical form session
// state needed for an open-form request.
message runtime_ui_open_form_form_session_persist_failed {
    code: "BUI-UI-0012";
    severity: error;
    category: processing;
    message: {
        en: "Runtime UI failed to persist the form session during form open";
    };
}

// Raised when the runtime cannot materialize the reflected control-session
// state for a form-open request.
message runtime_ui_open_form_control_sessions_persist_failed {
    code: "BUI-UI-0013";
    severity: error;
    category: processing;
    message: {
        en: "Runtime UI failed to persist control sessions during form open";
    };
}

// Raised when the runtime cannot execute the reflected form-load handler
// during initial form open.
message runtime_ui_open_form_load_handler_failed {
    code: "BUI-UI-0014";
    severity: error;
    category: processing;
    message: {
        en: "Runtime UI failed to execute the form load handler";
    };
}

// Raised when a reflected form-load handler symbol does not resolve to a
// source declaration before dispatch is attempted.
message runtime_ui_open_form_load_handler_not_found {
    code: "BUI-UI-0068";
    severity: error;
    category: validation;
    message: {
        en: "Runtime UI form load handler was not found";
    };
}

// Raised when a reflected form-load handler symbol resolves to a declaration
// kind that the canonical UI runtime cannot dispatch.
message runtime_ui_open_form_load_handler_unsupported_declaration_kind {
    code: "BUI-UI-0070";
    severity: error;
    category: validation;
    message: {
        en: "Runtime UI form load handler declaration kind is not supported";
    };
}

// Raised when a reflected form-load handler symbol resolves to a callable
// whose lowered return contract is not valid for runtime-ui dispatch.
message runtime_ui_open_form_load_handler_invalid_return_contract {
    code: "BUI-UI-0071";
    severity: error;
    category: validation;
    message: {
        en: "Runtime UI form load handler return contract is invalid";
    };
}

// Raised when the runtime cannot sync canonical control runtime state during
// the open-form pipeline.
message runtime_ui_open_form_control_state_sync_failed {
    code: "BUI-UI-0015";
    severity: error;
    category: processing;
    message: {
        en: "Runtime UI failed to sync control runtime state during form open";
    };
}

// Raised when the runtime cannot compare-and-save the canonical app session
// during the open-form pipeline.
message runtime_ui_open_form_app_session_compare_and_save_failed {
    code: "BUI-UI-0016";
    severity: error;
    category: processing;
    message: {
        en: "Runtime UI failed to compare and save the app session during form open";
    };
}

// Raised when the runtime cannot atomically persist the full open-form session
// bundle after the initial form state is prepared.
message runtime_ui_open_form_atomic_persist_failed {
    code: "BUI-UI-0017";
    severity: error;
    category: processing;
    message: {
        en: "Runtime UI failed to persist the atomic session bundle during form open";
