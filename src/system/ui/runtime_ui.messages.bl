    severity: error;
    category: processing;
    message: {
        en: "Runtime UI failed to persist the atomic session bundle during apply";
    };
}

// Raised when a guarded apply request includes an invalid object-guard target
// payload and the runtime cannot determine the canonical guarded object.
message runtime_ui_apply_object_guard_target_invalid {
    code: "BUI-UI-0032A";
    severity: error;
    category: validation;
    message: {
        en: "Runtime UI apply received an invalid object guard target";
    };
}

// Raised when a guarded apply request attempts mutation without an active
// object guard owned by the current session/form context.
message runtime_ui_apply_object_guard_required {
    code: "BUI-UI-0032B";
    severity: error;
    category: processing;
    message: {
        en: "Runtime UI apply requires an active object guard before mutation";
    };
}

// Raised when a guarded apply request attempts mutation while another owner
// holds the object guard for the same canonical business object.
message runtime_ui_apply_object_guard_held_by_other {
    code: "BUI-UI-0032C";
    severity: error;
    category: processing;
    message: {
        en: "Runtime UI apply cannot mutate because another owner holds the object guard";
    };
}

